        "faq_ac4RCN": {
          "type": "faq",
          "settings": {
            "category_match": "Sofa related questions",
            "question": "How long will delivery take?",
            "answer": "<p>We offer fast delivery within 7-10 working days for most of our products. You will be provided with an estimated delivery date at checkout.</p>"
          }
        },
        "faq_NVJcEw": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "Can I choose a specific delivery date?",
            "answer": "<p>Unfortunately, we cannot guarantee a specific delivery date at the time of order. However, our delivery partner will contact you to arrange a convenient delivery slot.</p>"
          }
        },
        "faq_J3hx3j": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "Are your sofas made in the UK?",
            "answer": "<p>Yes, all our sofas are proudly manufactured in the UK. We believe in supporting local craftsmanship and ensuring the highest quality standards.</p>"
          }
        },
        "faq_FPhRqG": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "What is your return policy?",
            "answer": "<p>We offer a 14-day risk-free guarantee. If you are not completely satisfied with your purchase, you can return it within 14 days for a full refund, no questions asked.</p>"
          }
        },
        "faq_tgCpMi": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "Do you deliver to my room of choice?",
            "answer": "<p>Yes, our delivery team can deliver your new sofa to your room of choice. Please ensure there is clear access and sufficient space for the delivery.</p>"
          }
        },
        "faq_n4Yd9W": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "How do I arrange a return?",
            "answer": "<p>To arrange a return, please contact our customer support team via live chat or phone. We will guide you through the process and arrange a collection.</p>"
          }
        },
        "faq_w7epea": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "Do you offer a warranty?",
            "answer": "<p>Yes, all our sofas come with a comprehensive warranty that covers manufacturing defects.</p>"
          }
        },
        "faq_GtUEGe": {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "Do you offer financing options?",
            "answer": "<p>Yes, we offer flexible financing with up to 9 months interest-free. You can choose this option at checkout and complete a simple application.</p>"
