+
+.collection-card__delivery-banner .icon-truck {
+  color: #555555;
+  flex-shrink: 0;
+}
+
+.collection-card__delivery-banner .delivery-text {
+  font-size: 1.2rem;
+  color: #121212;
+  font-weight: 500;
+  letter-spacing: 0px;
+}
+
+.collection-card__header-row {
+  display: flex;
+  justify-content: space-between;
+  align-items: flex-start;
+  gap: 1.2rem;
+  margin-top: 1rem;
+}
+
+.collection-card__header-row .collection-card__title-link {
+  flex-grow: 1;
+}
+
+.collection-card__title {
+  font-size: 1.5rem !important;
+  font-weight: 700 !important;
+  color: #121212 !important;
+  line-height: 1.3 !important;
+}
+
+.collection-card__rating {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.4rem;
+  flex-shrink: 0;
+  margin: 0;
+}
+
+.collection-card__rating .rating-star {
+  --color-rating-star: #0f766e !important;
+  --font-size: 1.3 !important;
+  --letter-spacing: 0.2 !important;
+}
+
+.collection-card__rating .rating-count {
+  font-size: 1.2rem;
+  color: #555555;
+  font-weight: 600;
+}
+
+.collection-card__price {
+  margin-top: 0.6rem !important;
+}
+
+.collection-card__price .price {
+  font-size: 1.5rem !important;
+}
+
+.collection-card__price .price-item--regular {
+  font-weight: 700 !important;
+}
+
+.collection-card__price .price--on-sale .price-item--sale {
