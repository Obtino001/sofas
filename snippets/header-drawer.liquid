{% comment %}
  Renders the mobile menu drawer for the header.
  Implements slide-in panel navigation:
  - Main panel: menu links, search, account
  - Sub panels: slide in from right with back button + block content

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}

<style>
  /* ============================================
     MOBILE DRAWER — Core Layout
     ============================================ */
  #menu-drawer {
    background-color: rgb(var(--color-background));
  }

  .menu-drawer__inner-container {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .menu-drawer__navigation-container {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    position: relative;
  }

  /* ============================================
     DRAWER CLOSE BUTTON
     ============================================ */
  .woc-drawer-close-btn {
    position: sticky;
    top: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 1.6rem 2rem;
    background-color: rgb(var(--color-background));
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .woc-drawer-close-btn svg {
    width: 22px;
    height: 22px;
  }

  /* ============================================
     SLIDE PANELS
     ============================================ */
  .woc-drawer-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    -webkit-overflow-scrolling: touch;
  }

  .woc-drawer-panel--main {
    transform: translateX(0);
    z-index: 1;
  }

  .woc-drawer-panel--sub {
    transform: translateX(100%);
    z-index: 2;
    background-color: rgb(var(--color-background));
  }

  /* When a sub-panel is open, push main left */
  .woc-drawer-panel--main.is-hidden {
    transform: translateX(-30%);
    pointer-events: none;
  }

  .woc-drawer-panel--sub.is-active {
    transform: translateX(0);
  }

  /* ============================================
     SEARCH BAR
     ============================================ */
  .woc-drawer-search {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem 2rem;
    text-decoration: none;
    color: rgba(var(--color-foreground), 0.7);
    font-size: 1.5rem;
  }

  .woc-drawer-search svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .woc-drawer-search:hover {
    color: rgb(var(--color-foreground));
    background-color: rgba(var(--color-foreground), 0.03);
  }

  /* ============================================
     MENU ITEMS (Main Level)
     ============================================ */
  .woc-drawer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .woc-drawer-menu-item {
    display: flex;
    align-items: center;
    justify-content: start;
    gap: 10px;
    padding: 1.2rem 2rem;
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    border: none;
    background: transparent;
    width: 100%;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body-family);
    transition: background-color 0.15s ease;
    text-transform: uppercase;
  }

  .woc-drawer-menu-item:hover {
    background-color: rgba(var(--color-foreground), 0.04);
  }

  .woc-drawer-menu-item .woc-chevron {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.5;
  }

  /* ============================================
     BACK BUTTON (Sub Panel)
     ============================================ */
  .woc-drawer-back {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.4rem 2rem;
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgb(var(--color-foreground));
    border: none;
    background: transparent;
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: var(--font-body-family);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .woc-drawer-back svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .woc-drawer-back:hover {
    background-color: rgba(var(--color-foreground), 0.04);
  }

  /* ============================================
     SUB PANEL — Image Grid (2 columns)
     ============================================ */
  .woc-drawer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    padding: 20px;
  }

  .woc-drawer-grid-item {
    text-decoration: none;
    color: rgb(var(--color-foreground));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .woc-drawer-grid-item__img {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 10px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.04);
  }

  .woc-drawer-grid-item__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .woc-drawer-grid-item:hover .woc-drawer-grid-item__img img {
    transform: scale(1.03);
  }

  .woc-drawer-grid-item__title {
font-family: DM Sans;
font-weight: 500;
font-style: Medium;
font-size: 16px;
leading-trim: NONE;
line-height: 100%;
letter-spacing: 0%;
text-align: center;
color: #2B2B2B;
  }

  /* ============================================
     SUB PANEL — Promo Banner Card
     ============================================ */
  .woc-drawer-promo {
    margin: 0 20px 20px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    min-height: 200px;
    display: flex;
    align-items: center;
  }

  .woc-drawer-promo__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .woc-drawer-promo__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.15) 100%);
    z-index: 2;
  }

.woc-drawer-promo__content {
    position: relative;
    z-index: 3;
    padding: 24px;
    color: #fff;
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    min-height: 350px;
}
.woc-drawer-promo__content p{
  text-align: center;
}
  .woc-drawer-promo__timer-label {
    font-size: 1.1rem;
    display: block;
    margin-bottom: 4px;
    opacity: 0.9;
  }

  .woc-drawer-promo__timer {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 16px;
    letter-spacing: 3.5px;
  }

  .woc-drawer-promo__timer-block {
    display: flex;
    align-items: baseline;
  }

.woc-drawer-promo__heading.h1 {
    color: #2B2B2B;
    font-size: 3.2rem;
    margin: 0;
    text-align: center;
}

  .woc-drawer-promo__btn {
    display: inline-block;
    background-color: #D3A77C;
    color: #fff;
    font-size: 1.3rem;
    font-weight: 500;
    text-decoration: none;
    padding: 10px 20px;
    border-radius: 30px;
    transition: background-color 0.2s ease;
  }

  .woc-drawer-promo__btn:hover {
    background-color: #b8916a;
  }

  .woc-drawer-promo__btn--outline {
    background-color: transparent;
    border: 1px solid #fff;
  }

  .woc-drawer-promo__btn--outline:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* ============================================
     SUB PANEL — Standard menu links
     ============================================ */
  .woc-drawer-submenu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .woc-drawer-submenu-item {
    display: block;
    padding: 1.2rem 2rem;
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    transition: background-color 0.15s ease;
  }

  .woc-drawer-submenu-item:hover {
    background-color: rgba(var(--color-foreground), 0.04);
  }

  /* ============================================
     DRAWER FOOTER
     ============================================ */
  .woc-drawer-footer {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    padding: 1.5rem 2rem;
    flex-shrink: 0;
  }

  .woc-drawer-footer__account {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    font-weight: 500;
  }

  .woc-drawer-footer__account svg {
    width: 20px;
    height: 20px;
  }

  .woc-drawer-footer__account:hover {
    opacity: 0.7;
  }
</style>

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {% render 'icon-hamburger' %}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        {%- comment -%} Close Button {%- endcomment -%}
        <button class="woc-drawer-close-btn" aria-label="{{ 'accessibility.close' | t }}">
          {% render 'icon-close' %}
        </button>

        <div class="menu-drawer__navigation-container">
          {%- comment -%} ===== MAIN PANEL ===== {%- endcomment -%}
          <div class="woc-drawer-panel woc-drawer-panel--main" id="woc-main-panel">
            <nav class="menu-drawer__navigation">
              {%- comment -%} Search Link {%- endcomment -%}
              {%- if section.settings.drawer_show_search -%}
                <a href="#" class="woc-drawer-search thb-quick-search">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                  </svg>
                  Search
                </a>
              {%- endif -%}

              {%- comment -%} Menu Links {%- endcomment -%}
              <ul class="woc-drawer-menu" role="list">
                {%- for link in section.settings.menu.links -%}
                  {% assign hasBlock = false %}
                  {% for block in section.blocks %}
                    {% if block.type == 'megamenu'
                      or block.type == 'collections'
                      or block.type == 'categories'
                      or block.type == 'bottom'
                      or block.type == 'image-cards-grid'
                      or block.type == 'text-column'
                    %}
                      {% assign matched_link = block.settings.title | downcase %}
                      {% assign menu_link = link.title | downcase %}
                      {%- if matched_link == menu_link -%}
                        {% assign hasBlock = true %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}

                  <li>
                    {% if hasBlock == true or link.links != blank %}
                      {%- comment -%} Parent item with children — opens sub-panel {%- endcomment -%}
                      <a href="#"
                        class="woc-drawer-menu-item"
                        data-target="woc-sub-panel-{{ forloop.index }}"
                        aria-expanded="false"
                      >
                        {{ link.title | escape }}
                        <svg class="woc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                      </a>
                    {% else %}
                      {%- comment -%} Simple link {%- endcomment -%}
                      <a
                        href="{{ link.url }}"
                        class="woc-drawer-menu-item"
                      >
                        {{ link.title | escape }}
                      </a>
                    {% endif %}
                  </li>
                {%- endfor -%}
              </ul>

              {%- comment -%} Promo Banner for Main Drawer {%- endcomment -%}
              {% if section.settings.drawer_promo_image != blank %}
                <div class="woc-drawer-promo" style="margin-top: 2rem;">
                  <img src="{{ section.settings.drawer_promo_image | image_url: width: 1800 }}" class="woc-drawer-promo__bg" alt="{{ section.settings.drawer_promo_title }}" loading="lazy">
                  <div class="woc-drawer-promo__overlay"> </div>
                  <div class="woc-drawer-promo__content">
                    {% if section.settings.drawer_promo_title != blank %}
                      <h3 class="woc-drawer-promo__heading h1">{{ section.settings.drawer_promo_title }}</h3>
                    {% endif %}

                    {% if section.settings.drawer_promo_text != blank %}
                      <p>{{ section.settings.drawer_promo_text }}</p>
                    {% endif %}

                    {% if section.settings.drawer_promo_btn_text != blank %}
                      <a href="{{ section.settings.drawer_promo_btn_link }}" class="woc-drawer-promo__btn woc-drawer-promo__btn--outline">
                        {{ section.settings.drawer_promo_btn_text }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </nav>

            {%- comment -%} Account Link at Bottom of Main Panel {%- endcomment -%}
            {%- if section.settings.drawer_show_account and shop.customer_accounts_enabled -%}
              <div class="woc-drawer-footer">
                <a
                  href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                  class="woc-drawer-footer__account"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                  Account
                </a>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} ===== SUB PANELS (one per parent link) ===== {%- endcomment -%}
          {%- for link in section.settings.menu.links -%}
            {% assign hasBlock = false %}
            {% for block in section.blocks %}
              {% if block.type == 'megamenu'
                or block.type == 'collections'
                or block.type == 'categories'
                or block.type == 'bottom'
                or block.type == 'image-cards-grid'
                or block.type == 'text-column'
              %}
                {% assign matched_link = block.settings.title | downcase %}
                {% assign menu_link = link.title | downcase %}
                {%- if matched_link == menu_link -%}
                  {% assign hasBlock = true %}
                {% endif %}
              {% endif %}
            {% endfor %}

            {% if hasBlock == true or link.links != blank %}
              <div class="woc-drawer-panel woc-drawer-panel--sub" id="woc-sub-panel-{{ forloop.index }}" aria-hidden="true">
                {%- comment -%} Back Button {%- endcomment -%}
                <a href="#" class="woc-drawer-back" data-back>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                  MAIN MENU
                </a>

                {% if hasBlock %}
                  {%- comment -%} Block-based content (megamenu, collections, etc.) {%- endcomment -%}
                  {%- for block in section.blocks -%}
                    {% assign matched_link = block.settings.title | downcase %}
                    {% assign menu_link = link.title | downcase %}
                    {%- if matched_link == menu_link and block.type != 'bottom' -%}
                      {% case block.type %}

                        {% when 'megamenu' %}
                          {% if block.settings.widget == 'menu' %}
                            {%- comment -%} Menu List {%- endcomment -%}
                            <ul class="woc-drawer-submenu" role="list">
                              {%- for childlink in block.settings.menu_link_list_child.links -%}
                                <li>
                                  <a href="{{ childlink.url }}" class="woc-drawer-submenu-item">
                                    {{ childlink.title }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>

                          {% elsif block.settings.widget == 'image' %}
                            {%- comment -%} Image Banner {%- endcomment -%}
                            <div style="padding: 20px;">
                              {% if block.settings.image != blank %}
                                <img
                                  src="{{ block.settings.image | image_url: width: 600 }}"
                                  alt="{{ block.settings.banner_title }}"
                                  style="width: 100%; border-radius: 10px; display: block;"
                                  loading="lazy"
                                >
                              {% endif %}
                              {% if block.settings.banner_title != blank %}
                                <a href="{{ block.settings.banner_link }}" style="display: block; margin-top: 10px; font-weight: 600; font-size: 1.4rem; text-decoration: none; color: rgb(var(--color-foreground));">
                                  {{ block.settings.banner_title }}
                                </a>
                              {% endif %}
                              {% if block.settings.banner_button != blank %}
                                <a href="{{ block.settings.banner_link }}" style="font-size: 1.3rem; text-decoration: underline; color: rgba(var(--color-foreground), 0.8);">
                                  {{ block.settings.banner_button }}
                                </a>
                              {% endif %}
                            </div>

                          {% elsif block.settings.widget == 'image_grid_promo' %}
                            {%- comment -%} Image Grid + Promo Banner {%- endcomment -%}
                            <div class="woc-drawer-grid">
                              {%- for childlink in block.settings.menu_link_list_child.links limit: 6 -%}
                                <a href="{{ childlink.url }}" class="woc-drawer-grid-item">
                                  <div class="woc-drawer-grid-item__img">
                                    {%- if childlink.type == 'collection_link' and childlink.object.image != blank -%}
                                      <img src="{{ childlink.object.image | image_url: width: 400 }}" alt="{{ childlink.title }}" loading="lazy">
                                    {%- elsif childlink.type == 'product_link' and childlink.object.featured_image != blank -%}
                                      <img src="{{ childlink.object.featured_image | image_url: width: 400 }}" alt="{{ childlink.title }}" loading="lazy">
                                    {%- else -%}
                                      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                    {%- endif -%}
                                  </div>
                                  <span class="woc-drawer-grid-item__title">{{ childlink.title }}</span>
                                </a>
                              {%- endfor -%}
                            </div>

                            {%- comment -%} Promo Banner {%- endcomment -%}
                            {% if block.settings.image != blank %}
                              <div class="woc-drawer-promo">
                                <img src="{{ block.settings.image | image_url: width: 1800 }}" class="woc-drawer-promo__bg" alt="{{ block.settings.banner_title }}" loading="lazy">
                                <div class="woc-drawer-promo__overlay"> </div>
                                <div class="woc-drawer-promo__content">
                                  {% if block.settings.banner_title != blank %}
                                    <h3 class="woc-drawer-promo__heading h1">{{ block.settings.banner_title }}</h3>
                                  {% endif %}

                                  {% if block.settings.timer_date != blank %}
                                    <div>
                                      <span class="woc-drawer-promo__timer-label">{{ block.settings.timer_label }}</span>
                                      <div class="woc-drawer-promo__timer" data-end-time="{{ block.settings.timer_date }}">
                                        <div class="woc-drawer-promo__timer-block"><span class="cx-time-hh">00</span>H</div>
                                        <span>:</span>
                                        <div class="woc-drawer-promo__timer-block"><span class="cx-time-mm">00</span>M</div>
                                        <span>:</span>
                                        <div class="woc-drawer-promo__timer-block"><span class="cx-time-ss">00</span>S</div>
                                      </div>
                                    </div>
                                  {% endif %}

                                  {% if block.settings.banner_button != blank %}
                                    <a href="{{ block.settings.banner_link }}" class="woc-drawer-promo__btn">
                                      {{ block.settings.banner_button }}
                                    </a>
                                  {% endif %}
                                </div>
                              </div>
                            {% endif %}
                          {% endif %}

                        {% when 'collections' %}
                          {%- comment -%} Collection Slots (5 max) {%- endcomment -%}
                          {% if block.settings.heading != blank %}
                            <div style="padding: 14px 20px 0; font-size: 1.3rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">{{ block.settings.heading }}</div>
                          {% endif %}
                          <div class="woc-drawer-grid">
                            {% for i in (1..5) %}
                              {% capture col_id %}collection_{{i}}{% endcapture %}
                              {% capture img_id %}custom_image_{{i}}{% endcapture %}
                              {% capture title_id %}custom_title_{{i}}{% endcapture %}

                              {% assign col = block.settings[col_id] %}
                              {% assign img = block.settings[img_id] %}
                              {% assign custom_title = block.settings[title_id] %}

                              {% if col != blank %}
                                <a href="{{ col.url }}" class="woc-drawer-grid-item">
                                  <div class="woc-drawer-grid-item__img">
                                    {% if img != blank %}
                                      <img src="{{ img | image_url: width: 1400 }}" alt="{{ custom_title | default: col.title }}" loading="lazy">
                                    {% elsif col.image != blank %}
                                      <img src="{{ col.image | image_url: width: 1400 }}" alt="{{ custom_title | default: col.title }}" loading="lazy">
                                    {% endif %}
                                  </div>
                                  <span class="woc-drawer-grid-item__title">
                                    {% if custom_title != blank %}{{ custom_title }}{% else %}{{ col.title }}{% endif %}
                                  </span>
                                </a>
                              {% endif %}
                            {% endfor %}
                          </div>

                        {% when 'categories' %}
                          {%- comment -%} Category links {%- endcomment -%}
                          {% if block.settings.heading != blank %}
                            <div style="padding: 14px 20px 0; font-size: 1.3rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">{{ block.settings.heading }}</div>
                          {% endif %}
                          <ul class="woc-drawer-submenu" role="list">
                            {% for i in (1..6) %}
                              {% capture col_id %}collection_{{i}}{% endcapture %}
                              {% capture title_id %}custom_title_{{i}}{% endcapture %}

                              {% assign col = block.settings[col_id] %}
                              {% assign custom_title = block.settings[title_id] %}

                              {% if col != blank or custom_title != blank %}
                                <li>
                                  <a href="{{ col | default: '#' }}" class="woc-drawer-submenu-item">
                                    {% if custom_title != blank %}{{ custom_title }}{% else %}{{ col.title | default: 'Category' }}{% endif %}
                                  </a>
                                </li>
                              {% endif %}
                            {% endfor %}
                          </ul>

                        {% when 'image-cards-grid' %}
                          {% if block.settings.heading != blank %}
                            <div style="padding: 14px 20px 0; font-size: 1.3rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">{{ block.settings.heading }}</div>
                          {% endif %}
                          {% render 'images-grid', block: block %}

                        {% when 'text-column' %}
                          {% if block.settings.heading != blank %}
                            <div style="padding: 14px 20px 0; font-size: 1.3rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">{{ block.settings.heading }}</div>
                          {% endif %}
                          {% render 'megamenu-text-column', block: block %}

                      {% endcase %}
                    {%- endif -%}
                  {%- endfor -%}

                  {%- comment -%} Bottom links block {%- endcomment -%}
                  {%- for block in section.blocks -%}
                    {% assign matched_link = block.settings.title | downcase %}
                    {% assign menu_link = link.title | downcase %}
                    {%- if matched_link == menu_link and block.type == 'bottom' -%}
                      <div style="padding: 15px 20px; display: flex; gap: 10px; justify-content: space-between;">
                        {% if block.settings.link_1_text != blank %}
                          <a href="{{ block.settings.link_1_url }}" class="button button--primary" style="color: {{ block.settings.link_color_1 }}">
                            {{ block.settings.link_1_text }}
                          </a>
                        {% endif %}
                        {% if block.settings.link_2_text != blank %}
                          <a href="{{ block.settings.link_2_url }}" class="button button--primary" style="color: {{ block.settings.link_color_2 }}">
                            {{ block.settings.link_2_text }}
                          </a>
                        {% endif %}
                      </div>
                    {% endif %}
                  {%- endfor -%}

                {% else %}
                  {%- comment -%} Standard sub-links from Shopify menu {%- endcomment -%}
                  <ul class="woc-drawer-submenu" role="list">
                    {%- for childlink in link.links -%}
                      <li>
                        <a href="{{ childlink.url }}" class="woc-drawer-submenu-item">
                          {{ childlink.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {% endif %}

                {%- comment -%} Account Link at Bottom of Sub Panel {%- endcomment -%}
                {%- if section.settings.drawer_show_account and shop.customer_accounts_enabled -%}
                  <div class="woc-drawer-footer">
                    <a
                      href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                      class="woc-drawer-footer__account"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                      </svg>
                      Account
                    </a>
                  </div>
                {%- endif -%}
              </div>
            {% endif %}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </details>
</header-drawer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const drawer = document.querySelector('header-drawer');
    if (!drawer) return;

    const mainPanel = drawer.querySelector('#woc-main-panel');
    let activeSubPanel = null;

    // ---- Open sub-panel ----
    drawer.querySelectorAll('[data-target]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        const targetId = this.getAttribute('data-target');
        const subPanel = drawer.querySelector('#' + targetId);
        if (!subPanel || !mainPanel) return;

        // Close any previously open sub-panel
        if (activeSubPanel && activeSubPanel !== subPanel) {
          activeSubPanel.classList.remove('is-active');
          activeSubPanel.setAttribute('aria-hidden', 'true');
        }

        // Slide in
        mainPanel.classList.add('is-hidden');
        subPanel.classList.add('is-active');
        subPanel.setAttribute('aria-hidden', 'false');
        this.setAttribute('aria-expanded', 'true');
        activeSubPanel = subPanel;

        // Scroll sub-panel to top
        subPanel.scrollTop = 0;
      });
    });

    // ---- Back button ----
    drawer.querySelectorAll('[data-back]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        const subPanel = this.closest('.woc-drawer-panel--sub');
        if (!subPanel || !mainPanel) return;

        // Slide back
        subPanel.classList.remove('is-active');
        subPanel.setAttribute('aria-hidden', 'true');
        mainPanel.classList.remove('is-hidden');

        // Reset aria-expanded on the trigger
        const targetId = subPanel.id;
        const trigger = drawer.querySelector('[data-target="' + targetId + '"]');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');

        activeSubPanel = null;
      });
    });

    // ---- Close button ----
    const closeBtn = drawer.querySelector('.woc-drawer-close-btn');
    if (closeBtn) {
      closeBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        // Reset panels
        if (activeSubPanel) {
          activeSubPanel.classList.remove('is-active');
          activeSubPanel.setAttribute('aria-hidden', 'true');
          activeSubPanel = null;
        }
        if (mainPanel) {
          mainPanel.classList.remove('is-hidden');
        }

        // Close drawer via Dawn's built-in method
        const summary = drawer.querySelector('details > summary');
        if (drawer.closeMenuDrawer) {
          drawer.closeMenuDrawer(e, summary);
        }
      });
    }

    // ---- Reset panels when drawer closes (e.g. clicking overlay) ----
    const details = drawer.querySelector('#Details-menu-drawer-container');
    if (details) {
      const observer = new MutationObserver(function (mutations) {
        mutations.forEach(function (m) {
          if (m.attributeName === 'open' && !details.hasAttribute('open')) {
            // Drawer was closed — reset all panels
            if (activeSubPanel) {
              activeSubPanel.classList.remove('is-active');
              activeSubPanel.setAttribute('aria-hidden', 'true');
              activeSubPanel = null;
            }
            if (mainPanel) {
              mainPanel.classList.remove('is-hidden');
            }
          }
        });
      });
      observer.observe(details, { attributes: true });
    }
  });
</script>
