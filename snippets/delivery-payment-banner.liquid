    <div class="dt-text">
      {%- if block.settings.text != blank -%}
        {{ block.settings.text }}
      {%- else -%}
        <p>Buy now & get it delivered in 7-10 days, order within:</p>
      {%- endif -%}
    </div>
  </div>
  <div class="dt-bottom">
    <span class="dt-countdown" id="countdown-{{ block.id }}">
      9H : 12M : 29S
    </span>
  </div>
</div>

{%- style -%}
  .delivery-timer-container-{{ block.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.margin_bottom | default: 16 }}px;
    font-family: inherit;
    color: #2B2B2B;
    margin: 0 !important;
  }
  .dt-top {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    margin-bottom: 8px;
  }
  .dt-top .dt-text {
    line-height: 1.2;
  }
  .dt-top .dt-text p {
    margin: 0;
  }
  .dt-top strong {
    font-weight: 700;
  }
  .dt-bottom {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 1.5px;
    line-height: 1;
    color: #2B2B2B;
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const countdownEl = document.getElementById('countdown-{{ block.id }}');
    if (!countdownEl) return;
    
    // Set timer to reset every midnight
    function updateTimer() {
      const now = new Date();
      const tomorrow = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
      const diff = tomorrow - now;
      
      const h = Math.floor((diff / (1000 * 60 * 60)) % 24).toString().padStart(2, '0');
      const m = Math.floor((diff / 1000 / 60) % 60).toString().padStart(2, '0');
      const s = Math.floor((diff / 1000) % 60).toString().padStart(2, '0');
      
      // Formatting to match: 9H : 12M : 29S
      countdownEl.innerHTML = `${h}H : ${m}M : ${s}S`;
    }
    
    setInterval(updateTimer, 1000);
    updateTimer();
  });
</script>
