{% comment %}
  Renders a megamenu for the header.

  Usage:
  {% render 'header-mega-menu' %}
{% endcomment %}

<style>
   details-menu{
    visibility: hidden;
    opacity: 0;
    position: absolute;
    width: 100%;
    left: 0px;
    right: 0px;
    top: 100%;
    padding-top: 30px;
    background-color: #fff;
    transition: visibility 0.3s, opacity 0.3s;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
  }
  nav-container{
    height: 100%;
    display: flex;
    align-items: center;
  }
  nav-container:hover details-menu{
    visibility: visible;
    opacity: 1;
    transition: all .2s linear;
  }
.desktopMenu-Item {
    display: flex;
    align-items: center;
    text-decoration: none;
    gap: 10px;
    font-weight: 500;
    font-size: 14px;
    line-height: 100%;
    letter-spacing: 1px;
    vertical-align: middle;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
    text-transform: uppercase;
}
  .desktopMenu-Item svg{
    width: 14px;
    height: 12px;
  }
/* Default state: white icons */
.header-transparent .desktopMenu-Item svg path {
  fill: white;
}
 .desktopMenu-Item svg path {
 fill:rgba(var(--color-foreground));
}
/* Scrolled or Hovered state: black icons */
.header-transparent.header-scrolled .desktopMenu-Item svg path, 
.header-transparent.header-hovered .desktopMenu-Item svg path {
  fill:rgba(var(--color-foreground));
}
  .desktopMenu-Inner{
    display: flex;
    gap: 20px;
    padding-bottom: 30px;
  }
  .desktopMenu-title{
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .desktopMenu-linkList a{
    font-size: 14px;
    font-weight: 500;
  }
  .header .mega-menu__link--level-2 {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 10px;
  }
  .header__menu-item_new {
    padding: 20px 14px;
  }
  .header-menu-1{
    padding-left: 0;
  }
  /* .desktopMenu-banner img,
  .desktopMenu-banner{
    aspect-ratio: 1 /1;
  } */
  .desktopMenu-banner img{
    border-radius: 10px;
    max-height: 250px;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center;
  }
  .desktopBanner-title a{
    text-decoration: none;
    font-weight: 500;
    display: block;
    font-size: 18px;
    line-height: 25px;
    color: #272B28;
    margin-bottom: 5px;
  }
  .desktopBanner_button{
    cursor: pointer;
  }
  .desktopBanner_button .link-animate{
    font-size: 16px;
    font-weight: 500;
    margin-top: 10px;
  }
  .desktopBanner_button svg{
    width: 20px;
    margin-left: 10px;
    transition: margin-left 0.4s ease-in-out;
  }
  .desktopBanner_button:hover svg{
    margin-left: 6px;
    transition: margin-left 0.4s ease-in-out;
  }
  @media screen and (max-width: 990px){
    .desktopBanner-container{
      padding: 1.1rem 3rem;
      display: flex;
      gap: 10px;
    }
    .desktopMenu-banner{
      height: 100%;
    }
  }
  @media screen and (max-width: 990px){
    .header_navigation_new{
      display: none;
    }
  }
</style>

<nav class="header_navigation_new header__inline-menu">
  <ul class="list-menu list-menu--inline Header_menu_mainleft_new" role="list">
    {%- for link in section.settings.menu.links -%}
      
        {% assign hasBlock = false %}
        {% for block in section.blocks %}
          {% if block.type == 'megamenu' or block.type == 'collections' or block.type == 'categories' or block.type == 'bottom' or block.type == 'image-cards-grid' or block.type == 'text-column' %}
            {% assign matched_link = block.settings.title | downcase %}
            {% assign menu_link = link.title | downcase %}
            {%- if matched_link == menu_link -%}
              {% assign hasBlock = true %}
            {% endif %}
          {% endif %}
        {% endfor %}
      
        <li>
        {% unless hasBlock == true or link.links != blank %}
          <span
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset header__menu-item_new {% if forloop.first %}header-menu-1{% endif %}" normal
              >
                <span>
                  <a class="desktopMenu-Item" href="{{ link.url }}">{{- link.title | strip_html -}}</a>
                </span>
          </span>
        {% else %}
          {%- if hasBlock == true -%}
            <nav-container id="Details-{{ forloop.index }}">
              <menu-item>
                <span
                      id="HeaderMenu-{{ link.handle }}"
                      class="header__menu-item list-menu__item link focus-inset header__menu-item_new {% if forloop.first %}header-menu-1{% endif %}"
                    >
                      <span>
                        <a class="desktopMenu-Item" href="{{ link.url }}">{{- link.title | strip_html -}}
                          <svg class="icon icon-caret" fill="none" height="7" viewBox="0 0 12 7" width="12" xmlns="http://www.w3.org/2000/svg"><path d="m1.2334.554688 5.65685 5.656852-.7071.70711-5.656858-5.65686z"></path><path d="m11.8247 1.26221-5.65685 5.65685-.7071-.70711 5.65685-5.65685z"></path></svg>
                        </a>
                      </span>
                </span>
              </menu-item>
              <details-menu id="Menu-{{ forloop.index }}">
                <div class="desktopMenu-Nav page-width">
                  <div class="desktopMenu-Inner">
                      {% for block in section.blocks %}
                        {% assign matched_link = block.settings.title | downcase %}
                        {% assign menu_link = link.title | downcase %}
                        {%- if matched_link == menu_link and block.type != 'bottom' -%}
                          <div class="desktopMenu-linkList-container" style="width: 100%;">
                          {% case block.type %}
                        {% when 'megamenu' %}
  {% if block.settings.widget == 'menu' %}
    <div class="cx-menu-block">
      {% if block.settings.menu_heading != blank %}
        <div class="cx-menu-heading">
          {{ block.settings.menu_heading }}
        </div>
      {% endif %}
      <!-- Native Dawn classes kept here ONLY to maintain standard dropdown functionality -->
      <ul class="menu-drawer__menu list-menu" role="list">
        {%- for childlink in block.settings.menu_link_list_child.links -%}
          <li>
            <a href="{{ childlink.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
              {{ childlink.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>

  {% elsif block.settings.widget == 'image' %}
    <div class="cx-img-banner">
      {% if block.settings.image != blank %}
        <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.banner_title }}" loading="lazy">
      {% endif %}
      <div class="cx-img-content">
        {% if block.settings.banner_title != blank %}
          <a href="{{ block.settings.banner_link }}" class="cx-img-title">
            {{- block.settings.banner_title -}}
          </a>
        {% endif %}
        {% if block.settings.banner_button != blank %}
          <a href="{{ block.settings.banner_link }}" class="cx-img-btn">
            {{- block.settings.banner_button -}}
          </a>
        {% endif %}
      </div>
    </div>

  {% elsif block.settings.widget == 'image_grid_promo' %}
    <div class="cx-promo-wrapper">
      
      <!-- Left Side: Image Grid -->
      <div class="cx-promo-grid">
        {%- for childlink in block.settings.menu_link_list_child.links limit: 6 -%}
          <a href="{{ childlink.url }}" class="cx-promo-item">
            <div class="cx-promo-img-wrap">
              {%- if childlink.type == 'collection_link' and childlink.object.image != blank -%}
                <img src="{{ childlink.object.image | image_url: width: 1300 }}" alt="{{ childlink.title }}" loading="lazy">
              {%- elsif childlink.type == 'product_link' and childlink.object.featured_image != blank -%}
                <img src="{{ childlink.object.featured_image | image_url: width: 1300 }}" alt="{{ childlink.title }}" loading="lazy">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <span class="cx-promo-title">{{ childlink.title }}</span>
          </a>
        {%- endfor -%}
      </div>

      <!-- Right Side: Promotional Banner with Timer -->
      <div class="cx-promo-banner">
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 1800 }}" class="cx-promo-bg" alt="{{ block.settings.banner_title }}" loading="lazy">
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg cx-promo-bg' }}
        {% endif %}
        
        <div class="cx-promo-overlay"></div>
        
        <div class="cx-promo-content-box">
          {% if block.settings.banner_title != blank %}
            <h3 class="cx-promo-heading">{{ block.settings.banner_title }}</h3>
          {% endif %}

          {% if block.settings.timer_date != blank %}
            <div class="cx-promo-timer-wrap">
              <span class="cx-promo-timer-label">{{ block.settings.timer_label }}</span>
              <div class="cx-promo-timer-display" data-end-time="{{ block.settings.timer_date }}">
                <div class="cx-promo-timer-block"><span class="cx-time-hh">00</span>H</div> 
                <span class="cx-promo-timer-colon">:</span>
                <div class="cx-promo-timer-block"><span class="cx-time-mm">00</span>M</div> 
                <span class="cx-promo-timer-colon">:</span>
                <div class="cx-promo-timer-block"><span class="cx-time-ss">00</span>S</div>
              </div>
            </div>
          {% endif %}

          {% if block.settings.banner_button != blank %}
            <a href="{{ block.settings.banner_link }}" class="cx-promo-btn">
              {{ block.settings.banner_button }}
            </a>
          {% endif %}
        </div>
      </div>
      
    </div>
  {% endif %}
  {% when 'collections' %}
    <div class="desktopMenu-linkList">
      <div class="desktopMenu-title">{{ block.settings.heading }}</div>
      {% render 'featured-collection', block: block %}
    </div>
  {% when 'categories' %}
    <div class="desktopMenu-linkList">
      <div class="desktopMenu-title">{{ block.settings.heading }}</div>
      {% render 'shop-by-categories', block: block %}
    </div>
  {% when 'image-cards-grid' %}
    <div class="desktopMenu-linkList">
      <div class="desktopMenu-title">{{ block.settings.heading }}</div>
      {% render 'images-grid', block: block %}
    </div>
  {% when 'text-column' %}
    <div class="desktopMenu-linkList">
      <div class="desktopMenu-title">{{ block.settings.heading }}</div>
      {% render 'megamenu-text-column', block: block %}
    </div>
  {% endcase %}
</div>
{% endif %}
{% endfor %}
                    </div>
                    {% for block in section.blocks %}
                      {% assign matched_link = block.settings.title | downcase %}
                      {% assign menu_link = link.title | downcase %}
                      {%- if matched_link == menu_link -%}
                        {% case block.type %}
                        {% when 'bottom' %}
                          {% render 'megamenu-bottom', block: block %}
                      {% endcase %}
                      {% endif %}
                    {% endfor %}
                </div>
              </details-menu>
            </nav-container>

            {%- else -%}
            <nav-container id="Details-{{ forloop.index }}">
              <menu-item>
                <span
                      id="HeaderMenu-{{ link.handle }}"
                      class="header__menu-item list-menu__item link focus-inset navigation__item {% if forloop.first %}header-menu-1{% endif %}"
                    >
                      <span>
                        <a class="desktopMenu-Item" href="{{ link.url }}">{{- link.title | strip_html -}}
                          <svg fill="none" height="7" viewBox="0 0 12 7" width="12" xmlns="http://www.w3.org/2000/svg"><g fill="#000"><path d="m1.2334.554688 5.65685 5.656852-.7071.70711-5.656858-5.65686z"></path><path d="m11.8247 1.26221-5.65685 5.65685-.7071-.70711 5.65685-5.65685z"></path></g></svg>
                        </a>
                      </span>
                </span>
              </menu-item>
              <details-menu id="Menu-{{ forloop.index }}">
                <div class="desktopMenu-Nav page-width">
                  <div class="desktopMenu-Inner ">
                      {%- for childlink in link.links -%}
                        <div class="desktopMenu-container padding-with">
                          <a
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            href="{{ childlink.url }}"
                            class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                            {% if childlink.current %}
                              aria-current="page"
                            {% endif %}
                          >
                            {{ childlink.title | escape }}
                          </a>
                          {%- if childlink.links != blank -%}
                            <ul class="list-unstyled" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                    {% if grandchildlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                  </div>
                </div>
              </details-menu>
            </nav-container>
          {% endif %}
        {% endunless %}
        </li>
    {%- endfor -%}
  </ul>
  {%- if section.settings.main_right_detail_text != blank -%}
    <div class="Header_menu_mainright_new">
      <div class="Header_menu_innerright_new">
        {{ section.settings.main_right_detail_text }}
      </div>
    </div>
  {%- endif -%}
</nav>

<script>
  /* ============================================
     Mega Menu / Drawer — Countdown Timer
     Targets all elements with [data-end-time]
     ============================================ */
  (function () {
    'use strict';

    function initMegaMenuTimers() {
      var timers = document.querySelectorAll('[data-end-time]');
      if (!timers.length) return;

      function pad(n) {
        return n < 10 ? '0' + n : n;
      }

      function updateTimers() {
        var now = new Date().getTime();

        timers.forEach(function (el) {
          var endStr = el.getAttribute('data-end-time');
          if (!endStr) return;

          var end = new Date(endStr).getTime();
          var diff = end - now;

          if (diff <= 0) {
            var hh = el.querySelector('.cx-time-hh');
            var mm = el.querySelector('.cx-time-mm');
            var ss = el.querySelector('.cx-time-ss');
            if (hh) hh.textContent = '00';
            if (mm) mm.textContent = '00';
            if (ss) ss.textContent = '00';
            return;
          }

          var hours = Math.floor(diff / (1000 * 60 * 60));
          var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          var seconds = Math.floor((diff % (1000 * 60)) / 1000);

          var hh = el.querySelector('.cx-time-hh');
          var mm = el.querySelector('.cx-time-mm');
          var ss = el.querySelector('.cx-time-ss');
          if (hh) hh.textContent = pad(hours);
          if (mm) mm.textContent = pad(minutes);
          if (ss) ss.textContent = pad(seconds);
        });
      }

      updateTimers();
      setInterval(updateTimers, 1000);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMegaMenuTimers);
    } else {
      initMegaMenuTimers();
    }

    /* Re-init on Shopify theme editor events */
    if (typeof Shopify !== 'undefined' && Shopify.designMode) {
      document.addEventListener('shopify:section:load', initMegaMenuTimers);
    }
  })();
</script>
