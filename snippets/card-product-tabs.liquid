{% comment %}
  Renders a product card styled for the Collection Tabs section.

  Accepts:
  - card_product: {Object} Product Liquid object (optional)
  - section_id: {String} Section id, used for unique ids
  - media_aspect_ratio: {String} 'adapt' | 'portrait' | 'square'. Default 'adapt'.
  - show_secondary_image: {Boolean} Default false.
  - show_rating: {Boolean} Default false.
  - show_swatches: {Boolean} Default false.
  - swatch_option: {String} The name of the option used as colour (e.g. 'Color').
  - swatch_limit: {Number} Max swatches to show.
  - show_delivery: {Boolean} Default false.
  - delivery_text: {String} Pre-computed delivery line (e.g. "Order now & get it by 28-29 March").
  - lazy_load: {Boolean} Default true.
  - placeholder_image: {String} Placeholder svg id.
  - badge_position: {String} 'top-left' | 'top-right'. Default 'top-right'.
  - quick_add: {String} 'none' | 'standard' | 'bulk'. Default 'none'.
{% endcomment %}
{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}

  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}
{%- liquid
  assign ratio = 1
  if media_aspect_ratio == 'portrait'
    assign ratio = 0.8
  elsif media_aspect_ratio == 'square'
    assign ratio = 1
  elsif media_aspect_ratio == 'adapt' and card_product.featured_media
    assign ratio = card_product.featured_media.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif

  assign swatch_key = swatch_option | default: 'Color' | downcase
  assign found_option = null
  assign found_option_position = nil
  if card_product
    for option in card_product.options_with_values
      assign option_name = option.name | downcase
      if option_name == swatch_key
        assign found_option = option
        assign found_option_position = option.position
        break
      endif
    endfor
  endif

  assign first_variant = card_product.selected_or_first_available_variant
-%}

<div
  class="card-product-tabs card-wrapper underline-links-hover"
  data-product-id="{{ card_product.id }}"
  data-product-url="{{ card_product.url }}"
>
  <div
    class="card-product-tabs__inner"
    style="--ct-ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
  >
    {%- if card_product and card_product != empty -%}
      <a
        href="{{ card_product.url }}"
        class="card-product-tabs__media"
        aria-label="{{ card_product.title | escape }}"
        data-card-media-link
      >
        <div class="card-product-tabs__media-inner">
          {%- if card_product.featured_media -%}
            {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
            <img
              srcset="
                {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                {%- if card_product.featured_media.width >= 720 -%}{{ card_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                {%- if card_product.featured_media.width >= 940 -%}{{ card_product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                {%- if card_product.featured_media.width >= 1066 -%}{{ card_product.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
              "
              src="{{ card_product.featured_media | image_url: width: 720 }}"
              sizes="(min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
              alt="{{ card_product.featured_media.alt | escape }}"
              class="card-product-tabs__image card-product-tabs__image--primary motion-reduce"
              {% if lazy_load == false %}loading="eager"{% else %}loading="lazy"{% endif %}
              width="{{ card_product.featured_media.width }}"
              height="{{ card_product.featured_media.height }}"
              data-card-primary-image
            >
            {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}

            {%- if show_secondary_image and card_product.media[1] != null -%}
              <img
                srcset="
                  {%- if card_product.media[1].width >= 533 -%}{{ card_product.media[1] | image_url: width: 533 }} 533w,{%- endif -%}
                  {%- if card_product.media[1].width >= 720 -%}{{ card_product.media[1] | image_url: width: 720 }} 720w,{%- endif -%}
                  {%- if card_product.media[1].width >= 940 -%}{{ card_product.media[1] | image_url: width: 940 }} 940w,{%- endif -%}
                  {{ card_product.media[1] | image_url }} {{ card_product.media[1].width }}w
                "
                src="{{ card_product.media[1] | image_url: width: 720 }}"
                sizes="(min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                alt="{{ card_product.media[1].alt | escape }}"
                class="card-product-tabs__image card-product-tabs__image--secondary motion-reduce"
                loading="lazy"
                width="{{ card_product.media[1].width }}"
                height="{{ card_product.media[1].height }}"
              >
            {%- endif -%}
          {%- else -%}
            {{ placeholder_image | default: 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg card-product-tabs__image' }}
          {%- endif -%}

          {%- comment -%} Cart icon button (shopping bag) {%- endcomment -%}
          {%- if card_product.available -%}
            <button
              type="button"
              class="card-product-tabs__cart-btn"
              data-variant-id="{{ first_variant.id }}"
              data-product-url="{{ card_product.url }}"
              data-product-handle="{{ card_product.handle }}"
              data-has-variants="{% if card_product.variants.size > 1 %}true{% else %}false{% endif %}"
              aria-label="{{ 'products.product.add_to_cart' | t }}"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <path d="M16 10a4 4 0 01-8 0"></path>
              </svg>
              <div class="card-product-tabs__cart-spinner">
                <svg class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                  <circle fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                </svg>
              </div>
            </button>
          {%- endif -%}
        </div>

        {%- liquid
          assign badge_label = ''
          assign badge_modifier = ''
          if card_product.metafields.custom.badge != blank
            assign badge_label = card_product.metafields.custom.badge
            assign badge_modifier = 'card-product-tabs__badge--custom'
          elsif card_product.available == false
            assign badge_label = 'products.product.sold_out' | t
            assign badge_modifier = 'card-product-tabs__badge--soldout'
          elsif card_product.compare_at_price > card_product.price and card_product.available
            assign saved_percent = card_product.compare_at_price | minus: card_product.price | times: 100 | divided_by: card_product.compare_at_price
            assign badge_label = saved_percent | append: '% OFF'
            assign badge_modifier = 'card-product-tabs__badge--sale'
          elsif card_product.created_at and card_product.tags contains 'new'
            assign badge_label = 'sections.featured_collection.new_badge' | t | default: 'New'
            assign badge_modifier = 'card-product-tabs__badge--new'
          endif
        -%}
        {%- if badge_label != blank -%}
          <span class="card-product-tabs__badge card-product-tabs__badge--{{ badge_position | default: 'top-right' }} {{ badge_modifier }}" data-card-badge>
            {{ badge_label }}
          </span>
        {%- endif -%}
      </a>

      {%- comment -%} Quick Add (Dawn standard/bulk) — kept for backwards compat {%- endcomment -%}
      {% assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id %}
      {% if quick_add == 'standard' %}
        <div class="quick-add no-js-hidden">
          {%- liquid
            assign qty_rules = false
            if card_product.selected_or_first_available_variant.quantity_rule.min > 1 or card_product.selected_or_first_available_variant.quantity_rule.max != null or card_product.selected_or_first_available_variant.quantity_rule.increment > 1
              assign qty_rules = true
            endif
          -%}
            <product-form data-section-id="{{ section.id }}">
              {%- form 'product',
                card_product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input
                  type="hidden"
                  name="id"
                  value="{{ card_product.selected_or_first_available_variant.id }}"
                  class="product-variant-id"
                  {% if card_product.selected_or_first_available_variant.available == false %}
                    disabled
                  {% endif %}
                >
                <button
                  id="{{ product_form_id }}-submit"
                  type="submit"
                  name="add"
                  class="quick-add__submit button button--full-width button--secondary{% if horizontal_quick_add %} card--horizontal__quick-add{% endif %}"
                  aria-haspopup="dialog"
                  aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
                  aria-live="polite"
                  data-sold-out-message="true"
                  {% if card_product.selected_or_first_available_variant.available == false %}
                    disabled
                  {% endif %}
                >
                  <span>
                    {%- if card_product.selected_or_first_available_variant.available -%}
                      {{ 'products.product.add_to_cart' | t }}
                    {%- else -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- endif -%}
                  </span>
                  <span class="sold-out-message hidden">
                    {{ 'products.product.sold_out' | t }}
                  </span>
                  {%- if horizontal_quick_add -%}
                    <span class="icon-wrap">
                      {{- 'icon-plus.svg' | inline_asset_content -}}
                    </span>
                  {%- endif -%}
                  {%- render 'loading-spinner' -%}
                </button>
              {%- endform -%}
            </product-form>
        </div>
      {% endif %}

      {%- if show_delivery and delivery_text != blank -%}
        <div class="card-product-tabs__delivery">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
          <span class="js-delivery-date" data-days="5">Order now &amp; get it by <strong class="delivery-date-calc">...</strong></span>
        </div>
      {%- endif -%}

      <div class="card-product-tabs__content">
        <div class="card-product-tabs__header">
          <h3 class="card-product-tabs__title">
            <a href="{{ card_product.url }}" class="full-unstyled-link" id="CardLink-{{ section_id }}-{{ card_product.id }}" data-card-title-link>
              {{ card_product.title | escape }}
            </a>
          </h3>

          {%- if show_rating and card_product.metafields.reviews.rating.value != blank -%}
            {%- liquid
              assign rating_value = card_product.metafields.reviews.rating.value.rating | default: card_product.metafields.reviews.rating.value
              assign rating_max = card_product.metafields.reviews.rating.value.scale_max | default: 5
              assign rating_count = card_product.metafields.reviews.rating_count | default: 0
            -%}
            <div class="card-product-tabs__rating" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}">
              <span class="card-product-tabs__stars" aria-hidden="true" style="--rating: {{ rating_value | floor }}; --rating-max: {{ rating_max }};"></span>
              {%- if rating_count > 0 -%}
                <span class="card-product-tabs__rating-count">({{ rating_count }})</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <div class="card-product-tabs__price" data-card-price-container>
          {% render 'price', product: card_product, price_class: '', show_compare_at_price: true %}
        </div>

        {%- if show_swatches and found_option and found_option.values.size > 0 -%}
          <div class="card-product-tabs__swatches" role="listbox" aria-label="Color" data-swatch-option-name="{{ found_option.name | escape }}">
            {%- assign swatch_max = swatch_limit | default: 6 -%}
            {%- for value in found_option.values limit: swatch_max -%}
              {%- liquid
                assign swatch_background = ''
                if value.swatch.image
                  assign swatch_image_url = value.swatch.image | image_url: width: 50
                  assign swatch_background = 'url(' | append: swatch_image_url | append: ')'
                elsif value.swatch.color
                  assign swatch_background = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                else
                  assign swatch_background = value | downcase
                endif

                assign is_first_swatch = false
                if forloop.first
                  assign is_first_swatch = true
                endif
              -%}
              <button
                type="button"
                class="card-product-tabs__swatch{% if is_first_swatch %} is-active{% endif %}"
                role="option"
                aria-selected="{% if is_first_swatch %}true{% else %}false{% endif %}"
                title="{{ value | escape }}"
                data-swatch-value="{{ value | escape }}"
                data-swatch-option-position="{{ found_option_position }}"
                style="background: {{ swatch_background }};"
              ></button>
            {%- endfor -%}
            {%- if found_option.values.size > swatch_max -%}
              <span class="card-product-tabs__swatch card-product-tabs__swatch--more" aria-hidden="true">+{{ found_option.values.size | minus: swatch_max }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Variant JSON data for JavaScript variant switching {%- endcomment -%}
      {%- if show_swatches and found_option and found_option.values.size > 1 -%}
        <script type="application/json" data-card-variants-json>
          {%- assign variant_data = '' -%}
          [
          {%- for variant in card_product.variants -%}
            {
              "id": {{ variant.id }},
              "title": {{ variant.title | json }},
              "available": {{ variant.available }},
              "price": {{ variant.price }},
              "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
              "price_formatted": {{ variant.price | money | json }},
              "compare_at_price_formatted": {{ variant.compare_at_price | money | json }},
              "url": {{ variant.url | json }},
              {%- if variant.featured_media -%}
              "featured_image": {
                "url": {{ variant.featured_media | image_url: width: 720 | json }},
                "alt": {{ variant.featured_media.alt | json }},
                "width": {{ variant.featured_media.width }},
                "height": {{ variant.featured_media.height }}
              },
              {%- else -%}
              "featured_image": null,
              {%- endif -%}
              "options": {{ variant.options | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
          ]
        </script>
      {%- endif -%}

      {%- comment -%} Mobile Quick Add Drawer content (hidden, injected into drawer by JS) {%- endcomment -%}
      {%- if card_product.variants.size > 1 -%}
        <ma-addtocart style="display: none;" data-card-mobile-drawer-content>
          <div class="WI_mobileQuickAffDrawer_pro" id="WI_mobileQuickAffDrawer_pro">
            <div class="WI_quickAddProduct_img">
              {%- if card_product.featured_media -%}
                <img
                  src="{{ card_product.featured_media | image_url: width: 533 }}"
                  alt="{{ card_product.featured_media.alt }}"
                  width="500"
                  height="750"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
            <div class="WI_quickAddProduct_title">
              <h5>{{ card_product.title | escape }}</h5>
              <span>{% render 'price', product: card_product, price_class: '', show_compare_at_price: true %}</span>

              <div class="WI_quickAddProduct_options">
                {%- for variant in card_product.variants -%}
                  <input
                    type="radio"
                    id="ct-variant-{{ section_id | append: card_product.id | append: variant.id }}"
                    value="{{ variant.id }}"
                    name="ct-variant-{{ section_id | append: card_product.id }}"
                    class="WI_mobileQuickAdd"
                    data-varid="{{ variant.id }}"
                    {% if variant.id == card_product.selected_or_first_available_variant.id %}
                      checked
                    {% endif %}
                    {% unless variant.available %}
                      disabled
                    {% endunless %}
                  >
                  <label
                    for="ct-variant-{{ section_id | append: card_product.id | append: variant.id }}"
                    class="WI_mobileQuickAdd_label"
                  >
                    {{ variant.title }}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          </div>

          <div class="WI_quickAddProduct_form">
            <button
              class="quickATC"
              type="submit"
              data-variantid="{{ card_product.selected_or_first_available_variant.id }}"
              {% unless card_product.available %}
                disabled
              {% endunless %}
            >
              <div class="Ma-span">
                {%- if card_product.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </div>
              <div class="loading-overlay__spinner hidden">
                <svg
                  aria-hidden="true"
                  focusable="false"
                  role="presentation"
                  class="spinner"
                  viewBox="0 0 66 66"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <circle fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                </svg>
              </div>
            </button>
          </div>
        </ma-addtocart>
      {%- endif -%}

    {%- else -%}
      <div class="card-product-tabs__media">
        <div class="card-product-tabs__media-inner">
          {{ placeholder_image | default: 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg card-product-tabs__image' }}
        </div>
      </div>
      <div class="card-product-tabs__content">
        <div class="card-product-tabs__header">
          <h3 class="card-product-tabs__title">
            <a role="link" aria-disabled="true" class="full-unstyled-link">
              {{ 'onboarding.product_title' | t }}
            </a>
          </h3>
        </div>
        <div class="card-product-tabs__price">
          {% render 'price', placeholder: true, show_compare_at_price: true %}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>
