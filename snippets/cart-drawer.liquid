{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'ma-quickAdd.js' | asset_url }}" defer="defer"></script>

{% comment %} Styles moved to sereluna.css {% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ settings.padding_top }}px;
    padding-bottom: {{ settings.padding_bottom }}px;
    background-color: {{ settings.bg_color }};
  }
  .usp-grid-settings {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  justify-content: center;
  align-items: center;
    align-items: flex-start;
  }

  .usp-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 8px;
  }

  .usp-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ settings.icon_width }}px;
    margin-bottom: 5px;
  }

  .usp-icon-img {
    width: {{ settings.icon_width }}px;
    height: auto;
    object-fit: contain;
    display: block;
  }


  .usp-text h3 {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 1px;
    text-transform: capitalize;
    color: {{ settings.text_color }};
  }

  @media screen and (max-width: 767px) {
    .usp-grid-settings {
      gap: 10px;
    }

    .usp-text h3 {
      font-size: 10px;
      letter-spacing: 0.5px;
    }
  }
{%- endstyle -%}
<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div class="drawer__container">
      {% if settings.upsell__container and cart != empty %}
        <div class="drawer__upsell-container">
          <div class="drawer__upsell-header">
            <h4>{{ settings.upsell__heading }}</h4>
          </div>
          <div class="drawer__upsell-wrapper">
            <div class="drawer__upsell-inner">
              {% for item in settings.upsell__products %}
                {% render 'card-drawer-product', card_product: item %}
              {% endfor %}
            </div>
          </div>
          {% if settings.upsell__points %}
            <div class="drawer__upsell-footer">
              <div class="drawer__upsell-footer-inner">
                {% if settings['upsell__points-heading'] != blank %}
                  <h5>{{ settings['upsell__points-heading'] }}</h5>
                {% endif %}

                <div class="drawer__upsell-point">
                  <div class="upsell-icon">
                    {%- if settings.icon_1 != blank -%}
                      {{ settings.icon_1 | image_url: width: 50 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      <svg class="usp-icon-img" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                        <circle cx="12" cy="12" r="10"></circle>
                      </svg>
                    {%- endif -%}
                  </div>
                  <span>{{ settings.title_1 | newline_to_br }}</span>
                </div>

                <div class="drawer__upsell-point">
                  <div class="upsell-icon">
                    {%- if settings.icon_2 != blank -%}
                      {{ settings.icon_2 | image_url: width: 50 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      <svg class="usp-icon-img" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      </svg>
                    {%- endif -%}
                  </div>
                  <span>{{ settings.title_2 | newline_to_br }}</span>
                </div>

                <div class="drawer__upsell-point">
                  <div class="upsell-icon">
                    {%- if settings.icon_3 != blank -%}
                      {{ settings.icon_3 | image_url: width: 50 | image_tag: loading: 'lazy' }}
                    {%- else -%}
                      <svg class="usp-icon-img" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                      </svg>
                    {%- endif -%}
                  </div>
                  <span>{{ settings.title_3 | newline_to_br }}</span>
                </div>
              </div>

              {% comment %} Styles moved to sereluna.css {% endcomment %}
            </div>
          {% endif %}
        </div>
      {% endif %}
      <div
        class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
        role="dialog"
        aria-modal="true"
        aria-label="{{ 'sections.cart.title' | t }}"
        tabindex="-1"
      >
        <div id="CartDrawer-GlobalLoadingOverlay" class="cart-drawer__loading-overlay">
          <div class="cart-drawer__spinner-ring"> </div>
        </div>
        {%- if cart == empty -%}
          <div class="drawer__inner-empty">
            <div class="cart-drawer__warnings center">
              <div class="cart-drawer__empty-content" style="padding-top: 4rem;">
                <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
                <button
                  class="drawer__close"
                  type="button"
                  onclick="this.closest('cart-drawer').close()"
                  aria-label="{{ 'accessibility.close' | t }}"
                >
                  <span class="svg-wrapper">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M18 6L6 18M6 6l12 12" stroke="#121212" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
                <a href="{{ routes.all_products_collection_url }}" class="button" style="margin-top: 1.5rem;">
                  {{ 'general.continue_shopping' | t }}
                </a>
              </div>
            </div>
          </div>
        {%- endif -%}

        <div class="drawer__header">
          <h2 class="drawer__heading">Your cart</h2>
          <button
            class="drawer__close"
            type="button"
            onclick="this.closest('cart-drawer').close()"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span class="svg-wrapper">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18M6 6l12 12" stroke="#121212" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
        </div>

        <cart-drawer-items
          {% if cart == empty %}
            class=" is-empty"
          {% endif %}
        >
          <form
            action="{{ routes.cart_url }}"
            id="CartDrawer-Form"
            class="cart__contents cart-drawer__form"
            method="post"
          >
            <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
              {%- if cart != empty -%}
                <div class="drawer__cart-items-wrapper">
                  <table class="cart-items" role="table">
                    <thead role="rowgroup" class="visually-hidden">
                      <tr role="row">
                        <th id="CartDrawer-ColumnProductImage" role="columnheader">Image</th>
                        <th id="CartDrawer-ColumnDetails" role="columnheader">Details</th>
                      </tr>
                    </thead>

                    <tbody role="rowgroup">
                      {%- for item in cart.items -%}
                        <tr
                          id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                          class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                          role="row"
                        >
                          <td
                            class="cart-item__media"
                            role="cell"
                            headers="CartDrawer-ColumnProductImage"
                          >
                            {% if item.image %}
                              <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                              <img
                                class="cart-item__image"
                                src="{{ item.image | image_url: width: 300 }}"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="160"
                                height="160"
                              >
                            {% endif %}
                          </td>

                          <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                            <a href="{{ item.url }}" class="cart-item__name full-unstyled-link">
                              {{- item.product.title | escape -}}
                            </a>
                            {%- if item.product.metafields.reviews.rating.value != blank -%}
                              {%- assign rating_value = item.product.metafields.reviews.rating.value.rating | default: item.product.metafields.reviews.rating.value -%}
                              {%- assign rating_count = item.product.metafields.reviews.rating_count | default: 0 -%}
                              <div class="cart-item__rating-stars">
                                {%- assign floor_rating = rating_value | floor -%}
                                {%- for i in (1..5) -%}
                                  {%- if i <= floor_rating -%}
                                    <span>★</span>
                                  {%- else -%}
                                    <span style="opacity: 0.3;">★</span>
                                  {%- endif -%}
                                {%- endfor -%}
                                {%- if rating_count > 0 -%}
                                  <span class="star-count" style="color: #555; font-size: 13px; margin-left: 2px;">({{ rating_count }})</span>
                                {%- endif -%}
                              </div>
                            {%- endif -%}

                            <div class="cart-item__price-row">
                              {%- if item.variant.compare_at_price > item.variant.price -%}
                                {%- assign item_compare_at = item.variant.compare_at_price | times: item.quantity -%}
                                <span class="price price--sale">{{ item.final_line_price | money }}</span>
                                <s class="price price--compare">{{ item_compare_at | money }}</s>
                                {%- assign savings = item.variant.compare_at_price | minus: item.variant.price | times: 100 | divided_by: item.variant.compare_at_price | round -%}
                                <span class="price-discount-badge">{{ savings }}% OFF</span>
                              {%- else -%}
                                <span class="price price--normal">{{ item.final_line_price | money }}</span>
                              {%- endif -%}
                            </div>

                            {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                              <dl class="cart-item__options">
                                {%- if item.product.has_only_default_variant == false -%}
                                  {%- for option in item.options_with_values -%}
                                    <div class="product-option">
                                      <dt>{{ option.name }}:</dt>
                                      <dd>{{ option.value }}{%- unless forloop.last %}, {% endunless %}</dd>
                                    </div>
                                  {%- endfor -%}
                                {%- endif -%}
                              </dl>
                            {%- endif -%}

                            <cart-remove-button
                              id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                              class="cart-item__remove-btn"
                            >
                              <button
                                type="button"
                                class="cart-remove-button-raw"
                                aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                                data-variant-id="{{ item.variant.id }}"
                              >
                               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="20" viewBox="0 0 18 20" fill="none">
<path d="M15.3542 6.1875V16.8208C15.3542 17.4043 15.1224 17.9639 14.7098 18.3765C14.2972 18.789 13.7376 19.0208 13.1542 19.0208H4.72083C4.13736 19.0208 3.57778 18.789 3.1652 18.3765C2.75262 17.9639 2.52083 17.4043 2.52083 16.8208V6.1875M12.6042 3.4375V1.7875C12.6042 1.1825 12.1092 0.6875 11.5042 0.6875H6.37083C5.76583 0.6875 5.27083 1.1825 5.27083 1.7875V3.4375M12.6042 3.4375H5.27083M12.6042 3.4375H17.1875M5.27083 3.4375H0.6875M8.9375 8.9375V14.4375M11.6875 8.9375V14.4375M6.1875 8.9375V14.4375" stroke="black" stroke-width="1.375" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
                              </button>
                            </cart-remove-button>
                          </td>

                          <td class="cart-item__quantity-hidden" style="display:none;">
                            <input
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              data-quantity-variant-id="{{ item.variant.id }}"
                              id="Drawer-quantity-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                          </td>
                        </tr>
                      {%- endfor -%}
                    </tbody>
                  </table>
                </div>
              {%- endif -%}
              <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
              <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
                {{ 'accessibility.loading' | t }}
              </p>
            </div>
            <div id="CartDrawer-CartErrors" role="alert"></div>
          </form>

          {%- if cart != empty -%}
            {% comment %} Inline complete your set upsells {% endcomment %}
            {%- assign upsell_products = cart.items.first.product.metafields.custom.complementary_products.value -%}
            {%- if upsell_products == blank -%}
              {%- assign upsell_products = cart.items.first.product.metafields.complementary_products.value -%}
            {%- endif -%}
            {%- if upsell_products == blank -%}
              {%- assign upsell_products = cart.items.first.product.metafields.shopify--discovery--product_recommendation.complementary_products.value -%}
            {%- endif -%}
            {%- if upsell_products == blank -%}
              {%- assign upsell_products = settings.upsell__products -%}
            {%- endif -%}

            {%- if upsell_products != blank -%}
              <div class="cart-drawer__complete-set">
                <div class="complete-set__header">
                  <span class="complete-set__line"></span>
                  <div class="complete-set__title">Complete Your Set</div>
                  <span class="complete-set__line"></span>
                </div>

                <div class="complete-set__items">
                  {%- for product in upsell_products limit: 2 -%}
                    {% render 'card-product-item', card_product: product %}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}
        </cart-drawer-items>

        {%- if cart != empty -%}
          <div class="cart-drawer__trust-badges-bar">
            <div class="cart-drawer__trust-badges">
              <div class="trust-badge__item">
                <div class="trust-badge__icon">
                  <img src="//sofasnbeds.co.uk/cdn/shop/files/7489a1e90ef25fb8e6eaa8da5c9eef9c7af65f5b.png?v=1781434342&amp;width=1920" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/7489a1e90ef25fb8e6eaa8da5c9eef9c7af65f5b.png?v=1781434342&amp;width=352 352w, //sofasnbeds.co.uk/cdn/shop/files/7489a1e90ef25fb8e6eaa8da5c9eef9c7af65f5b.png?v=1781434342&amp;width=832 832w, //sofasnbeds.co.uk/cdn/shop/files/7489a1e90ef25fb8e6eaa8da5c9eef9c7af65f5b.png?v=1781434342&amp;width=1200 1200w, //sofasnbeds.co.uk/cdn/shop/files/7489a1e90ef25fb8e6eaa8da5c9eef9c7af65f5b.png?v=1781434342&amp;width=1920 1920w" width="1920" height="1920" loading="lazy">
                </div>
                <div class="trust-badge__content">
                  <span class="trust-badge__title">One Year Warranty</span>
                  <span class="trust-badge__desc">Built to last with quality you can trust on</span>
                </div>
              </div>
              <div class="trust-badge__divider"></div>
              <div class="trust-badge__item">
                <div class="trust-badge__icon">
                  <img src="//sofasnbeds.co.uk/cdn/shop/files/Group_1413372281.svg?v=1781507966&amp;width=1920" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/Group_1413372281.svg?v=1781507966&amp;width=352 352w, //sofasnbeds.co.uk/cdn/shop/files/Group_1413372281.svg?v=1781507966&amp;width=832 832w, //sofasnbeds.co.uk/cdn/shop/files/Group_1413372281.svg?v=1781507966&amp;width=1200 1200w, //sofasnbeds.co.uk/cdn/shop/files/Group_1413372281.svg?v=1781507966&amp;width=1920 1920w" width="1920" height="1920" loading="lazy">
                </div>
                <div class="trust-badge__content">
                  <span class="trust-badge__title">14-Day Returns</span>
                  <span class="trust-badge__desc">Not right? Send it back, hassle-free</span>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
        
        <div class="drawer__footer">
          {%- if cart != empty -%}
            <div class="cart-drawer__footer-shipping">
              <span class="shipping-icon">
               <svg xmlns="http://www.w3.org/2000/svg" width="21" height="17" viewBox="0 0 21 17" fill="none">
<path d="M17.334 13.5C17.334 14.1354 17.0816 14.7448 16.6323 15.1941C16.183 15.6434 15.5736 15.8958 14.9382 15.8958C14.3027 15.8958 13.6933 15.6434 13.244 15.1941C12.7947 14.7448 12.5423 14.1354 12.5423 13.5C12.5423 12.8645 12.7947 12.2552 13.244 11.8058C13.6933 11.3565 14.3027 11.1041 14.9382 11.1041C15.5736 11.1041 16.183 11.3565 16.6323 11.8058C17.0816 12.2552 17.334 12.8645 17.334 13.5ZM7.75065 13.5C7.75065 14.1354 7.49823 14.7448 7.04893 15.1941C6.59962 15.6434 5.99023 15.8958 5.35482 15.8958C4.7194 15.8958 4.11001 15.6434 3.66071 15.1941C3.2114 14.7448 2.95898 14.1354 2.95898 13.5C2.95898 12.8645 3.2114 12.2552 3.66071 11.8058C4.11001 11.3565 4.7194 11.1041 5.35482 11.1041C5.99023 11.1041 6.59962 11.3565 7.04893 11.8058C7.49823 12.2552 7.75065 12.8645 7.75065 13.5Z" stroke="#2B2B2B" stroke-width="1.125"/>
<path d="M12.5417 13.5H7.75M17.3333 13.5H18.0645C18.2754 13.5 18.3808 13.5 18.469 13.4885C18.7862 13.449 19.0812 13.3049 19.3074 13.0789C19.5335 12.8529 19.6779 12.558 19.7177 12.2408C19.7292 12.1516 19.7292 12.0462 19.7292 11.8354V9.1875C19.7292 7.53542 19.0729 5.95101 17.9047 4.78281C16.7365 3.61462 15.1521 2.95833 13.5 2.95833M13.0208 11.5833V3.4375C13.0208 2.08242 13.0208 1.40488 12.5992 0.984167C12.1794 0.5625 11.5019 0.5625 10.1458 0.5625H3.4375C2.08242 0.5625 1.40488 0.5625 0.984167 0.984167C0.5625 1.40392 0.5625 2.08146 0.5625 3.4375V11.1042C0.5625 12.0002 0.5625 12.4477 0.755125 12.7812C0.881287 12.9998 1.06274 13.1812 1.28125 13.3074C1.61475 13.5 2.06229 13.5 2.95833 13.5" stroke="#2B2B2B" stroke-width="1.125" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
              </span>
              <span class="shipping-text">Complete your checkout now &amp; get it delivered in 7-10 days</span>
            </div>

            <div class="cart-drawer__totals-wrapper">
              <div class="totals-row">
                <span class="totals-label">Subtotal</span>
                <span class="totals-value">{{ cart.total_price | money }}</span>
              </div>
              <div class="totals-row totals-row--small">
                <span class="totals-label">Discounts & Taxes</span>
                <span class="totals-value">Completed at checkout</span>
              </div>
            </div>

            <div class="cart__ctas">
              <button
                type="submit"
                id="CartDrawer-Checkout"
                class="cart__checkout-button  button button--primary"
                name="checkout"
                form="CartDrawer-Form"
              >
                Complete Your Checkout
              </button>
            </div>

            <div class="cart-drawer__payment-badges">
              {%- for type in shop.enabled_payment_types -%}
                <div class="payment-badge-card">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </div>
              {%- endfor -%}
            </div>


          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</cart-drawer>
