{% comment %}
  ============================================================================
  EXERCER FILTERS – 100% Custom Filter Snippet
  Uses: custom-exercer.css, custom-filters.js
  No Dawn dependency.
  ============================================================================
{% endcomment %}

{{ 'custom-exercer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-filters.js' | asset_url }}" defer="defer"></script>

<exercer-filters>

  {%- comment -%} ── Toolbar above the grid ── {%- endcomment -%}
  <div class="exr-toolbar">
    <div class="exr-toolbar__left">
      <button type="button" class="exr-trigger" data-exr-open aria-label="Open Filters">
       <svg xmlns="http://www.w3.org/2000/svg" width="18" height="17" viewBox="0 0 18 17" fill="none">
<path d="M16.6875 8.18862H5.87688H16.6875ZM2.061 8.18862H0.5H2.061ZM16.6875 13.9698H11.658H16.6875ZM7.84212 13.9698H0.5H7.84212ZM16.6875 2.4075H13.9706H16.6875ZM10.1548 2.4075H0.5H10.1548ZM12.0623 4.315C12.3127 4.315 12.5608 4.26566 12.7922 4.1698C13.0236 4.07394 13.2339 3.93343 13.4111 3.75631C13.5882 3.57918 13.7287 3.3689 13.8246 3.13747C13.9204 2.90604 13.9697 2.658 13.9697 2.4075C13.9697 2.157 13.9204 1.90896 13.8246 1.67753C13.7287 1.4461 13.5882 1.23582 13.4111 1.05869C13.2339 0.881566 13.0236 0.741061 12.7922 0.6452C12.5608 0.549339 12.3127 0.5 12.0623 0.5C11.5563 0.5 11.0712 0.700968 10.7134 1.05869C10.3557 1.41642 10.1548 1.9016 10.1548 2.4075C10.1548 2.9134 10.3557 3.39858 10.7134 3.75631C11.0712 4.11403 11.5563 4.315 12.0623 4.315ZM3.9685 10.0961C4.4744 10.0961 4.95958 9.89516 5.31731 9.53743C5.67503 9.1797 5.876 8.69452 5.876 8.18862C5.876 7.68272 5.67503 7.19754 5.31731 6.83982C4.95958 6.48209 4.4744 6.28112 3.9685 6.28112C3.4626 6.28112 2.97742 6.48209 2.61969 6.83982C2.26197 7.19754 2.061 7.68272 2.061 8.18862C2.061 8.69452 2.26197 9.1797 2.61969 9.53743C2.97742 9.89516 3.4626 10.0961 3.9685 10.0961ZM9.74963 15.8781C10.2556 15.8781 10.7409 15.6771 11.0987 15.3193C11.4565 14.9615 11.658 14.4758 11.658 13.9698C11.658 13.4637 11.4565 12.9789 11.0987 12.6211C10.7409 12.2633 10.2556 12.0623 9.74963 12.0623C9.24372 12.0623 8.75854 12.2632 8.40082 12.6209C8.04309 12.9787 7.84212 13.4639 7.84212 13.9698C7.84212 14.4757 8.04309 14.9608 8.40082 15.3186C8.75854 15.6763 9.24372 15.8781 9.74963 15.8781Z" fill="#2B2B2B"/>
<path d="M16.6875 8.18862H5.87688M2.061 8.18862H0.5M2.061 8.18862C2.061 7.68272 2.26197 7.19754 2.61969 6.83982C2.97742 6.48209 3.4626 6.28112 3.9685 6.28112C4.4744 6.28112 4.95958 6.48209 5.31731 6.83982C5.67503 7.19754 5.876 7.68272 5.876 8.18862C5.876 8.69453 5.67503 9.17971 5.31731 9.53743C4.95958 9.89516 4.4744 10.0961 3.9685 10.0961C3.4626 10.0961 2.97742 9.89516 2.61969 9.53743C2.26197 9.17971 2.061 8.69453 2.061 8.18862ZM16.6875 13.9698H11.658M11.658 13.9698C11.658 14.4758 11.4565 14.9615 11.0987 15.3193C10.7409 15.6771 10.2556 15.8781 9.74963 15.8781C9.24372 15.8781 8.75854 15.6763 8.40082 15.3186C8.04309 14.9608 7.84212 14.4757 7.84212 13.9698M11.658 13.9698C11.658 13.4637 11.4565 12.9789 11.0987 12.6211C10.7409 12.2633 10.2556 12.0622 9.74963 12.0622C9.24372 12.0622 8.75854 12.2632 8.40082 12.6209C8.04309 12.9787 7.84212 13.4638 7.84212 13.9698M7.84212 13.9698H0.5M16.6875 2.4075H13.9706M10.1548 2.4075H0.5M10.1548 2.4075C10.1548 1.9016 10.3557 1.41642 10.7134 1.05869C11.0712 0.700968 11.5563 0.5 12.0622 0.5C12.3127 0.5 12.5608 0.549339 12.7922 0.6452C13.0236 0.741061 13.2339 0.881566 13.4111 1.05869C13.5882 1.23582 13.7287 1.4461 13.8246 1.67753C13.9204 1.90896 13.9697 2.157 13.9697 2.4075C13.9697 2.658 13.9204 2.90604 13.8246 3.13747C13.7287 3.3689 13.5882 3.57918 13.4111 3.75631C13.2339 3.93343 13.0236 4.07394 12.7922 4.1698C12.5608 4.26566 12.3127 4.315 12.0622 4.315C11.5563 4.315 11.0712 4.11403 10.7134 3.75631C10.3557 3.39858 10.1548 2.9134 10.1548 2.4075Z" stroke="#2B2B2B" stroke-miterlimit="10" stroke-linecap="round"/>
</svg>
        <span>Filter</span>
      </button>

      <span class="exr-toolbar__count" data-exr-toolbar-count>
      {{ 'products.facets.product_count_simple' | t: count: collection.products_count | default: 'products' }}
      </span>
    </div>

    {%- if enable_sorting -%}
      <div class="exr-sort">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <select data-exr-sort class="exr-sort__select" aria-label="Sort by">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected{% endif %}>
              {{ option.name | escape }}
            </option>
          {%- endfor -%}
        </select>
        <span class="exr-sort__arrow">
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Overlay ── {%- endcomment -%}
  <div class="exr-overlay" data-exr-overlay></div>

  {%- comment -%} ── Drawer ── {%- endcomment -%}
  <div class="exr-drawer" data-exr-drawer aria-label="Filters">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="exr-drawer__header">
      <div class="exr-drawer__header-left">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M6.61111 8.33332H12.7222M0.5 1.66666H6.84188M9.94444 1.66666H12.7222M3.27778 8.33332H0.5" stroke="currentColor" stroke-linecap="round"/>
          <path d="M4.94482 7.06641C5.64413 7.06658 6.21125 7.63371 6.21143 8.33301C6.21143 9.03246 5.64424 9.59943 4.94482 9.59961C4.24526 9.59961 3.67822 9.03257 3.67822 8.33301C3.6784 7.6336 4.24537 7.06641 4.94482 7.06641ZM8.27783 0.400391C8.97739 0.400391 9.54443 0.967432 9.54443 1.66699C9.54426 2.3664 8.97728 2.93359 8.27783 2.93359C7.57838 2.93359 7.01141 2.3664 7.01123 1.66699C7.01123 0.967431 7.57827 0.400391 8.27783 0.400391Z" stroke="currentColor" stroke-width="0.8"/>
        </svg>
        <h3 class="exr-drawer__title">Filter</h3>
      </div>
      <button type="button" class="exr-drawer__close" data-exr-close aria-label="Close Filters">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 9 9" fill="none">
          <path d="M0.5 8.5L4.5 4.5L8.5 8.5M8.5 0.5L4.49924 4.5L0.5 0.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} ── Scrollable Body ── {%- endcomment -%}
    <div class="exr-drawer__body">
      <form data-exr-form>

        {%- for filter in collection.filters -%}
          <details class="exr-group" data-exr-group open>
            <summary class="exr-group__trigger" data-exr-trigger>
              <span>{{ filter.label | escape | upcase }}</span>
              <span class="exr-group__arrow">
                <svg width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>

            <div class="exr-group__body">

              {%- case filter.type -%}

                {%- when 'list' -%}
                  {%- comment -%} Detect if this is a color filter {%- endcomment -%}
                  {%- assign is_color = false -%}
                  {%- assign label_lower = filter.label | downcase -%}
                  {%- if label_lower contains 'color' or label_lower contains 'colour' or label_lower contains 'farge' -%}
                    {%- assign is_color = true -%}
                  {%- endif -%}

                  {%- if is_color -%}
                    {%- comment -%} ── COLOR SWATCHES ── {%- endcomment -%}
                    <ul class="exr-swatches">
                      {%- for value in filter.values -%}
                        {%- assign swatch_parts = value.label | split: '/' -%}
                        {%- assign c1 = blank -%}
                        {%- assign c2 = blank -%}
                        {%- assign c3 = blank -%}

                        {%- for part in swatch_parts -%}
                          {%- assign swatch_handle = part | downcase | replace: ' ', '-' -%}
                          {%- assign part_hex = '' -%}
                          {%- case swatch_handle -%}
                            {%- when 'beige' -%}{%- assign part_hex = '#C8B69E' -%}
                            {%- when 'blå' or 'bla' -%}{%- assign part_hex = '#3B82F6' -%}
                            {%- when 'brun' -%}{%- assign part_hex = '#8B6914' -%}
                            {%- when 'grå' or 'gra' or 'mørk-grå' -%}{%- assign part_hex = '#9CA3AF' -%}
                            {%- when 'grønn' or 'gronn' or 'grön' -%}{%- assign part_hex = '#22C55E' -%}
                            {%- when 'gul' -%}{%- assign part_hex = '#EAB308' -%}
                            {%- when 'hvit' or 'hvitt' -%}{%- assign part_hex = '#FFFFFF' -%}
                            {%- when 'lilla' -%}{%- assign part_hex = '#A855F7' -%}
                            {%- when 'marineblå' or 'marinebla' -%}{%- assign part_hex = '#1E3A5F' -%}
                            {%- when 'rosa' -%}{%- assign part_hex = '#F9A8D4' -%}
                            {%- when 'rød' or 'rod' -%}{%- assign part_hex = '#EF4444' -%}
                            {%- when 'sort' or 'svart' -%}{%- assign part_hex = '#1A1A1A' -%}
                            {%- when 'black' -%}{%- assign part_hex = '#000000' -%}
                            {%- when 'white' or 'off-white' or 'offwhite' -%}{%- assign part_hex = '#F5F5F0' -%}
                            {%- when 'navy' or 'dark-navy' -%}{%- assign part_hex = '#1B2A4A' -%}
                            {%- when 'denim' or 'dueblå' or 'duebla' -%}{%- assign part_hex = '#6B8CAE' -%}
                            {%- when 'burgunder' -%}{%- assign part_hex = '#800020' -%}
                            {%- when 'sand' or 'lyssand' -%}{%- assign part_hex = '#D2B48C' -%}
                            {%- when 'lysegrå' or 'lysegra' or 'blågrå' -%}{%- assign part_hex = '#D1D5DB' -%}
                            {%- when 'lysegul' -%}{%- assign part_hex = '#FDE68A' -%}
                            {%- when 'lyserosa' -%}{%- assign part_hex = '#FBCFE8' -%}
                            {%- when 'lyseblå' or 'lysebla' or 'lysblå' -%}{%- assign part_hex = '#93C5FD' -%}
                            {%- when 'mørk-brun' or 'mork-brun' -%}{%- assign part_hex = '#5C3317' -%}
                            {%- when 'mørk-oliven' or 'mork-oliven' or 'oliven' -%}{%- assign part_hex = '#556B2F' -%}
                            {%- when 'pink' -%}{%- assign part_hex = '#EC4899' -%}
                            {%- when 'red' -%}{%- assign part_hex = '#EF4444' -%}
                            {%- when 'blue' -%}{%- assign part_hex = '#3B82F6' -%}
                            {%- when 'green' -%}{%- assign part_hex = '#22C55E' -%}
                            {%- when 'yellow' -%}{%- assign part_hex = '#EAB308' -%}
                            {%- when 'orange' -%}{%- assign part_hex = '#F97316' -%}
                            {%- when 'brown' -%}{%- assign part_hex = '#92400E' -%}
                            {%- when 'grey' or 'gray' -%}{%- assign part_hex = '#9CA3AF' -%}
                            {%- when 'purple' -%}{%- assign part_hex = '#A855F7' -%}
                            {%- else -%}{%- assign part_hex = swatch_handle -%}
                          {%- endcase -%}

                          {%- if forloop.first -%}
                            {%- assign c1 = part_hex -%}
                          {%- elsif forloop.index == 2 -%}
                            {%- assign c2 = part_hex -%}
                          {%- elsif forloop.index == 3 -%}
                            {%- assign c3 = part_hex -%}
                          {%- endif -%}
                        {%- endfor -%}

                        {%- if c1 != blank and c2 != blank and c3 != blank -%}
                          {%- assign swatch_color_css = 'linear-gradient(90deg, ' | append: c1 | append: ' 50%, transparent 50%), linear-gradient(180deg, ' | append: c2 | append: ' 50%, ' | append: c3 | append: ' 50%)' -%}
                        {%- elsif c1 != blank and c2 != blank -%}
                          {%- assign swatch_color_css = 'linear-gradient(90deg, ' | append: c1 | append: ' 50%, ' | append: c2 | append: ' 50%)' -%}
                        {%- else -%}
                          {%- assign swatch_color_css = c1 -%}
                        {%- endif -%}

                        <li class="exr-swatch{% if value.count == 0 and value.active == false %} exr-swatch--disabled{% endif %}">
                          <input
                            class="exr-swatch__input"
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            id="exr-{{ filter.label | handleize }}-{{ forloop.index }}"
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          >
                          <label class="exr-swatch__label" for="exr-{{ filter.label | handleize }}-{{ forloop.index }}">
                            <span class="exr-swatch__check">
                              <svg viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                            <span class="exr-swatch__color" style="background: {{ swatch_color_css }};"></span>
                            <span class="exr-swatch__name">{{ value.label }}</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>

                  {%- else -%}
                    {%- comment -%} ── PILL BUTTONS (Product Type, Size, Activity, etc.) ── {%- endcomment -%}
                    <ul class="exr-pills">
                      {%- for value in filter.values -%}
                        <li class="exr-pill{% if value.count == 0 and value.active == false %} exr-pill--disabled{% endif %}">
                          <input
                            class="exr-pill__input"
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            id="exr-{{ filter.label | handleize }}-{{ forloop.index }}"
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          >
                          <label class="exr-pill__label" for="exr-{{ filter.label | handleize }}-{{ forloop.index }}">
                            {{ value.label }}
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                {%- when 'price_range' -%}
                  {%- comment -%} ── PRICE RANGE ── {%- endcomment -%}
                  <div class="exr-price">
                    <div class="exr-price__fields">
                      <div class="exr-price__field">
                        <span class="exr-price__currency">{{ cart.currency.symbol }}</span>
                        <input
                          class="exr-price__input"
                          data-exr-price-input
                          type="number"
                          name="{{ filter.min_value.param_name }}"
                          value="{{ filter.min_value.value }}"
                          min="0"
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          placeholder="{{ filter.min_value.value | default: 0 | money_without_currency }}"
                        >
                      </div>
                      <span class="exr-price__sep"></span>
                      <div class="exr-price__field">
                        <span class="exr-price__currency">{{ cart.currency.symbol }}</span>
                        <input
                          class="exr-price__input"
                          data-exr-price-input
                          type="number"
                          name="{{ filter.max_value.param_name }}"
                          value="{{ filter.max_value.value }}"
                          min="0"
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          placeholder="{{ filter.range_max | money_without_currency }}"
                        >
                      </div>
                    </div>
                  </div>

              {%- endcase -%}

            </div>
          </details>
        {%- endfor -%}

      </form>
    </div>

    {%- comment -%} ── Active Tags ── {%- endcomment -%}
    <div class="exr-active-tags" data-exr-active-tags>
      {%- for filter in collection.filters -%}
        {%- for value in filter.active_values -%}
          <a class="exr-active-tag" href="{{ value.url_to_remove }}" data-exr-remove="{{ value.url_to_remove }}">
            <small>{{ value.label }}</small>
            <span class="exr-active-tag__x">
              <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 9 9" fill="none">
                <path d="M0.5 8.5L4.5 4.5L8.5 8.5M8.5 0.5L4.49924 4.5L0.5 0.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        {%- endfor -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
            <a class="exr-active-tag" href="{{ filter.url_to_remove }}" data-exr-remove="{{ filter.url_to_remove }}">
              <small>{{ filter.min_value.value | default: 0 | money }} – {{ filter.max_value.value | default: filter.range_max | money }}</small>
              <span class="exr-active-tag__x">
                <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 9 9" fill="none">
                  <path d="M0.5 8.5L4.5 4.5L8.5 8.5M8.5 0.5L4.49924 4.5L0.5 0.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── Footer ── {%- endcomment -%}
    <div class="exr-drawer__footer">
      <button type="button" class="exr-btn" data-exr-close>
        Apply Filter
      </button>
      <button type="button" class="exr-btn" data-exr-close data-exr-count>
        View {{ collection.products_count }} items
      </button>
    </div>

  </div>

</exercer-filters>
