
  <div class="pdp-review-block block-{{ block.id }}" {{ block.shopify_attributes }}>
    <div class="pdp-review-container">
      
      {%- comment -%} Navigation Arrows - Top Right {%- endcomment -%}
      <div class="pdp-review-nav">
        <button class="pdp-review-prev" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="pdp-review-next" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <div class="pdp-review-slider">
        {%- for i in (1..5) -%}
          {%- assign rating_key = 'rating_' | append: i -%}
          {%- assign verified_key = 'verified_' | append: i -%}
          {%- assign title_key = 'title_' | append: i -%}
          {%- assign text_key = 'text_' | append: i -%}
          {%- assign author_key = 'author_' | append: i -%}

          {%- if block.settings[title_key] != blank -%}
            <div class="pdp-review-slide">
              <div class="pdp-review-card">
                
                <div class="pdp-review-header">
                  <div class="pdp-review-stars">
                    {%- assign current_rating = block.settings[rating_key] -%}
                    <div class="product__review-icons" style="display: flex; align-items: center; gap: 0px;"><img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
</div>
                  </div>
                  {% if block.settings[verified_key] %}
                    <div class="pdp-review-verified">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
<path d="M2 6.94471C2 4.81271 2 3.74671 2.252 3.38804C2.50333 3.03004 3.50533 2.68671 5.51 2.00071L5.892 1.87004C6.93667 1.51204 7.45867 1.33337 8 1.33337C8.54133 1.33337 9.06333 1.51204 10.108 1.87004L10.49 2.00071C12.4947 2.68671 13.4967 3.03004 13.748 3.38804C14 3.74671 14 4.81337 14 6.94471V7.99404C14 11.7527 11.174 13.5774 9.40067 14.3514C8.92 14.5614 8.68 14.6667 8 14.6667C7.32 14.6667 7.08 14.5614 6.59933 14.3514C4.826 13.5767 2 11.7534 2 7.99404V6.94471Z" stroke="#2B2B2B" stroke-width="0.8"/>
<path d="M6.3335 8.26675L7.28616 9.33341L9.66683 6.66675" stroke="#2B2B2B" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
                      <span>Verified</span>
                    </div>
                  {% endif %}
                </div>

                <div class="pdp-review-body">
                  <h4 class="pdp-review-title">{{ block.settings[title_key] }}</h4>
                  <div class="pdp-review-text">{{ block.settings[text_key] }}</div>
                </div>

                <div class="pdp-review-footer">
                  <span class="pdp-review-author">— {{ block.settings[author_key] }}</span>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <style>
    .pdp-review-block { margin: 25px 0; width: 100%; }
    .pdp-review-container { position: relative; width: 100%; }
    
    /* Card Style */
    .pdp-review-card {
      background-color: #F5F2ED; /* Matches image beige */
      border-radius: 12px; /* High radius like image */
      padding: 10px;
      position: relative;
    }

    /* Navigation */
    .pdp-review-nav {
      position: absolute;
      top: 30px;
      right: 35px;
      display: flex;
      gap: 8px;
      z-index: 5;
    }
    .pdp-review-nav button {
      background: #D8D3CC;
      border: none;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #FFF;
      padding: 0;
    }

    /* Header & Stars */
    .pdp-review-header { display: flex; align-items: center; gap: 12px; }
    .pdp-star { width: 20px; height: 20px; fill: #E0E0E0; }
    .pdp-star.is-filled { fill: #1F5E3F; } /* Dark Green */
    
    .pdp-review-verified { display: flex; align-items: center; gap: 4px; font-size: 13px; color: #666; font-style: italic; }

 .pdp-review-title {
    font-size: 17px;
    /* font-weight: 600; */
    color: #333;
    margin-block: 7px;
    line-height: 1.4;
}
    .pdp-review-text { 
      font-size: 15px; 
      color: #444; 
      line-height: 1.6; 
      margin-bottom: 15px;
    }
    .pdp-review-footer { text-align: right; }
    .pdp-review-author { font-weight: 600; font-size: 15px; color: #333; }

    /* Slider Logic */
    .pdp-review-slider {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .pdp-review-slider::-webkit-scrollbar { display: none; }
    .pdp-review-slide { flex: 0 0 100%; scroll-snap-align: start; }

    @media (max-width: 600px) {
      .pdp-review-card { padding: 25px 30px; border-radius: 25px; }
      .pdp-review-nav { top: 20px; right: 25px; }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const b = document.querySelector('.block-{{ block.id }}');
      const s = b.querySelector('.pdp-review-slider');
      b.querySelector('.pdp-review-next').onclick = () => s.scrollBy({left: s.offsetWidth, behavior: 'smooth'});
      b.querySelector('.pdp-review-prev').onclick = () => s.scrollBy({left: -s.offsetWidth, behavior: 'smooth'});
    });
  </script>