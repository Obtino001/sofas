  {%- assign metaobject = blank -%}
  {%- for collection in product.collections -%}
    {%- if collection.metafields.custom.why_you_love_it.value != blank -%}
      {%- assign metaobject_val = collection.metafields.custom.why_you_love_it.value -%}
      {%- if metaobject_val.first != blank -%}
        {%- assign metaobject = metaobject_val.first -%}
      {%- else -%}
        {%- assign metaobject = metaobject_val -%}
      {%- endif -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign title = block.settings.title -%}
  {%- if metaobject != blank and metaobject.heading != blank -%}
    {%- assign title = metaobject.heading -%}
  {%- endif -%}

  <div class="benefit-list-wrapper block-{{ block.id }}" {{ block.shopify_attributes }}>
    
    {% if title != blank %}
      <h3 class="benefit-list-title">{{ title }}</h3>
    {% endif %}
    
    <div class="benefit-list-container">
      {%- assign has_metaobject_items = false -%}
      {%- if metaobject != blank -%}
        {%- if metaobject.item_1 != blank or metaobject.item_2 != blank or metaobject.item_3 != blank or metaobject.item_4 != blank or metaobject.item_5 != blank -%}
          {%- assign has_metaobject_items = true -%}
        {%- endif -%}
      {%- endif -%}

      {%- if has_metaobject_items -%}
        {%- for i in (1..5) -%}
          {%- assign benefit_text = blank -%}
          {%- if i == 1 -%}{%- assign benefit_text = metaobject.item_1 -%}{%- endif -%}
          {%- if i == 2 -%}{%- assign benefit_text = metaobject.item_2 -%}{%- endif -%}
          {%- if i == 3 -%}{%- assign benefit_text = metaobject.item_3 -%}{%- endif -%}
          {%- if i == 4 -%}{%- assign benefit_text = metaobject.item_4 -%}{%- endif -%}
          {%- if i == 5 -%}{%- assign benefit_text = metaobject.item_5 -%}{%- endif -%}
          
          {%- if benefit_text != blank -%}
            <div class="benefit-list-item">
              <div class="benefit-icon">
                {%- if block.settings.custom_svg != blank -%}
                  {{ block.settings.custom_svg }}
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {%- endif -%}
              </div>
              <span class="benefit-text">{{ benefit_text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          {%- assign benefit_text_key = 'benefit_' | append: i -%}
          {%- assign benefit_text = block.settings[benefit_text_key] -%}
          
          {%- if benefit_text != blank -%}
            <div class="benefit-list-item">
              <div class="benefit-icon">
                {%- if block.settings.custom_svg != blank -%}
                  {{ block.settings.custom_svg }}
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {%- endif -%}
              </div>
              <span class="benefit-text">{{ benefit_text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <style>
    .block-{{ block.id }}.benefit-list-wrapper {
      margin: 25px 0;
      color: {{ block.settings.text_color | default: '#2B2B2B333' }};
    }
    
    .block-{{ block.id }} .benefit-list-title {
      font-size: 16px;
      font-weight: 600; /* Bold title like the image */
      margin: 0 0 16px 0;
      color: inherit;
      font-family: inherit;
      line-height: 1.2;
    }
    
    .block-{{ block.id }} .benefit-list-container {
      display: flex;
      flex-direction: column; /* 1-Column layout */
      gap: 12px; /* Spacing between list items */
    }
    
    .block-{{ block.id }} .benefit-list-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      font-family: inherit;
      font-weight: 400; /* Regular weight for list items */
      font-size: 15px; 
      line-height: 1.4;
      white-space: normal; /* Allows text to wrap safely on mobile */
    }
    
    .block-{{ block.id }} .benefit-icon {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 2px; /* Aligns the icon perfectly with the text baseline */
    }
    
    .block-{{ block.id }} .benefit-icon svg {
      width: 100%;
      height: 100%;
      color: {{ block.settings.icon_color | default: '#111111' }};
    }
  </style>