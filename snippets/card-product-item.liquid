{%- if card_product and card_product != empty -%}
  <style>
    .custom-upsell-card {
      display: flex;
      align-items: center;
      border: 1px solid #EAEAEA;
      border-radius: 8px;
      padding: 12px;
      background: #FFFFFF;
      gap: 16px;
      margin-bottom: 12px;
      text-decoration: none;
    }
    
    .custom-upsell-image {
      width: 80px;
      height: 80px;
      background: #F6F4EE;
      border-radius: 8px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    
    .custom-upsell-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .custom-upsell-details {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    
    .custom-upsell-title {
      font-size: 14px;
      font-weight: 500;
      color: #2B2B2B;
      text-decoration: none;
      margin: 0;
      line-height: 1.2;
    }
    
    .custom-upsell-swatches {
      display: flex;
      gap: 6px;
    }
    
    .custom-upsell-swatch {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 1px solid rgba(0,0,0,0.12);
      box-shadow: inset 0 0 0 2px #fff;
      display: inline-block;
      cursor: pointer;
      padding: 0;
      appearance: none;
      -webkit-appearance: none;
    }
    
    .custom-upsell-action {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 12px;
      flex-shrink: 0;
    }
    
    .custom-upsell-price {
      font-size: 15px;
      font-weight: 600;
      color: #000000;
    }
    
    .custom-upsell-btn {
      background-color: #CBAE8F;
      color: #FFFFFF;
      border: none;
      border-radius: 20px;
      padding: 6px 24px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 0.2s ease;
      position: relative;
      min-width: 70px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    
    .custom-upsell-btn:hover {
      opacity: 0.85;
    }
    
    .custom-upsell-btn:disabled {
      background-color: #E0E0E0;
      cursor: not-allowed;
      color: #888888;
    }
    
    .custom-upsell-btn.loading .ma-span,
    .custom-upsell-btn .ma-span.hidden {
      opacity: 0;
      visibility: hidden;
    }

    .custom-upsell-btn.loading {
      color: #CBAE8F;
      pointer-events: none;
    }

    .custom-upsell-btn .loading-overlay__spinner {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 1.8rem;
      height: 1.8rem;
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 2;
    }

    .custom-upsell-btn .loading-overlay__spinner:not(.hidden) {
      display: flex !important;
    }

    .custom-upsell-btn .loading-overlay__spinner .spinner {
      width: 1.8rem;
      height: 1.8rem;
    }

    .custom-upsell-btn .loading-overlay__spinner .path {
      stroke: currentColor;
    }

    /* Text-style Add on upsell (PDP + cart drawer) */
    .drawer__upsell-container-mobile .custom-upsell-btn.ma_quickAdd_atc {
      background: transparent;
      border: none;
      padding: 6px 12px;
      color: #CBAE8F;
      min-width: 48px;
      min-height: 28px;
    }

    .drawer__upsell-container-mobile .custom-upsell-btn.ma_quickAdd_atc:hover {
      opacity: 0.75;
    }

    .drawer__upsell-container-mobile .custom-upsell-btn.ma_quickAdd_atc.loading {
      color: #CBAE8F;
    }

    .custom-upsell-options {
      display: flex;
      flex-direction: column;
      gap: 2px;
      margin: 0;
    }

    .custom-upsell-option {
      font-size: 12px;
      color: #666666;
      line-height: 1.3;
    }

    .custom-upsell-option-name {
      color: #666666;
    }

    .custom-upsell-option-value {
      color: #2B2B2B;
    }

    .custom-upsell-swatch.is-active {
      box-shadow: inset 0 0 0 2px #fff, 0 0 0 1px #000;
    }
  </style>

  <div class="custom-upsell-card">
    <a href="{{ card_product.url }}" class="custom-upsell-image">
      {%- if card_product.featured_media -%}
        <img src="{{ card_product.featured_media | image_url: width: 160 }}" alt="{{ card_product.title | escape }}" loading="lazy" width="80" height="80">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </a>

    <div class="custom-upsell-details">
      <a href="{{ card_product.url }}" class="custom-upsell-title">{{ card_product.title }}</a>

      <div class="custom-upsell-options">
        {%- unless card_product.has_only_default_variant -%}
          {%- for option in card_product.options_with_values -%}
            <div class="custom-upsell-option">
              <span class="custom-upsell-option-name">{{ option.name }}:</span>
              <span class="custom-upsell-option-value" data-option-index="{{ forloop.index0 }}">{{ card_product.selected_or_first_available_variant.options[forloop.index0] }}</span>
            </div>
          {%- endfor -%}
        {%- endunless -%}
      </div>

      {%- for option in card_product.options_with_values -%}
        {%- assign option_name_lower = option.name | downcase | strip -%}
        {%- if option_name_lower contains 'colour' or option_name_lower contains 'color' -%}
          {%- assign colour_option_index = forloop.index0 -%}
          <div class="custom-upsell-swatches">
            {%- for value in option.values -%}
              {%- liquid
                assign variant_for_value = card_product.variants | where: 'option1', value | first
                if variant_for_value == blank
                  assign variant_for_value = card_product.variants | where: 'option2', value | first
                endif
                if variant_for_value == blank
                  assign variant_for_value = card_product.variants | where: 'option3', value | first
                endif

                assign variant_image = variant_for_value.featured_media | default: card_product.featured_media
                assign is_selected_swatch = false
                if card_product.selected_or_first_available_variant.options[colour_option_index] == value
                  assign is_selected_swatch = true
                endif

                assign sw_bg = ''
                if value.swatch.image
                  assign sw_img_url = value.swatch.image | image_url: width: 50
                  assign sw_bg = 'url(' | append: sw_img_url | append: ')'
                elsif value.swatch.color
                  assign sw_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                else
                  assign sw_bg = value | downcase | remove: ' '
                endif
              -%}
              <button
                type="button"
                class="custom-upsell-swatch{% if is_selected_swatch %} is-active{% endif %}"
                style="background: {{ sw_bg }}; background-size: cover; background-position: center;"
                title="{{ value }}"
                aria-label="{{ option.name }}: {{ value }}"
                data-variant-id="{{ variant_for_value.id }}"
                data-variant-options="{{ variant_for_value.options | json | escape }}"
                data-image-url="{{ variant_image | image_url: width: 160 }}"
                data-price="{{ variant_for_value.price | money }}"
                data-available="{{ variant_for_value.available }}"
                onclick="updateUpsellVariant(this)"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="custom-upsell-action">
      <div class="custom-upsell-price">
        {{ card_product.price | money }}
      </div>
      
      <ma-quickadd>
        <button
          type="button"
          class="custom-upsell-btn ma_Add_atc ma_quickAdd_atc"
          data-variantid="{{ card_product.selected_or_first_available_variant.id }}"
          {% if card_product.selected_or_first_available_variant.available == false %}
            disabled
          {% endif %}
        >
          <span class="ma-span">
            {%- if card_product.selected_or_first_available_variant.available -%}
              Add
            {%- else -%}
              Sold
            {%- endif -%}
          </span>
          <div class="loading-overlay__spinner hidden">
            <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
              <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
            </svg>
          </div>
        </button>
      </ma-quickadd>
    </div>
  </div>

  <script>
    if (typeof updateUpsellVariant !== 'function') {
      function updateUpsellVariant(element) {
        const card = element.closest('.custom-upsell-card');
        if (!card) return;

        const variantId = element.getAttribute('data-variant-id');
        const imageUrl = element.getAttribute('data-image-url');
        const price = element.getAttribute('data-price');
        const available = element.getAttribute('data-available') === 'true';
        let variantOptions = [];
        try {
          variantOptions = JSON.parse(element.getAttribute('data-variant-options') || '[]');
        } catch (e) {
          variantOptions = [];
        }

        // Update image
        const imageEl = card.querySelector('.custom-upsell-image img');
        if (imageEl && imageUrl && imageUrl !== '') {
          imageEl.src = imageUrl;
          imageEl.srcset = imageUrl;
        }

        // Update price
        const priceEl = card.querySelector('.custom-upsell-price');
        if (priceEl && price) {
          priceEl.innerHTML = price;
        }

        // Update selected option labels
        card.querySelectorAll('.custom-upsell-option-value').forEach((valueEl, index) => {
          if (variantOptions[index]) {
            valueEl.textContent = variantOptions[index];
          }
        });

        // Update variant ID on add button
        const btnEl = card.querySelector('.ma_quickAdd_atc');
        if (btnEl && variantId) {
          btnEl.dataset.variantid = variantId;
        }

        // Update button state
        if (btnEl) {
          const spanEl = btnEl.querySelector('.ma-span');
          if (available) {
            btnEl.removeAttribute('disabled');
            if (spanEl) spanEl.textContent = 'Add';
          } else {
            btnEl.setAttribute('disabled', 'disabled');
            if (spanEl) spanEl.textContent = 'Sold';
          }
        }

        // Update active state visual
        const swatches = card.querySelectorAll('.custom-upsell-swatch');
        swatches.forEach((s) => s.classList.remove('is-active'));
        element.classList.add('is-active');
      }
    }
  </script>
{%- endif -%}