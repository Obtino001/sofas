{%- if card_product and card_product != empty -%}
  <style>
    .custom-upsell-card {
      display: flex;
      align-items: center;
      border: 1px solid #EAEAEA;
      border-radius: 8px;
      padding: 12px;
      background: #FFFFFF;
      gap: 16px;
      margin-bottom: 12px;
      text-decoration: none;
    }
    
    .custom-upsell-image {
      width: 80px;
      height: 80px;
      background: #F6F4EE;
      border-radius: 8px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    
    .custom-upsell-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .custom-upsell-details {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    
    .custom-upsell-title {
      font-size: 14px;
      font-weight: 500;
      color: #2B2B2B;
      text-decoration: none;
      margin: 0;
      line-height: 1.2;
    }
    
    .custom-upsell-swatches {
      display: flex;
      gap: 6px;
    }
    
    .custom-upsell-swatch {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      border: 1px solid rgba(0,0,0,0.12);
      box-shadow: inset 0 0 0 2px #fff;
      display: inline-block;
      cursor: pointer;
    }
    
    .custom-upsell-action {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 12px;
      flex-shrink: 0;
    }
    
    .custom-upsell-price {
      font-size: 15px;
      font-weight: 600;
      color: #000000;
    }
    
    .custom-upsell-btn {
      background-color: #CBAE8F;
      color: #FFFFFF;
      border: none;
      border-radius: 20px;
      padding: 6px 24px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 0.2s ease;
      position: relative;
      min-width: 70px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    
    .custom-upsell-btn:hover {
      opacity: 0.85;
    }
    
    .custom-upsell-btn:disabled {
      background-color: #E0E0E0;
      cursor: not-allowed;
      color: #888888;
    }
    
    .custom-upsell-form {
      margin: 0;
    }

    .custom-upsell-btn > .loading__spinner {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 1.5rem;
      align-items: center;
      justify-content: center;
    }
    
    .custom-upsell-btn .path {
      stroke: #FFFFFF;
    }
    
    .custom-upsell-btn.loading > span {
      color: transparent;
    }
  </style>

  <div class="custom-upsell-card">
    <a href="{{ card_product.url }}" class="custom-upsell-image">
      {%- if card_product.featured_media -%}
        <img src="{{ card_product.featured_media | image_url: width: 160 }}" alt="{{ card_product.title | escape }}" loading="lazy" width="80" height="80">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </a>

    <div class="custom-upsell-details">
      <a href="{{ card_product.url }}" class="custom-upsell-title">{{ card_product.title }}</a>
      {%- for option in card_product.options_with_values -%}
        {%- assign option_name_lower = option.name | downcase -%}
        {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
          <div class="custom-upsell-swatches">
            {%- for value in option.values -%}
              {%- liquid
                assign variant_for_value = card_product.variants | where: 'option1', value | first
                if variant_for_value == blank
                  assign variant_for_value = card_product.variants | where: 'option2', value | first
                endif
                if variant_for_value == blank
                  assign variant_for_value = card_product.variants | where: 'option3', value | first
                endif

                assign sw_bg = ''
                if value.swatch.image
                  assign sw_img_url = value.swatch.image | image_url: width: 50
                  assign sw_bg = 'url(' | append: sw_img_url | append: ')'
                elsif value.swatch.color
                  assign sw_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                else
                  assign sw_bg = value | downcase | remove: ' '
                endif
              -%}
              <span class="custom-upsell-swatch" 
                    style="background: {{ sw_bg }}; background-size: cover; background-position: center;" 
                    title="{{ value }}"
                    data-variant-id="{{ variant_for_value.id }}"
                    data-image-url="{{ variant_for_value.featured_media | image_url: width: 160 }}"
                    data-price="{{ variant_for_value.price | money }}"
                    data-available="{{ variant_for_value.available }}"
                    onclick="updateUpsellVariant(this)"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="custom-upsell-action">
      <div class="custom-upsell-price">
        {{ card_product.price | money }}
      </div>
      
      <product-form>
        {%- form 'product', card_product, class: 'custom-upsell-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}" class="product-variant-id">
          
          <button type="submit" name="add" class="custom-upsell-btn" aria-live="polite"
            {% if card_product.selected_or_first_available_variant.available == false %}
              disabled
            {% endif %}>
            <span>
              {%- if card_product.selected_or_first_available_variant.available -%}
                Add
              {%- else -%}
                Sold
              {%- endif -%}
            </span>
            <span class="sold-out-message hidden">
              Sold
            </span>
            {%- render 'loading-spinner' -%}
          </button>
        {%- endform -%}
      </product-form>
    </div>
  </div>

  <script>
    if (typeof updateUpsellVariant !== 'function') {
      function updateUpsellVariant(element) {
        const card = element.closest('.custom-upsell-card');
        if (!card) return;

        const variantId = element.getAttribute('data-variant-id');
        const imageUrl = element.getAttribute('data-image-url');
        const price = element.getAttribute('data-price');
        const available = element.getAttribute('data-available') === 'true';

        // Update image
        const imageEl = card.querySelector('.custom-upsell-image img');
        if (imageEl && imageUrl && imageUrl !== '') {
          imageEl.src = imageUrl;
          imageEl.srcset = imageUrl;
        }

        // Update variant ID in form
        const inputEl = card.querySelector('.product-variant-id');
        if (inputEl && variantId) {
          inputEl.value = variantId;
        }

        // Update price
        const priceEl = card.querySelector('.custom-upsell-price');
        if (priceEl && price) {
          priceEl.innerHTML = price;
        }

        // Update button state
        const btnEl = card.querySelector('.custom-upsell-btn');
        if (btnEl) {
          const spanEl = btnEl.querySelector('span:not(.sold-out-message)');
          if (available) {
            btnEl.removeAttribute('disabled');
            if(spanEl) spanEl.textContent = 'Add';
          } else {
            btnEl.setAttribute('disabled', 'disabled');
            if(spanEl) spanEl.textContent = 'Sold';
          }
        }

        // Update active state visual
        const swatches = card.querySelectorAll('.custom-upsell-swatch');
        swatches.forEach(s => s.style.boxShadow = 'inset 0 0 0 2px #fff');
        element.style.boxShadow = 'inset 0 0 0 2px #fff, 0 0 0 1px #000';
      }
    }
  </script>
{%- endif -%}