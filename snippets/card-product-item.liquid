{%- if card_product and card_product != empty -%}
  <style>
    .custom-upsell-card {
      display: flex;
      align-items: center;
      border: 1px solid #EAEAEA;
      border-radius: 8px;
      padding: 12px;
      background: #FFFFFF;
      gap: 16px;
      margin-bottom: 12px;
      text-decoration: none;
    }
    
    .custom-upsell-image {
      width: 80px;
      height: 80px;
      background: #F6F4EE;
      border-radius: 8px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    
    .custom-upsell-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .custom-upsell-details {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    
    .custom-upsell-title {
      font-size: 14px;
      font-weight: 500;
      color: #2B2B2B;
      text-decoration: none;
      margin: 0;
      line-height: 1.2;
    }
    
    .custom-upsell-swatches {
      display: flex;
      gap: 6px;
    }
    
    .custom-upsell-swatch {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      border: 1px solid #4A4A4A;
      display: inline-block;
    }
    
    .custom-upsell-action {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 12px;
      flex-shrink: 0;
    }
    
    .custom-upsell-price {
      font-size: 15px;
      font-weight: 600;
      color: #000000;
    }
    
    .custom-upsell-btn {
      background-color: #CBAE8F;
      color: #FFFFFF;
      border: none;
      border-radius: 20px;
      padding: 6px 24px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 0.2s ease;
    }
    
    .custom-upsell-btn:hover {
      opacity: 0.85;
    }
    
    .custom-upsell-btn:disabled {
      background-color: #E0E0E0;
      cursor: not-allowed;
      color: #888888;
    }
    
    .custom-upsell-form {
      margin: 0;
    }
  </style>

  <div class="custom-upsell-card">
    <a href="{{ card_product.url }}" class="custom-upsell-image">
      {%- if card_product.featured_media -%}
        <img src="{{ card_product.featured_media | image_url: width: 160 }}" alt="{{ card_product.title | escape }}" loading="lazy" width="80" height="80">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </a>

    <div class="custom-upsell-details">
      <a href="{{ card_product.url }}" class="custom-upsell-title">{{ card_product.title }}</a>
      {%- for option in card_product.options_with_values -%}
        {%- assign option_name_lower = option.name | downcase -%}
        {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
          <div class="custom-upsell-swatches">
            {%- for value in option.values -%}
              {%- assign bg_color = value | downcase | remove: ' ' -%}
              <span class="custom-upsell-swatch" style="background-color: {{ bg_color }};" title="{{ value }}"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="custom-upsell-action">
      <div class="custom-upsell-price">
        {{ card_product.price | money }}
      </div>
      
      <product-form>
        {%- form 'product', card_product, class: 'custom-upsell-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}">
          
          {%- if card_product.available -%}
            <button type="submit" name="add" class="custom-upsell-btn">Add</button>
          {%- else -%}
            <button type="submit" class="custom-upsell-btn" disabled>Sold</button>
          {%- endif -%}
        {%- endform -%}
      </product-form>
    </div>
  </div>
{%- endif -%}