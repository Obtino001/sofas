<style>
  swiper-gallery { 
    display: block; 
    width: 100%; 
    opacity: 0; 
    transition: opacity 0.2s ease-in; 
    --border-radius: {{ section.settings.border_radius | default: 12 }}px;
    --thumb-gap: {{ section.settings.thumb_gap | default: 10 }}px;
    --desktop-cols: {{ section.settings.desktop_columns | default: 2 }};
    --mobile-cols: {{ section.settings.mobile_columns | default: 4 }};
  }
  swiper-gallery.loaded { opacity: 1; }
  
  .swiper-gallery-main { 
    width: 100%; 
    position: relative; 
    overflow: hidden; 
    border-radius: var(--border-radius);
  }
  .swiper-gallery-main .swiper-slide { display: flex; align-items: center; justify-content: center; height: 100%; }
  .swiper-gallery-main img { width: 100%; height: 100%; object-fit: cover; }
  
  .swiper-gallery-thumbs { 
    margin-top: var(--thumb-gap); 
    opacity: 0; 
    transition: opacity 0.3s; 
    box-sizing: border-box; 
  }
  swiper-gallery.loaded .swiper-gallery-thumbs { opacity: 1; }
  
  .swiper-gallery-thumbs .swiper-slide { 
    cursor: pointer; 
    border: 2px solid transparent; 
    transition: all 0.2s; 
    display: flex; 
    align-items: center; 
    justify-content: center;      
    border-radius: var(--border-radius);
    box-sizing: border-box;
  }
  .swiper-gallery-thumbs .swiper-slide img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    display: block;      
    border-radius: calc(var(--border-radius) - 3px); 
  }
  .swiper-gallery-thumbs .swiper-slide-thumb-active { 
    opacity: 1; 
    border-color: #000;      
  }

  /* Custom Arrows */
  .swiper-button-next, .swiper-button-prev { 
    color: #000; 
    display: flex !important;
    width: 40px !important;
    height: 40px !important;
    background: #f1ede9;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: background 0.2s ease;
  }
  
  /* Custom Line Pagination */
  .swiper-gallery-main .swiper-pagination {
    bottom: 15px !important;
  }
  .swiper-gallery-main .swiper-pagination-bullet {
    width: 35px;
    height: 3px;
    background: #ffffff;
    opacity: 0.6;
    border-radius: 2px;
    margin: 0 4px !important;
    transition: all 0.3s ease;
  }
  .swiper-gallery-main .swiper-pagination-bullet-active {
    background: #000000;
    opacity: 1;
  }

  /* Desktop Grid Overrides */
  @media (min-width: 750px) {
    swiper-gallery.desktop-grid .swiper-gallery-thumbs .swiper-wrapper { 
      flex-wrap: wrap !important; 
      transform: none !important; 
      gap: var(--thumb-gap); 
    }
    swiper-gallery.desktop-grid .swiper-gallery-thumbs .swiper-slide { 
      width: calc((100% - (var(--desktop-cols) - 1) * var(--thumb-gap)) / var(--desktop-cols)) !important; 
      margin-right: 0 !important; 
      margin-bottom: var(--thumb-gap); 
    }
  }

  /* Mobile Grid Overrides */
  @media (max-width: 749px) {
    swiper-gallery.mobile-grid .swiper-gallery-thumbs .swiper-wrapper { 
      flex-wrap: wrap !important; 
      transform: none !important; 
      gap: var(--thumb-gap); 
    }
    swiper-gallery.mobile-grid .swiper-gallery-thumbs .swiper-slide { 
      width: calc((100% - (var(--mobile-cols) - 1) * var(--thumb-gap)) / var(--mobile-cols)) !important; 
      margin-right: 0 !important; 
      margin-bottom: var(--thumb-gap); 
    }
  }

  .gallery-master-repository { display: none !important; }
</style>

{%- liquid
  assign media_count = product.media.size
  assign group_enabled = section.settings.enable_group_by_color
  assign show_all_in_lightbox = section.settings.fancybox_show_all
  assign target_color_name = section.settings.color_option_name | downcase
  assign color_option_index = 'option1'
  for option in product.options_with_values
    assign option_downcase = option.name | downcase
    if option_downcase == target_color_name
        assign option_position = forloop.index
        assign color_option_index = 'option' | append: option_position
    endif
  endfor
  assign initial_color_value = product.selected_or_first_available_variant[color_option_index] | escape
-%}

<swiper-gallery 
  id="Gallery-{{ section.id }}" 
  data-section-id="{{ section.id }}" 
  data-group-enabled="{{ group_enabled }}" 
  data-show-all-lightbox="{{ show_all_in_lightbox }}" 
  data-initial-color="{{ initial_color_value }}" 
  class="product__media-gallery-wrapper desktop-{{ section.settings.desktop_layout | default: 'grid' }} mobile-{{ section.settings.mobile_layout | default: 'slider' }}"
>
  <div class="gallery-master-repository">
    {%- for media in product.media -%}
      {%- assign media_alt = media.alt | strip | downcase -%}
      <div class="swiper-slide master-main-slide" data-media-id="{{ media.id }}" data-alt="{{ media_alt }}">
        {% render 'product-thumbnail', media: media, lazy_load: true %}
      </div>
      <div class="swiper-slide master-thumb-slide" data-media-id="{{ media.id }}">
         {{ media.preview_image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
      </div>
    {%- endfor -%}
  </div>

  <div class="swiper swiper-gallery-main">
    <div class="swiper-wrapper" id="MainWrapper-{{ section.id }}"></div>
    {% if product.media.size > 1 %}
    {% if section.settings.show_main_arrows %}
      <div class="swiper-button-next main-next"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
<path d="M9 18L15 12L9 6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></div>
      <div class="swiper-button-prev main-prev"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
<path d="M15 18L9 12L15 6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></div>
    {% endif %}
    
    {% if section.settings.show_main_pagination %}
      <div class="swiper-pagination"></div>
    {% endif %}
    {% endif %}
  </div>

  {% comment %} <div class="swiper swiper-gallery-thumbs" {% if media_count < 2 %}style="display:none"{% endif %}>
    <div class="swiper-wrapper" id="ThumbWrapper-{{ section.id }}"></div>
    {% if section.settings.show_thumbs_arrows %}
      <div class="swiper-button-next thumbs-next"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
<path d="M9 18L15 12L9 6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></div>
      <div class="swiper-button-prev thumbs-prev"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
<path d="M15 18L9 12L15 6" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></div>
    {% endif %}
  </div> {% endcomment %}

  <script type="application/json" class="variant-map">
    {
      {%- for variant in product.variants -%}
        "{{ variant.id }}": {
          "media_id": "{{ variant.featured_media.id }}",
          "color": "{{ variant[color_option_index] | escape }}"
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    }
  </script>
</swiper-gallery>

<script>
  if (!customElements.get('swiper-gallery')) {
    class SwiperGallery extends HTMLElement {
      constructor() {
        super();
        this.mainSwiper = null;
        this.thumbsSwiper = null;
      }
      connectedCallback() {
        this.sectionId = this.dataset.sectionId;
        this.groupEnabled = this.dataset.groupEnabled === 'true';
        this.showAllLightbox = this.dataset.showAllLightbox === 'true';
        this.initialColor = this.dataset.initialColor;
        this.mainWrapper = this.querySelector(`#MainWrapper-${this.sectionId}`);
        this.thumbWrapper = this.querySelector(`#ThumbWrapper-${this.sectionId}`);
        this.masterRepo = this.querySelector('.gallery-master-repository');
        this.variantMap = JSON.parse(this.querySelector('.variant-map').textContent);
        
        this.onVariantChange = this.onVariantChange.bind(this);
        document.addEventListener('change', this.onVariantChange);
        
        this.render(this.initialColor);
        this.classList.add('loaded');
      }
      disconnectedCallback() {
        if (this.mainSwiper) this.mainSwiper.destroy(true, true);
        if (this.thumbsSwiper) this.thumbsSwiper.destroy(true, true);
        document.removeEventListener('change', this.onVariantChange);
      }

      maskMaster() {
        this.masterRepo.querySelectorAll('[data-fancybox]').forEach(el => {
          el.setAttribute('data-fb-hidden', el.getAttribute('data-fancybox'));
          el.removeAttribute('data-fancybox');
        });
      }
  
      unmaskFancybox(elContainer) {
        elContainer.querySelectorAll('[data-fb-hidden]').forEach(el => {
          el.setAttribute('data-fancybox', el.getAttribute('data-fb-hidden'));
          el.removeAttribute('data-fb-hidden');
        });
      }
      
      render(colorName) {
        this.maskMaster();
        
        const allMain = Array.from(this.masterRepo.querySelectorAll('.master-main-slide'));
        const allThumb = Array.from(this.masterRepo.querySelectorAll('.master-thumb-slide'));
        
        this.mainWrapper.innerHTML = '';
        this.thumbWrapper.innerHTML = '';
        
        const normalizedColor = colorName ? colorName.trim().toLowerCase() : '';
      
        let indicesToShow = [];
        if (this.groupEnabled && normalizedColor) {
           allMain.forEach((slide, i) => { if(slide.dataset.alt === normalizedColor) indicesToShow.push(i); });
        }
        if (indicesToShow.length === 0) indicesToShow = allMain.map((_, i) => i);
        
        allMain.forEach((slide, index) => {
          if (indicesToShow.includes(index)) {
             const clone = slide.cloneNode(true);
             this.unmaskFancybox(clone);
             this.mainWrapper.appendChild(clone);
             this.thumbWrapper.appendChild(allThumb[index].cloneNode(true));
          } else {
             if (this.showAllLightbox) {
               this.unmaskFancybox(slide);
             }
          }
        });

        this.initSwiper();
      }
      
      initSwiper() {
        if (this.mainSwiper) this.mainSwiper.destroy(true, true);
        if (this.thumbsSwiper) this.thumbsSwiper.destroy(true, true);

        // Fetch dynamic columns and gaps from CSS variables set via Schema
        const desktopCols = parseInt(getComputedStyle(this).getPropertyValue('--desktop-cols').trim()) || 2;
        const mobileCols = parseInt(getComputedStyle(this).getPropertyValue('--mobile-cols').trim()) || 4;
        const thumbGap = parseInt(getComputedStyle(this).getPropertyValue('--thumb-gap').trim()) || 10;

        this.thumbsSwiper = new Swiper(this.querySelector('.swiper-gallery-thumbs'), {
          spaceBetween: thumbGap,
          slidesPerView: mobileCols,
          freeMode: false,
          watchSlidesProgress: true,
          navigation: { nextEl: this.querySelector('.thumbs-next'), prevEl: this.querySelector('.thumbs-prev') },
          breakpoints: { 750: { slidesPerView: desktopCols } }
        });
        
        this.mainSwiper = new Swiper(this.querySelector('.swiper-gallery-main'), {
          spaceBetween: 10,
          navigation: { nextEl: this.querySelector('.main-next'), prevEl: this.querySelector('.main-prev') },
          pagination: { el: this.querySelector('.swiper-pagination'), clickable: true },
          thumbs: { swiper: this.thumbsSwiper }
        });
      }
      
      onVariantChange(e) {
        if (e.target.matches('input[name="id"], select[name="id"]')) {
          const variantId = e.target.value;
          const data = this.variantMap[variantId];
          if (!data) return;
          if (this.currentMediaId && this.currentMediaId === data.media_id) {
            return;
          }
          this.currentMediaId = data.media_id;
          if (this.groupEnabled && data.color) this.render(data.color);

          setTimeout(() => {
            if (this.mainSwiper && data.media_id) {
              const slides = this.querySelectorAll('.swiper-gallery-main .swiper-slide');
              slides.forEach((slide, idx) => {
                if (slide.dataset.mediaId === data.media_id.toString()) {
                  this.mainSwiper.slideTo(idx);
                }
              });
            }
          }, 50);
        }
      }
    }
    customElements.define('swiper-gallery', SwiperGallery);
  }
</script>