{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Main Card Container */
  .custom-hero-{{ section.id }} {
    position: relative;
    display: flex;
    min-height: {{ section.settings.mobile_height }}px;
    align-items: {{ section.settings.mobile_align_y }};
    justify-content: {{ section.settings.mobile_align_x }};
    /* Removes border-radius if full width is enabled */
    border-radius: {% if section.settings.full_width %}0{% else %}15px{% endif %}; 
    overflow: hidden;    /* Keeps image inside rounded corners */
  }

  @media screen and (min-width: 750px) {
    .custom-hero-{{ section.id }} {
      min-height: {{ section.settings.desktop_height }}px;
      align-items: {{ section.settings.desktop_align_y }};
      justify-content: {{ section.settings.desktop_align_x }};
    }
  }

  .custom-hero-{{ section.id }} .hero-background-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Mobile vs Desktop Image Display Logic */
  .custom-hero-{{ section.id }} .hero-background-image--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .custom-hero-{{ section.id }} .hero-background-image {
      object-position: 70% 100%;
    }
    .custom-hero-{{ section.id }} .hero-background-image--desktop-only {
      display: none;
    }
    .custom-hero-{{ section.id }} .hero-background-image--mobile {
      display: block;
    }
  }

  /* Custom Color/Gradient Overlay */
  .custom-hero-{{ section.id }} .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: {{ section.settings.overlay_background }};
    
    {%- if section.settings.enable_blur -%}
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    {%- endif -%}
  }

  /* Content Wrapper */
  .custom-hero-{{ section.id }} .hero-content-wrapper {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 650px;
    color: rgb(var(--color-foreground));
    text-align: {{ section.settings.mobile_text_align }};
    align-items: {{ section.settings.mobile_flex_align }};
    padding: 3rem 2rem;
  }

  @media screen and (min-width: 750px) {
    .custom-hero-{{ section.id }} .hero-content-wrapper {
      text-align: {{ section.settings.desktop_text_align }};
      align-items: {{ section.settings.desktop_flex_align }};
      padding: 5rem 6rem;
    }
  }

  /* Base Scoped Styles */
  .hero-block-icon {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-content-wrapper * {
    margin: 0;
  }
  .hero-block-icon .icon-svg-wrapper,
  .hero-block-icon img {
    width: var(--icon-width);
    max-width: 100%;
    height: auto;
    display: block;
  }
  .hero-block-icon .icon-svg-wrapper svg {
    width: 100%;
    height: auto;
    fill: currentColor;
    stroke: currentColor;
  }
  .hero-block-text {
    line-height: 1.6;
    font-weight: 400;
    color: inherit;
  }
  .hero-block-text p {
    margin: 0;
  }
  .hero-block-button {
    margin-top: 1rem;
    min-width: 200px;
  }
  .hero-block-button-pill {
    border-radius: 50px !important;
    background-color: #C19A6B !important;
    color: #FFFFFF !important;
    border: none !important;
    margin-top: 1rem;
    min-width: 200px;
  }
  .hero-block-button-pill:hover {
    background-color: #a8855a !important;
  }

  /* Mobile Color Scheme Override */
  @media screen and (max-width: 749px) {
    .custom-hero-{{ section.id }}.color-mobile-{{ section.settings.color_scheme_mobile }} {
      --color-background: var(--color-{{ section.settings.color_scheme_mobile }}-background);
      --color-foreground: var(--color-{{ section.settings.color_scheme_mobile }}-text);
      --color-button: var(--color-{{ section.settings.color_scheme_mobile }}-button);
      --color-button-text: var(--color-{{ section.settings.color_scheme_mobile }}-button-text);
      --color-secondary-button-text: var(--color-{{ section.settings.color_scheme_mobile }}-secondary-button-text);
      
      background: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding{% unless section.settings.full_width %} page-width{% endunless %}">
  <div class="custom-hero-{{ section.id }} color-{{ section.settings.color_scheme }} color-mobile-{{ section.settings.color_scheme_mobile }} gradient">
    
    {%- if section.settings.image != blank -%}
      {%- liquid
        assign desktop_image_class = 'hero-background-image'
        if section.settings.mobile_image != blank
          assign desktop_image_class = desktop_image_class | append: ' hero-background-image--desktop-only'
        endif
      -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'lazy',
          class: desktop_image_class,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      }}
    {%- endif -%}

    {%- if section.settings.mobile_image != blank -%}
      {{
        section.settings.mobile_image
        | image_url: width: 3840
        | image_tag:
          loading: 'lazy',
          class: 'hero-background-image hero-background-image--mobile',
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      }}
    {%- endif -%}

    <div class="hero-overlay"> </div>

    <div class="hero-content-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'icon' -%}
            <div class="hero-block-icon" {{ block.shopify_attributes }} style="--icon-width: {{ block.settings.icon_width }}px; margin-bottom: {{ block.settings.margin_bottom }}px;">
              {%- if block.settings.custom_svg != blank -%}
                <div class="icon-svg-wrapper">
                  {{ block.settings.custom_svg }}
                </div>
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: block.settings.icon_width }}" alt="Icon" loading="lazy">
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-svg-wrapper">
                  <circle cx="12" cy="12" r="3"></circle>
                  <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
              {%- endif -%}
            </div>

          {%- when 'heading' -%}
            <h2 class="hero-block-heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h2>

          {%- when 'text' -%}
            <div class="hero-block-text {{ block.settings.text_size }}" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {%- when 'button' -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="button button--primary hero-block-button" {{ block.shopify_attributes }}>
                {{ block.settings.button_label | escape }}
              </a>
            {%- endif -%}

          {%- when 'button_pill' -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="button hero-block-button-pill" {{ block.shopify_attributes }}>
                {{ block.settings.button_label | escape }}
              </a>
            {%- endif -%}

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Overlay Banner (Blocks)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme (Desktop)",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_mobile",
      "label": "Color Scheme (Mobile)",
      "default": "scheme-1",
      "info": "Overrides the desktop color scheme on mobile screens."
    },
    {
      "type": "header",
      "content": "Overlay Settings"
    },
    {
      "type": "color_background",
      "id": "overlay_background",
      "label": "Overlay Color / Gradient",
      "default": "linear-gradient(270deg, rgba(0, 0, 0, 0) 24.03%, rgba(0, 0, 0, 0.35) 80.49%)",
      "info": "Choose a solid color or gradient to overlay on the image."
    },
    {
      "type": "checkbox",
      "id": "enable_blur",
      "label": "Enable Frosted Glass Blur",
      "default": false,
      "info": "Applies a blur effect underneath your chosen overlay color."
    },
    {
      "type": "header",
      "content": "Background Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Background Image (Mobile)",
      "info": "Optional. Overrides the desktop image on smaller screens."
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Desktop Height",
      "default": 480
    },
    {
      "type": "select",
      "id": "desktop_align_y",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_align_x",
      "label": "Horizontal Position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "desktop_text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "desktop_flex_align",
      "label": "Content Box Alignment",
      "info": "Aligns the blocks within the content wrapper.",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Mobile Height",
      "default": 400
    },
    {
      "type": "select",
      "id": "mobile_align_y",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_align_x",
      "label": "Horizontal Position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_flex_align",
      "label": "Content Box Alignment",
      "info": "Aligns the blocks within the content wrapper.",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Icon",
      "limit": 1,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code",
          "info": "Paste your raw SVG code here."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Or Image fallback"
        },
        {
          "type": "range",
          "id": "icon_width",
          "min": 20,
          "max": 200,
          "step": 2,
          "unit": "px",
          "label": "Icon Width",
          "default": 64
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 50,
          "step": 2,
          "unit": "px",
          "label": "Bottom Margin",
          "default": 10
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Sleep <em>bigger</em>. Sleep <em>better</em>.",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
            { "value": "hxl", "label": "Extra large" }
          ],
          "default": "h0",
          "label": "Heading Size"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Upgrade your bedroom with spacious king size beds designed for ultimate comfort and everyday luxury.</p>",
          "label": "Description"
        },
        {
          "type": "select",
          "id": "text_size",
          "options": [
            { "value": "text-body", "label": "Small" },
            { "value": "h3", "label": "Medium" },
            { "value": "h2", "label": "Large" }
          ],
          "default": "text-body",
          "label": "Text Size"
        }
      ]
    },
    {
      "type": "button",
      "name": "Primary Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Learn More",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    },
    {
      "type": "button_pill",
      "name": "Pill Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Explore collection →",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Overlay Banner (Blocks)",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button_pill"
        }
      ]
    }
  ]
}
{% endschema %}