{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .faq-tabs__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .faq-tabs__title {
    margin: 0 0 1rem 0;
    color: rgb(var(--color-foreground));
  }

  /* Elegant serif styling for italicized words */
  .faq-tabs__title em, 
  .faq-tabs__title i {
    font-style: italic;
    font-weight: 600;
  }

  .faq-tabs__description {
    margin: 0;
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.75);
  }

  /* --- Tabs / Categories --- */
  .faq-tabs__list {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-bottom: 1.5rem; /* Space for scrollbar on mobile */
    margin-bottom: 3rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Hide standard scrollbar */
  }

  .faq-tabs__list::-webkit-scrollbar {
    display: none;
  }

  .faq-tabs__tab {
    flex: 0 0 auto;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.2rem 2.5rem 1.2rem 1.2rem;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    border-radius: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
    min-width: 24rem;
    background-color: transparent;
  }

  .faq-tabs__tab[aria-selected="true"] {
    border-color: rgb(var(--color-foreground));
  }
  
  .faq-tabs__tab[aria-selected="true"] .faq-tabs__tab-icon {
    background: rgba(var(--color-foreground), 0.1);
  }

  .faq-tabs__tab-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 5rem;
    height: 5rem;
    background: rgba(var(--color-foreground), 0.05);
    border-radius: 0.6rem;
    transition: background 0.2s ease;
  }

  .faq-tabs__tab-icon img,
  .faq-tabs__tab-icon svg {
    width: 2.8rem;
    height: 2.8rem;
    object-fit: contain;
    fill: currentColor;
    color: rgb(var(--color-foreground));
  }

  .faq-tabs__tab-text-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .faq-tabs__tab-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.2;
    color: rgb(var(--color-foreground));
  }

  .faq-tabs__tab-count {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  /* --- Accordions --- */
  .faq-tabs__content {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .faq-accordion {
    border: 1px solid rgba(var(--color-foreground), 0.15);
    border-radius: 0.8rem;
    overflow: hidden;
    /* Hidden by default, JS reveals matching categories */
    display: none; 
  }

  .faq-accordion.is-active {
    display: block;
  }

  .faq-accordion__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem;
    cursor: pointer;
    font-size: 1.5rem;
    font-weight: 600;
    list-style: none;
    color: rgb(var(--color-foreground));
  }

  .faq-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .faq-accordion__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    background: rgba(var(--color-foreground), 0.08);
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  .faq-accordion__icon svg {
    width: 1.2rem;
    height: 1.2rem;
    color: rgb(var(--color-foreground));
  }

  details[open] .faq-accordion__icon {
    transform: rotate(180deg);
  }

  .faq-accordion__body-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-accordion[open] .faq-accordion__body-wrap {
    grid-template-rows: 1fr;
  }

  .faq-accordion__body-inner {
    overflow: hidden;
  }

  .faq-accordion__body {
    padding: 0 2rem 2rem 2rem;
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
    opacity: 0;
    transform: translateY(-0.6rem);
    transition:
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-accordion[open] .faq-accordion__body {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-accordion__body-wrap {
      transition: none;
    }

    .faq-accordion__body {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .faq-accordion__icon {
      transition: none;
    }
  }

  .faq-accordion__body p:first-child {
    margin-top: 0;
  }
  .faq-accordion__body p:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    
    .faq-tabs__list {
      justify-content: center;
      flex-wrap: wrap;
      overflow-x: visible;
    }
    
    .faq-tabs__tab {
      min-width: auto;
      padding-right: 3rem;
    }
  }
{%- endstyle -%}

<faq-tabs-component class="display-block color-{{ section.settings.color_scheme }} gradient" data-active-accordion-scheme="{{ section.settings.active_accordion_color_scheme }}">
  <div class="page-width section-{{ section.id }}-padding">
    
    <div class="faq-tabs__header">
      {%- if section.settings.title != blank -%}
        <h2 class="faq-tabs__title {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="faq-tabs__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- assign has_categories = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        {%- assign has_categories = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if section.settings.show_tabs and has_categories -%}
      <div class="faq-tabs__list" role="tablist">
        {%- assign first_tab = true -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            {%- assign category_handle = block.settings.title | handleize -%}
            
            {%- comment -%} Dynamically count matching FAQs {%- endcomment -%}
            {%- assign faq_count = 0 -%}
            {%- for faq_block in section.blocks -%}
              {%- if faq_block.type == 'faq' -%}
                {%- assign target_handle = faq_block.settings.category_match | handleize -%}
                {%- if target_handle == category_handle -%}
                  {%- assign faq_count = faq_count | plus: 1 -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            <button class="faq-tabs__tab {% if first_tab %}color-{{ block.settings.color_scheme }} gradient{% endif %}" 
                    role="tab" 
                    aria-selected="{% if first_tab %}true{% else %}false{% endif %}" 
                    aria-controls="panel-{{ category_handle }}" 
                    data-target="{{ category_handle }}"
                    data-color-scheme="{{ block.settings.color_scheme }}"
                    {{ block.shopify_attributes }}>
              
              <div class="faq-tabs__tab-icon">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy' }}
                {%- elsif block.settings.icon != blank and block.settings.icon != 'none' -%}
                  {% render 'icon-accordion', icon: block.settings.icon %}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              
              <div class="faq-tabs__tab-text-wrap">
                <span class="faq-tabs__tab-title">{{ block.settings.title | escape }}</span>
                <span class="faq-tabs__tab-count">{{ faq_count }} {{ section.settings.answers_label | escape }}</span>
              </div>
            </button>
            {%- assign first_tab = false -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="faq-tabs__content">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          {%- assign target_handle = block.settings.category_match | handleize -%}
          
          <details class="faq-accordion" data-category="{{ target_handle }}" {{ block.shopify_attributes }}>
            <summary class="faq-accordion__summary">
              {{ block.settings.question | escape }}
              <span class="faq-accordion__icon">
                <svg viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-accordion__body-wrap">
              <div class="faq-accordion__body-inner">
                <div class="faq-accordion__body">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</faq-tabs-component>

<script>
  if (!customElements.get('faq-tabs-component')) {
    class FaqTabs extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('[role="tab"]');
        this.accordions = this.querySelectorAll('.faq-accordion');
        
        if (this.tabs.length > 0) {
          this.tabs.forEach(tab => {
            tab.addEventListener('click', (e) => this.switchTab(e.currentTarget));
          });

          // Initialize first tab visually
          this.switchTab(this.tabs[0]);
        } else {
          // If there are no tabs, show all accordions
          this.accordions.forEach(accordion => accordion.classList.add('is-active'));
        }

        this.activeAccordionScheme = this.dataset.activeAccordionScheme;

        // Add toggle listener for accordions to apply color scheme only when open
        this.accordions.forEach(accordion => {
          const updateAccordionColor = () => {
            if (!this.activeAccordionScheme) return;
            const schemeClass = `color-${this.activeAccordionScheme}`;
            if (accordion.open) {
              accordion.classList.add(schemeClass, 'gradient');
            } else {
              accordion.classList.remove(schemeClass, 'gradient');
            }
          };

          accordion.addEventListener('toggle', updateAccordionColor);
          // Initial state
          updateAccordionColor();
        });
      }

      switchTab(selectedTab) {
        // Deselect all tabs and remove their color schemes
        this.tabs.forEach(tab => {
          tab.setAttribute('aria-selected', 'false');
          const scheme = tab.dataset.colorScheme;
          if (scheme) {
            tab.classList.remove(`color-${scheme}`, 'gradient');
          }
        });
        
        // Select clicked tab and apply its color scheme
        selectedTab.setAttribute('aria-selected', 'true');
        const activeScheme = selectedTab.dataset.colorScheme;
        if (activeScheme) {
          selectedTab.classList.add(`color-${activeScheme}`, 'gradient');
        }

        const targetCategory = selectedTab.dataset.target;

        // Show/Hide accordions based on target
        this.accordions.forEach(accordion => {
          if (accordion.dataset.category === targetCategory) {
            accordion.classList.add('is-active');
          } else {
            accordion.classList.remove('is-active');
            accordion.removeAttribute('open'); 
          }
        });
      }
    }
    customElements.define('faq-tabs-component', FaqTabs);
  }
</script>

{% schema %}
{
  "name": "FAQ Tabs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Expert <em>answers</em> to common <em>questions</em>",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" },
        { "value": "h0", "label": "Extra Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Browse questions by categories",
      "label": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_tabs",
      "label": "Enable Category Tabs",
      "default": true,
      "info": "Uncheck to hide tabs and show all FAQs. Also automatically hides if there are no Category Tab blocks."
    },
    {
      "type": "text",
      "id": "answers_label",
      "default": "answers",
      "label": "Counter text label",
      "info": "Displays after the number (e.g. '7 answers')"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Overall Section Color Scheme",
      "default": "background-1"
    },
    {
      "type": "color_scheme",
      "id": "active_accordion_color_scheme",
      "label": "Active Accordion Color Scheme",
      "default": "background-2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Sofa related questions",
          "label": "Category Name",
          "info": "This name must exactly match the 'Link to Category' setting in your FAQ blocks."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (Upload SVG/PNG)"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "chat_bubble", "label": "Chat bubble" },
            { "value": "check_mark", "label": "Check mark" },
            { "value": "question_mark", "label": "Question mark" }
          ],
          "default": "check_mark",
          "label": "Fallback Icon"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Tab Color Scheme",
          "default": "background-2"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Accordion",
      "settings": [
        {
          "type": "text",
          "id": "category_match",
          "default": "Sofa related questions",
          "label": "Link to Category",
          "info": "Type the name of the Category Tab this belongs to."
        },
        {
          "type": "text",
          "id": "question",
          "default": "How long does delivery take?",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>We offer fast UK delivery within 7-10 days on most sofas, so you don't have to wait weeks like traditional retailers.</p>",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Tabs",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Sofa related questions"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Bed related questions"
          }
        },
        {
          "type": "faq",
          "settings": {
            "category_match": "Sofa related questions",
            "question": "How long does delivery take?"
          }
        },
        {
          "type": "faq",
          "settings": {
            "category_match": "Sofa related questions",
            "question": "Are your sofas made in the UK?"
          }
        },
        {
          "type": "faq",
          "settings": {
            "category_match": "Bed related questions",
            "question": "What sizes are available?"
          }
        }
      ]
    }
  ]
}
{% endschema %}