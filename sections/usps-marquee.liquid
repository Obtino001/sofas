{%- style -%}
  .marquee-wrapper-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    position: relative;
    display: flex;
    white-space: nowrap;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .marquee-track-{{ section.id }} {
    display: flex;
    width: max-content;
    animation: scrollMarquee {{ section.settings.speed }}s linear infinite;
  }

  .marquee-track-{{ section.id }}:hover {
    animation-play-state: {% if section.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  .marquee-content {
    display: flex;
    align-items: center;
  }

  .marquee-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 {{ section.settings.item_spacing }}px;
    font-size: {{ section.settings.font_size }}px;
    font-weight: 500;
  }

  .marquee-item svg,
  .marquee-item img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
  }

  .marquee-item svg path {
    fill: currentColor;
  }

  @keyframes scrollMarquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .marquee-item {
      font-size: {{ section.settings.font_size_mobile }}px;
      padding: 0 {{ section.settings.item_spacing | divided_by: 2 }}px;
    }
    .marquee-item svg,
    .marquee-item img {
      width: {{ section.settings.icon_size | minus: 4 }}px;
      height: {{ section.settings.icon_size | minus: 4 }}px;
    }
  }
{%- endstyle -%}

<div class="marquee-wrapper-{{ section.id }} color-{{ section.settings.color_scheme }} gradient isolate">
  <div class="marquee-track-{{ section.id }}">
    
    {%- capture marquee_items -%}
      <div class="marquee-content">
        {%- for block in section.blocks -%}
          <div class="marquee-item" {{ block.shopify_attributes }}>
            {%- if block.settings.custom_svg != blank -%}
              {{ block.settings.custom_svg }}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy' }}
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <span>{{ block.settings.text }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endcapture -%}

    {% comment %} Render the content twice to create the seamless infinite scroll loop {% endcomment %}
    {{ marquee_items }}
    {{ marquee_items }}
    
  </div>
</div>

{% schema %}
{
  "name": "Marquee (Scrolling Text)",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Animation Speed",
      "default": 20,
      "info": "Lower is faster."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": false
    },
    {
      "type": "header",
      "content": "Sizing & Spacing"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Icon Size",
      "default": 24
    },
    {
      "type": "range",
      "id": "item_spacing",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Spacing Between Items",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "SVG Icon Code",
          "info": "Paste raw SVG code here for the crispest icons."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Or Image",
          "info": "Used if no SVG is provided."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Premium Quality at Fair Prices"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee",
      "blocks": [
        {
          "type": "marquee_item",
          "settings": {
            "text": "Made in UK"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "Delivered in 7-10 Days"
          }
        },
        {
          "type": "marquee_item",
          "settings": {
            "text": "Premium Quality at Fair Prices"
          }
        }
      ]
    }
  ]
}
{% endschema %}