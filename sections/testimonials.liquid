

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ts-header-flex {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .ts-main-heading {
    margin: 0;
    font-family: var(--font-heading-family);
  }

  .ts-nav-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
  }

  .ts-nav-wrapper .button {
    border-radius: 50px; /* Pill shape for the View All button */
    min-height: 40px;
    padding: 0 20px;
  }

  .ts-swiper-btn {
    position: static;
    width: 40px;
    height: 40px;
    background-color: rgba(var(--color-foreground), 0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.2s ease;
    margin: 0;
  }
  
  .ts-swiper-btn:hover {
    background-color: rgba(var(--color-foreground), 0.15);
  }

  .ts-swiper-btn.swiper-button-disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ts-card {
    border-radius: var(--popup-corner-radius, 16px);
    padding: 25px;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .ts-card-top {
    flex-grow: 1;
  }

  .ts-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 15px;
    color: #007F5F; /* Green tint matching the screenshot */
  }
  
  .ts-stars svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .ts-card-text {
    font-size: 1.4rem;
    line-height: 1.5;
    margin: 0 0 15px 0;
    color: rgba(var(--color-foreground), 1);
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .ts-card-author {
    font-weight: 600;
    font-size: 1.6rem;
    display: block;
    color: rgb(var(--color-foreground));
  }

  .ts-product-ref {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: 15px;
  }

  .ts-product-ref img {
    width: 55px;
    height: 55px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .ts-product-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ts-product-title {
    font-size: 1.4rem;
    font-weight: 500;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .ts-product-link {
    font-size: 1.1rem;
    color: rgba(var(--color-foreground), 0.6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ts-product-link:hover {
    color: rgb(var(--color-foreground));
  }

  .swiper-slide {
    height: auto; /* Ensures equal height cards */
  }

  .ts-swiper-{{ section.id }} {
    overflow: visible !important;
    clip-path: inset(-100vw -100vw -100vw -100vw); /* Ensure shadows are not clipped if overflow visible is restricted */
  }

  @media screen and (max-width: 749px) {
    .ts-nav-wrapper{
      display: none;
    }
    /* Fallback native scrolling in case Swiper JS doesn't fire */
    slider-container:not(.is-initialized) .ts-swiper-{{ section.id }} .swiper-wrapper {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      gap: 16px;
    }
    slider-container:not(.is-initialized) .ts-swiper-{{ section.id }} .swiper-wrapper::-webkit-scrollbar {
      display: none;
    }
    slider-container:not(.is-initialized) .ts-swiper-{{ section.id }} .swiper-slide {
      flex: 0 0 85vw; /* Show 1.1 cards */
      scroll-snap-align: center;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <slider-container class="template-slider-section" data-block-id="{{ section.id }}">
      <div class="ts-header-flex">
        <h2 class="ts-main-heading h1"> {{ section.settings.heading  }} </h2>
        
        <div class="ts-nav-wrapper">
          {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
            <a href="{{ section.settings.btn_link }}" class="button button--secondary">
              {{ section.settings.btn_text }}
            </a>
          {% endif %}
          <div class="ts-swiper-btn js-slider-template-prev">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="ts-swiper-btn js-slider-template-next">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </div>

      <div 
        class="swiper ts-swiper-{{ section.id }}"
        data-swiper-config='{
          "autoplay": {{ section.settings.enable_autoplay | default: false | json }},
          "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 | json }},
          "mobileSlides": {{ section.settings.mobile_slides | default: 1.1 | json }},
          "mobileSpacing": {{ section.settings.mobile_spacing | default: 16 | json }},
          "desktopSlides": {{ section.settings.desktop_slides | default: 4 | json }},
          "tabletSlides": {{ section.settings.tablet_slides | default: 3.2 | json }},
          "desktopSpacing": {{ section.settings.desktop_spacing | default: 24 | json }}
        }'
      >
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="ts-card color-{{ section.settings.card_color_scheme }} gradient">
              
              <div class="ts-card-top">
                <div class="ts-stars">
                <div class="product__review-icons" style="display: flex; align-items: center; gap: 0px;"><img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
<img src="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18" alt="" srcset="//sofasnbeds.co.uk/cdn/shop/files/material-symbols_star-rounded_1.svg?v=1779345252&amp;width=18 18w" width="18" height="18" loading="lazy" class="product__review-icon">
</div>
                </div>
                
                <p class="ts-card-text">{{ block.settings.content }}</p>
                <span class="ts-card-author">— {{ block.settings.author }}</span>
              </div>

              {%- if block.settings.product != blank -%}
                <div class="ts-product-ref">
                  <img src="{{ block.settings.product.featured_image | image_url: width: 110 }}" alt="{{ block.settings.product.title }}" width="55" height="55" loading="lazy">
                  <div class="ts-product-info">
                    <div class="ts-product-title">{{ block.settings.product.title }}</div>
                    <a href="{{ block.settings.product.url }}" class="ts-product-link">View Product</a>
                  </div>
                </div>
              {%- endif -%}

            </div>
          </div>
        {%- endfor -%}
      </div>
      </div>
    </slider-container>
  </div>
</div>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "background-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "background-2"
    },
    {
      "type": "header",
      "content": "Header Area"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Main Heading",
      "default": "<p>What our customers say</p>",
      "info": "The word 'customers' will automatically be italicized based on the code."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Layout Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    { "type": "header", "content": "⚙️ Slider Configuration" },
    { "type": "checkbox", "id": "enable_autoplay", "label": "Enable Autoplay", "default": false },
    { "type": "range", "id": "autoplay_interval", "min": 2, "max": 10, "step": 1, "unit": "s", "label": "Autoplay Interval", "default": 3 },
    { "type": "header", "content": "💻 Desktop Settings" },
    { "type": "range", "id": "desktop_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 4 },
    { "type": "range", "id": "desktop_spacing", "min": 0, "max": 100, "label": "Spacing (px)", "default": 24 },
    { "type": "header", "content": "📱 Tablet Settings" },
    { "type": "range", "id": "tablet_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 3.2 },
    { "type": "header", "content": "📱 Mobile Settings" },
    { "type": "range", "id": "mobile_slides", "min": 1, "max": 6, "step": 0.1, "label": "Slides per view", "default": 1.1 },
    { "type": "range", "id": "mobile_spacing", "min": 0, "max": 50, "label": "Spacing (px)", "default": 16 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Review Text",
          "default": "This is a really solid piece of furniture. The material feels durable and it's well put together. You can tell it's going to last. Would buy from here again."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Scarlet U."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Referenced Product",
          "info": "Select the product to display at the bottom of the card."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}