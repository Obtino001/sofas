

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ts-header-flex {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .ts-main-heading {
    margin: 0;
    font-family: var(--font-heading-family);
  }

  /* Target the em tag to match the specific italicized/serif 'customers' text */
  .ts-main-heading em {
    font-style: italic;
    font-family: serif; 
    font-weight: 500;
  }

  .ts-nav-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ts-nav-wrapper .button {
    border-radius: 50px; /* Pill shape for the View All button */
    min-height: 40px;
    padding: 0 20px;
  }

  .ts-swiper-btn {
    position: static;
    width: 40px;
    height: 40px;
    background-color: rgba(var(--color-foreground), 0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.2s ease;
    margin: 0;
  }
  
  .ts-swiper-btn:hover {
    background-color: rgba(var(--color-foreground), 0.15);
  }

  .ts-swiper-btn::after {
    font-size: 14px !important;
    font-weight: bold;
    color: rgb(var(--color-foreground));
  }

  .ts-card {
    border-radius: var(--popup-corner-radius, 16px);
    padding: 30px;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .ts-card-top {
    flex-grow: 1;
  }

  .ts-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 15px;
    color: #007F5F; /* Green tint matching the screenshot */
  }
  
  .ts-stars svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .ts-card-text {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    line-height: 1.5;
    margin: 0 0 15px 0;
    color: rgba(var(--color-foreground), 0.85);
  }

  .ts-card-author {
    font-weight: 600;
    font-size: 1.4rem;
    display: block;
    color: rgb(var(--color-foreground));
  }

  .ts-product-ref {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: 25px;
    padding-top: 20px;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .ts-product-ref img {
    width: 55px;
    height: 55px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .ts-product-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ts-product-title {
    font-size: 1.3rem;
    font-weight: 500;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .ts-product-link {
    font-size: 1.1rem;
    color: rgba(var(--color-foreground), 0.6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ts-product-link:hover {
    color: rgb(var(--color-foreground));
  }

  .swiper-slide {
    height: auto; /* Ensures equal height cards */
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="ts-header-flex">
      <!-- Use replace to inject the <em> tag around 'customers' -->
      <h2 class="ts-main-heading h1">
        {{ section.settings.heading | replace: 'customers', '<em>customers</em>' }}
      </h2>
      
      <div class="ts-nav-wrapper">
        {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
          <a href="{{ section.settings.btn_link }}" class="button button--secondary">
            {{ section.settings.btn_text }}
          </a>
        {% endif %}
        <div class="swiper-button-prev ts-swiper-btn"></div>
        <div class="swiper-button-next ts-swiper-btn"></div>
      </div>
    </div>

    <div class="swiper ts-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="ts-card color-{{ section.settings.card_color_scheme }} gradient">
              
              <div class="ts-card-top">
                <div class="ts-stars">
                  {%- for i in (1..block.settings.stars) -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {%- endfor -%}
                </div>
                
                <p class="ts-card-text">{{ block.settings.content }}</p>
                <span class="ts-card-author">— {{ block.settings.author }}</span>
              </div>

              {%- if block.settings.product != blank -%}
                <div class="ts-product-ref">
                  <img src="{{ block.settings.product.featured_image | image_url: width: 110 }}" alt="{{ block.settings.product.title }}" width="55" height="55" loading="lazy">
                  <div class="ts-product-info">
                    <h4 class="ts-product-title">{{ block.settings.product.title }}</h4>
                    <a href="{{ block.settings.product.url }}" class="ts-product-link">View Product</a>
                  </div>
                </div>
              {%- endif -%}

            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.ts-swiper-{{ section.id }}', {
      slidesPerView: 1.1,
      spaceBetween: 16,
      navigation: {
        nextEl: '.ts-swiper-{{ section.id }} .swiper-button-next',
        prevEl: '.ts-swiper-{{ section.id }} .swiper-button-prev',
      },
      breakpoints: {
        750: {
          slidesPerView: 2.2,
          spaceBetween: 20
        },
        990: {
          slidesPerView: 3.2,
          spaceBetween: 24
        },
        1200: {
          slidesPerView: 4,
          spaceBetween: 24
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "background-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "background-2"
    },
    {
      "type": "header",
      "content": "Header Area"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "What our customers say",
      "info": "The word 'customers' will automatically be italicized based on the code."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Layout Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Review Text",
          "default": "This is a really solid piece of furniture. The material feels durable and it's well put together. You can tell it's going to last. Would buy from here again."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Scarlet U."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Referenced Product",
          "info": "Select the product to display at the bottom of the card."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}