{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'slider-template.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<style>
  .section-{{ section.id }} {
    --columns-desktop: {{ section.settings.columns_desktop }};
    --columns-mobile: {{ section.settings.columns_mobile }};
    --gap-desktop: {{ section.settings.spacing }}px;
    --gap-mobile: {{ section.settings.spacing | divided_by: 1.5 }}px;
  }

  .section-{{ section.id }} .slider-template-section__swiper {
    overflow: {% if section.settings.overflow %}visible{% else %}hidden{% endif %};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

.collection-tabs-nav {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    justify-content: center;
    position: relative;
    flex-wrap: inherit;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scroll-padding-left: 1.5rem;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 1rem;
    margin-bottom: 30px;
    scrollbar-width: none;
}
  
.collection-tab-btn {
    background: #FFF2F2;
    border: none;
    font-size: 16px;
    font-family: inherit;
    color: #F5F2ED;
    cursor: pointer;
    padding: 12px 25px;
    white-space: nowrap;
    transition: all 0.3s ease;
    opacity: 1;
    border-radius: 50px;
}

  .collection-tab-btn:hover {
    opacity: 1;
    background: #F5F2ED;
    color: white;
  }
  
  .collection-tab-btn.is-active {
    opacity: 1;
    background: #F5F2ED;
    color: white;
  }

  /* --- Tab Panel Styles --- */
  .collection-tab-panel {
    display: none;
    animation: fadeInTab 0.4s ease-in-out;
  }

  .collection-tab-panel.is-active {
    display: block;
  }

  @keyframes fadeInTab {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media screen and (min-width: 800px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (max-width: 800px) {
    .collection-tabs-nav {
    justify-content: start;
    }
  }
</style>

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0

  assign max_columns_to_show = columns_mobile_int
  if columns_desktop_int > columns_mobile_int
    assign max_columns_to_show = columns_desktop_int
  endif

  assign mobile_slide_class = 'swiper-slide--multi'
  assign mobile_swiper_slides = 2
  if section.settings.columns_mobile == '1'
    assign mobile_slide_class = 'swiper-slide--single'
    assign mobile_swiper_slides = 1.2
  endif
-%}

<div class="section-{{ section.id }} color-{{ section.settings.color_scheme }} isolate gradient {% if section.settings.overflow %}slider-template-section__overflow-hidden{% endif %}">
  <div
    class="collection{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %}"
    id="collection-{{ section.id }}"
    data-id="{{ section.id }}"
  >
    <div class="collection__title center title-wrapper title-wrapper--no-top-margin page-width{% if section.settings.enable_slider_mobile %} title-wrapper--self-padded-tablet-down{% endif %}">
      {%- if section.settings.title != blank -%}
        <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      
      {%- if section.settings.description != blank -%}
        <div class="collection__description {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="collection-tabs-nav{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {%- for block in section.blocks -%}
            <button class="collection-tab-btn {% if forloop.first %}is-active{% endif %}" data-target="Panel-{{ block.id }}-{{ section.id }}" {{ block.shopify_attributes }}>
              {{ block.settings.tab_title | default: block.settings.collection.title | default: 'Collection' }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
      
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign products_to_display = collection.all_products_count

          assign more_in_collection = false
          if collection.all_products_count > section.settings.products_to_show
            assign products_to_display = section.settings.products_to_show
            assign more_in_collection = true
          endif
        -%}

        <div class="collection-tab-panel {% if forloop.first %}is-active{% endif %}" id="Panel-{{ block.id }}-{{ section.id }}">
          <slider-container class="slider-template-section block" data-block-id="{{ section.id }}-{{ block.id }}">
            <div class="slider-template-section__container">
              <div
                class="swiper js-slider-template-swiper slider-template-section__swiper"
                data-swiper-config='
                  {
                    "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
                    "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
                    "loop": {{ section.settings.enable_loop | default: false }},
                    "autoplay": {{ section.settings.enable_autoplay | default: false }},
                    "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                    "mobileSlides": {{ mobile_swiper_slides }},
                    "mobileSpacing": {{ section.settings.spacing | divided_by: 1.5 }},
                    "desktopSlides": {{ section.settings.columns_desktop }},
                    "desktopSpacing": {{ section.settings.spacing }}
                  }
                '
              >
                <div class="swiper-wrapper">
                  {% assign skip_card_product_styles = false %}

                  {%- if collection.products.size > 0 -%}
                    {% assign lazy_load = false %}
                    {% paginate collection.products by section.settings.products_to_show %}
                      {%- for product in collection.products limit: section.settings.products_to_show -%}
                        {% if lazy_load == false and forloop.index > max_columns_to_show %}
                          {% assign lazy_load = true %}
                        {% endif %}
                        <div
                          class="swiper-slide {{ mobile_slide_class }}"
                          {% if settings.animations_reveal_on_scroll %}
                            data-cascade
                            style="--animation-order: {{ forloop.index }};"
                          {% endif %}
                        >
                          {% render 'card-product',
                            card_product: product,
                            media_aspect_ratio: section.settings.image_ratio,
                            image_shape: section.settings.image_shape,
                            lazy_load: lazy_load,
                            show_secondary_image: section.settings.show_secondary_image,
                            show_vendor: section.settings.show_vendor,
                            show_rating: section.settings.show_rating,
                            skip_styles: skip_card_product_styles,
                            section_id: section.id,
                            quick_add: section.settings.quick_add
                          %}
                        </div>
                        {%- assign skip_card_product_styles = true -%}
                      {%- endfor -%}
                    {% endpaginate %}
                  {%- else -%}
                    {%- for i in (1..section.settings.columns_desktop) -%}
                      <div
                        class="swiper-slide {{ mobile_slide_class }}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                          style="--animation-order: {{ forloop.index }};"
                        {% endif %}
                      >
                        {% liquid
                          assign ridx = forloop.rindex
                          case ridx
                            when 5
                              assign ridx = 1
                            when 6
                              assign ridx = 2
                          endcase
                        %}
                        {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                        {% render 'card-product',
                          show_vendor: section.settings.show_vendor,
                          media_aspect_ratio: section.settings.image_ratio,
                          image_shape: section.settings.image_shape,
                          lazy_load: false,
                          placeholder_image: placeholder_image
                        %}
                      </div>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>

              <div
                class="
                  slider-template-controls
                  slider-template-controls--{{ section.settings.controls_position }}
                  {% unless section.settings.show_controls_desktop %}slider-template--hide-desktop{% endunless %}
                  {% unless section.settings.show_controls_mobile %}slider-template--hide-mobile{% endunless %}
                "
              >
                {%- if section.settings.controls_position == 'bottom' -%}
                  <div class="slider-template-progress-track">
                    <div class="slider-template-progress-fill"></div>
                  </div>
                {%- endif -%}

                {%- if section.settings.controls_position == 'dots' -%}
                  <div class="slider-template-pagination"></div>
                {%- endif -%}

                {%- if section.settings.controls_position == 'bottom' or section.settings.controls_position == 'middle' -%}
                  <div class="slider-template-controls-nav slider-template--hide-mobile">
                    <button
                      type="button"
                      class="slider-template-arrow js-slider-template-prev"
                      aria-label="{{ 'general.slider.previous_slide' | t }}"
                    >
                      {% render 'svg-icons', svg-icons: 'ma-caret-left' %}
                    </button>
                    <button
                      type="button"
                      class="slider-template-arrow js-slider-template-next"
                      aria-label="{{ 'general.slider.next_slide' | t }}"
                    >
                      {% render 'svg-icons', svg-icons: 'ma-caret-right' %}
                    </button>
                  </div>
                {%- endif -%}
              </div>

              {%- if section.settings.controls_position == 'dots' -%}
                <div
                  class="
                    slider-template-controls
                    slider-template-controls--middle
                    {% unless section.settings.show_controls_desktop %}slider-template--hide-desktop{% endunless %}
                  "
                >
                  <div class="slider-template-controls-nav">
                    <button
                      type="button"
                      class="slider-template-arrow js-slider-template-prev"
                      aria-label="{{ 'general.slider.previous_slide' | t }}"
                    >
                      {% render 'svg-icons', svg-icons: 'ma-caret-left' %}
                    </button>
                    <button
                      type="button"
                      class="slider-template-arrow js-slider-template-next"
                      aria-label="{{ 'general.slider.next_slide' | t }}"
                    >
                      {% render 'svg-icons', svg-icons: 'ma-caret-right' %}
                    </button>
                  </div>
                </div>
              {%- endif -%}
            </div>
          </slider-container>

          {%- if section.settings.show_view_all and more_in_collection -%}
            <div class="center collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              <a
                href="{{ collection.url }}"
                class="{% if section.settings.view_all_style == 'link' %}link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
                aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: collection.title | escape }}"
              >
                {{ 'sections.featured_collection.view_all' | t }}
              </a>
            </div>
          {%- endif -%}
          
        </div>
      {%- else -%}
        <div class="center page-width">
          <p>Please add collection blocks in the theme editor to display tabs.</p>
        </div>
      {%- endfor -%}

    </div>

    {% if section.settings.image_shape == 'arch' %}
      {{ 'mask-arch.svg' | inline_asset_content }}
    {%- endif -%}
  </div>
</div>

<script src="{{ 'slider-template.js' | asset_url }}" defer="defer"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabsSections = document.querySelectorAll('.section-{{ section.id }}');
    
    tabsSections.forEach(section => {
      const tabButtons = section.querySelectorAll('.collection-tab-btn');
      const tabPanels = section.querySelectorAll('.collection-tab-panel');

      tabButtons.forEach(button => {
        button.addEventListener('click', function() {
          // Remove active classes
          tabButtons.forEach(btn => btn.classList.remove('is-active'));
          tabPanels.forEach(panel => panel.classList.remove('is-active'));

          // Add active class to clicked button
          this.classList.add('is-active');

          // Show targeted panel
          const targetId = this.getAttribute('data-target');
          const activePanel = document.getElementById(targetId);
          if (activePanel) {
            activePanel.classList.add('is-active');
            // Force Swiper to recalculate layout when it becomes visible
            window.dispatchEvent(new Event('resize')); 
          }
        });
      });
    });
  });
</script>

{% schema %}
