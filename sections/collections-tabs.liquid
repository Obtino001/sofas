{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'slider-template.css' | asset_url | stylesheet_tag }}

{%- if section.settings.image_shape == 'blob' -%}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0

  assign max_columns_to_show = columns_mobile_int
  if columns_desktop_int > columns_mobile_int
    assign max_columns_to_show = columns_desktop_int
  endif

  assign mobile_slide_class = 'swiper-slide--multi'
  assign mobile_swiper_slides = section.settings.columns_mobile_value | default: 1.2
  if section.settings.columns_mobile == '1'
    assign mobile_slide_class = 'swiper-slide--single'
    assign mobile_swiper_slides = 1.2
  endif

  comment
    Build a delivery date string ("28-29 March") based on section settings.
  endcomment
  assign now_seconds = 'now' | date: '%s' | plus: 0
  assign min_days_seconds = section.settings.delivery_days_min | times: 86400
  assign max_days_seconds = section.settings.delivery_days_max | times: 86400
  assign min_delivery_ts = now_seconds | plus: min_days_seconds
  assign max_delivery_ts = now_seconds | plus: max_days_seconds
  assign min_day = min_delivery_ts | date: '%-d'
  assign max_day = max_delivery_ts | date: '%-d'
  assign min_month = min_delivery_ts | date: '%B'
  assign max_month = max_delivery_ts | date: '%B'
  if min_month == max_month
    assign delivery_range = min_day | append: '-' | append: max_day | append: ' ' | append: max_month
  else
    assign delivery_range = min_day | append: ' ' | append: min_month | append: ' - ' | append: max_day | append: ' ' | append: max_month
  endif
  assign delivery_text = section.settings.delivery_label | default: '' | append: ' ' | append: delivery_range | strip
-%}

<style>
  .section-{{ section.id }} {
    --ct-columns-desktop: {{ section.settings.columns_desktop }};
    --ct-columns-mobile: {{ section.settings.columns_mobile }};
    --ct-gap-desktop: {{ section.settings.spacing }}px;
    --ct-gap-mobile: {{ section.settings.spacing | divided_by: 1.5 }}px;
    --ct-tab-radius: {{ section.settings.tab_radius }}px;
    --ct-card-radius: {{ section.settings.card_radius }}px;
    --ct-image-bg: {{ section.settings.image_background }};
    --ct-tab-bg: {{ section.settings.tab_background }};
    --ct-tab-active-bg: {{ section.settings.tab_active_background }};
    --ct-tab-color: {{ section.settings.tab_color }};
    --ct-tab-active-color: {{ section.settings.tab_active_color }};
    --ct-accent: {{ section.settings.accent_color }};
    --ct-cart-bg: {{ section.settings.cart_btn_background }};
    --ct-cart-color: {{ section.settings.cart_btn_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }} .collection-tabs__swiper {
    overflow: {% if section.settings.overflow %}visible{% else %}hidden{% endif %};
  }
</style>

{{ 'section-collection-tabs.css' | asset_url | stylesheet_tag }}

<div class="section-{{ section.id }} color-{{ section.settings.color_scheme }} isolate gradient collection-tabs">
  <div class="collection-tabs__container page-width section-{{ section.id }}-padding{% if section.settings.full_width %} collection-tabs--full-width{% endif %}" id="CollectionTabs-{{ section.id }}" data-section-id="{{ section.id }}">

    <div class="collection-tabs__heading-row {% if section.settings.heading_alignment == 'left' %}collection-tabs__heading-row--left{% else %}collection-tabs__heading-row--center{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.title != blank -%}
        <h2 class="collection-tabs__title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="collection-tabs__description rte {{ section.settings.description_style }}">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="collection-tabs__controls-row{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <div class="collection-tabs__nav-wrapper">
          <div class="collection-tabs__nav" role="tablist" aria-label="{{ section.settings.title | default: 'Collections' | escape }}">
            {%- for block in section.blocks -%}
              {%- liquid
                assign tab_label = block.settings.tab_title | default: block.settings.collection.title | default: 'Collection'
                assign panel_id = 'CollectionTabPanel-' | append: section.id | append: '-' | append: block.id
                assign tab_id = 'CollectionTabBtn-' | append: section.id | append: '-' | append: block.id
                assign is_first = forloop.first
                assign tab_icon_alt = block.settings.tab_icon.alt | default: tab_label
                assign icon_dim = section.settings.icon_size | times: 2
              -%}
              <button
                type="button"
                class="collection-tabs__tab {% if is_first %}is-active{% endif %}"
                role="tab"
                id="{{ tab_id }}"
                aria-controls="{{ panel_id }}"
                aria-selected="{% if is_first %}true{% else %}false{% endif %}"
                data-target="{{ panel_id }}"
                data-collection-url="{{ block.settings.collection.url | default: '#' }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.tab_icon != blank -%}
                  <span class="collection-tabs__tab-icon" style="--ct-icon-size: {{ section.settings.icon_size }}px;">
                    {{ block.settings.tab_icon | image_url: width: icon_dim | image_tag:
                       loading: 'lazy',
                       width: section.settings.icon_size,
                       height: section.settings.icon_size,
                       alt: tab_icon_alt,
                       class: 'collection-tabs__tab-icon-img'
                    }}
                  </span>
                {%- endif -%}
                <span class="collection-tabs__tab-label">{{ tab_label }}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>

        <div class="collection-tabs__actions">
          {%- if section.settings.show_view_all -%}
            <a
              href="#"
              class="collection-tabs__view-all-btn"
              data-collection-tabs-view-all
              aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: section.settings.title | escape }}"
            >
              <span>{{ section.settings.view_all_text | default: 'View All' }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.show_arrows -%}
            <div class="collection-tabs__arrows" role="group" aria-label="{{ 'general.slider.name' | t }}">
              <button
                type="button"
                class="collection-tabs__arrow collection-tabs__arrow--prev"
                data-collection-tabs-arrow="prev"
                aria-label="{{ 'general.slider.previous_slide' | t }}"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button
                type="button"
                class="collection-tabs__arrow collection-tabs__arrow--next"
                data-collection-tabs-arrow="next"
                aria-label="{{ 'general.slider.next_slide' | t }}"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="collection-tabs__panels {% unless section.settings.full_width %}page-width{% endunless %}">

      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign panel_id = 'CollectionTabPanel-' | append: section.id | append: '-' | append: block.id
          assign tab_id = 'CollectionTabBtn-' | append: section.id | append: '-' | append: block.id
          assign is_first = forloop.first
        -%}
        <div
          class="collection-tabs__panel {% if is_first %}is-active{% endif %}"
          id="{{ panel_id }}"
          role="tabpanel"
          aria-labelledby="{{ tab_id }}"
          data-collection-url="{{ collection.url | default: '#' }}"
          {% unless is_first %}hidden{% endunless %}
        >
          <slider-container class="collection-tabs__slider slider-template-section block" data-block-id="{{ section.id }}-{{ block.id }}">
            <div class="slider-template-section__container">
              <div
                class="swiper js-slider-template-swiper collection-tabs__swiper"
                data-swiper-config='
                  {
                    "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
                    "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
                    "loop": {{ section.settings.enable_loop | default: false }},
                    "autoplay": {{ section.settings.enable_autoplay | default: false }},
                    "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                    "mobileSlides": {{ mobile_swiper_slides }},
                    "mobileSpacing": {{ section.settings.spacing | divided_by: 1.5 }},
                    "desktopSlides": {{ section.settings.columns_desktop }},
                    "desktopSpacing": {{ section.settings.spacing }}
                  }
                '
              >
                <div class="swiper-wrapper">
                  {%- if collection.products.size > 0 -%}
                    {% assign lazy_load = false %}
                    {% paginate collection.products by section.settings.products_to_show %}
                      {%- for product in collection.products limit: section.settings.products_to_show -%}
                        {% if lazy_load == false and forloop.index > max_columns_to_show %}
                          {% assign lazy_load = true %}
                        {% endif %}
                        <div
                          class="swiper-slide {{ mobile_slide_class }}"
                          {% if settings.animations_reveal_on_scroll %}
                            data-cascade
                            style="--animation-order: {{ forloop.index }};"
                          {% endif %}
                        >
                          {% render 'card-product-tabs',
                            card_product: product,
                            section_id: section.id,
                            media_aspect_ratio: section.settings.image_ratio,
                            show_secondary_image: section.settings.show_secondary_image,
                            show_rating: section.settings.show_rating,
                            show_swatches: section.settings.show_swatches,
                            swatch_option: section.settings.swatch_option_name,
                            swatch_limit: section.settings.swatch_limit,
                            show_delivery: section.settings.show_delivery,
                            delivery_text: delivery_text,
                            lazy_load: lazy_load,
                            badge_position: section.settings.badge_position
                          %}
                        </div>
                      {%- endfor -%}
                    {% endpaginate %}
                  {%- else -%}
                    {%- for i in (1..section.settings.columns_desktop) -%}
                      <div
                        class="swiper-slide {{ mobile_slide_class }}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                          style="--animation-order: {{ forloop.index }};"
                        {% endif %}
                      >
                        {% liquid
                          assign ridx = forloop.rindex
                          case ridx
                            when 5
                              assign ridx = 1
                            when 6
                              assign ridx = 2
                          endcase
                        %}
                        {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                        {% render 'card-product-tabs',
                          section_id: section.id,
                          media_aspect_ratio: section.settings.image_ratio,
                          placeholder_image: placeholder_image,
                          show_delivery: section.settings.show_delivery,
                          delivery_text: delivery_text
                        %}
                      </div>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>

              {%- comment %} Hidden per-slider nav buttons - the visible header arrows delegate to these via JS. {% endcomment -%}
              <button type="button" class="collection-tabs__hidden-nav js-slider-template-prev visually-hidden" aria-hidden="true" tabindex="-1">prev</button>
              <button type="button" class="collection-tabs__hidden-nav js-slider-template-next visually-hidden" aria-hidden="true" tabindex="-1">next</button>
            </div>
          </slider-container>
        </div>
      {%- else -%}
        <div class="collection-tabs__empty center">
          <p>{{ 'onboarding.no_content' | t | default: 'Add collection blocks in the theme editor to display tabs.' }}</p>
        </div>
      {%- endfor -%}

    </div>

    {% if section.settings.image_shape == 'arch' %}
      {{ 'mask-arch.svg' | inline_asset_content }}
    {%- endif -%}
  </div>
</div>

<script src="{{ 'collection-tabs.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Collection Tabs",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "The perfect <i>sofa</i> for your <i>space</i>",
      "label": "Heading",
      "info": "Use <i>text</i> to italicise specific words."
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" },
        { "value": "hxxl", "label": "Extra Extra Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "Description style",
      "options": [
        { "value": "body", "label": "Body" },
        { "value": "subtitle", "label": "Subtitle" },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Tab icon size",
      "default": 32
    },
    {
      "type": "range",
      "id": "tab_radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Tab corner radius",
      "default": 50
    },
    {
      "type": "color",
      "id": "tab_background",
      "label": "Tab background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "tab_color",
      "label": "Tab text color",
      "default": "#1F1F1F"
    },
    {
      "type": "color",
      "id": "tab_active_background",
      "label": "Active tab background",
      "default": "#EFE6D8"
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Active tab text color",
      "default": "#1F1F1F"
    },
    {
      "type": "header",
      "content": "View All & Arrows"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button in header",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All button text",
      "default": "View All"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows in header",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / arrow color",
      "default": "#1F1F1F"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 8,
      "label": "Maximum products to show per tab"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Space between cards",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "overflow",
      "label": "Show trailing slide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable slider on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay interval",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable infinite loop",
      "default": false
    },
    {
      "type": "header",
      "content": "Product Card"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card image corner radius",
      "default": 12
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Image background color",
      "default": "#F5F1EB"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "arch", "label": "Arch" },
        { "value": "blob", "label": "Blob" },
        { "value": "round", "label": "Round" }
      ],
      "default": "default",
      "label": "Image shape"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "Show product rating",
      "info": "Requires a product rating app that uses the reviews metafields."
    },
    {
      "type": "select",
      "id": "badge_position",
      "label": "Badge position",
      "options": [
        { "value": "top-right", "label": "Top right" },
        { "value": "top-left", "label": "Top left" }
      ],
      "default": "top-right"
    },
    {
      "type": "header",
      "content": "Cart Icon Button"
    },
    {
      "type": "color",
      "id": "cart_btn_background",
      "label": "Cart icon background",
      "default": "#A37B4C"
    },
    {
      "type": "color",
      "id": "cart_btn_color",
      "label": "Cart icon color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Color Swatches"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "text",
      "id": "swatch_option_name",
      "label": "Product option to use as swatches",
      "default": "Color",
      "info": "Must match a product option name (e.g. Color, Colour, Fabric)."
    },
    {
      "type": "range",
      "id": "swatch_limit",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Maximum swatches to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Delivery Info"
    },
    {
      "type": "checkbox",
      "id": "show_delivery",
      "label": "Show delivery date on cards",
      "default": true
    },
    {
      "type": "text",
      "id": "delivery_label",
      "label": "Delivery label",
      "default": "Order now & get it by"
    },
    {
      "type": "range",
      "id": "delivery_days_min",
      "min": 1,
      "max": 21,
      "step": 1,
      "label": "Earliest delivery in days",
      "default": 5
    },
    {
      "type": "range",
      "id": "delivery_days_max",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Latest delivery in days",
      "default": 7
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Tab",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab title",
          "info": "Leave empty to use the collection's name."
        },
        {
          "type": "image_picker",
          "id": "tab_icon",
          "label": "Tab icon (HD)",
          "info": "Upload a high-resolution icon (SVG/PNG recommended)."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Tabs",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
