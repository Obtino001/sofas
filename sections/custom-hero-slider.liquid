{%- liquid
  assign padding_bottom_desktop = section.settings.desktop_height | append: 'vh'
  assign padding_bottom_mobile = section.settings.mobile_height | append: 'vh'

  if section.settings.adapt_height_first_image and section.blocks.size > 0
    assign first_block = section.blocks.first
    if first_block.settings.image != blank
      assign padding_bottom_desktop = 1 | divided_by: first_block.settings.image.aspect_ratio | times: 100 | append: '%'
    else
      assign padding_bottom_desktop = '40%'
    endif
    
    if first_block.settings.mobile_image != blank
      assign padding_bottom_mobile = 1 | divided_by: first_block.settings.mobile_image.aspect_ratio | times: 100 | append: '%'
    elsif first_block.settings.image != blank
      assign padding_bottom_mobile = 1 | divided_by: first_block.settings.image.aspect_ratio | times: 100 | append: '%'
    else
      assign padding_bottom_mobile = '100%'
    endif
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .custom-hero-slider {
    position: relative;
    overflow: hidden;
  }

  .custom-hero-slider .swiper {
    width: 100%;
    height: 100%;
  }

  .custom-hero-slider__slide {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .custom-hero-slider__slide::before {
    content: '';
    width: 0;
    padding-bottom: {{ padding_bottom_mobile }};
  }

  .custom-hero-slider__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .custom-hero-slider__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-hero-slider__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000000;
    z-index: 2;
  }

  .custom-hero-slider__content-wrapper {
    position: relative;
    z-index: 3;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .custom-hero-slider__box {
    text-align: center;
    max-width: 60rem;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .custom-hero-slider__title {
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .custom-hero-slider__text {
    margin: 0;
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
  }

  .custom-hero-slider__buttons {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 1rem;
  }

  .custom-hero-slider .button--secondary {
      --alpha-button-background: 0;
      border: 1px solid #fff;
  }

  /* Desktop Layout */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .custom-hero-slider__slide::before {
      padding-bottom: {{ padding_bottom_desktop }};
    }

    .custom-hero-slider__box {
      padding: 6rem 0;
    }

    .custom-hero-slider__buttons {
      flex-direction: row;
      width: auto;
      gap: 1.5rem;
    }
  }

  /* Image toggling for Desktop vs Mobile */
  .custom-hero-slider__image--mobile {
    display: block;
  }
  .custom-hero-slider__image--desktop {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .custom-hero-slider__image--mobile {
      display: none;
    }
    .custom-hero-slider__image--desktop {
      display: block;
    }
  }

  /* Slider Controls */
  .custom-hero-slider .swiper-custom-controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .custom-hero-slider .swiper-custom-arrow {
    cursor: pointer;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: #fff;
  }
  .custom-hero-slider .swiper-custom-arrow:hover {
    background: #fff;
    color: #000;
  }
  .custom-hero-slider .swiper-custom-arrow svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
  }
  .custom-hero-slider .swiper-pagination {
    position: relative;
    bottom: 0;
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .custom-hero-slider .swiper-pagination-bullet {
    width: 35px;
    height: 3px;
    background: #ffffff;
    opacity: 0.6;
    border-radius: 2px;
    margin: 0 !important;
    transition: all 0.3s ease;
  }
  .custom-hero-slider .swiper-pagination-bullet-active {
    background: #2B2B2B;
    opacity: 1;
  }

  @media screen and (max-width: 767px) {
    .custom-hero-slider .hide-on-mobile { display: none !important; }
  }
  @media screen and (min-width: 768px) {
    .custom-hero-slider .hide-on-desktop { display: none !important; }
  }
  /* Prevent FOUC before Swiper initializes */
  .custom-hero-slider .swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
  }
  .custom-hero-slider .swiper:not(.swiper-initialized) .swiper-slide {
    width: 100%;
    flex: 0 0 100%;
  }
  @media screen and (min-width: 750px) {
    .custom-hero-slider .swiper:not(.swiper-initialized) .swiper-slide {
      width: 100%;
      flex: 0 0 100%;
    }
  }
{%- endstyle -%}

<slider-container class="custom-hero-slider section-{{ section.id }}-padding" data-block-id="{{ section.id }}">
  <div class="slider-wrapper relative-container">
    <div 
        class="swiper js-swiper-template"
        data-swiper-config='{
            "autoplay": {{ section.settings.enable_autoplay | default: false }},
            "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
            "mobileSlides": 1,
            "mobileSpacing": 0,
            "tabletSlides": 1,
            "desktopSlides": 1,
            "desktopSpacing": 0,
            "loop": true
        }'
    >
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide custom-hero-slider__slide color-{{ block.settings.color_scheme }} gradient" {{ block.shopify_attributes }}>
            
            <div class="custom-hero-slider__media">
              <div class="custom-hero-slider__overlay" style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
              
              {%- if block.settings.image != blank -%}
                {%- liquid
                  assign desktop_class = 'custom-hero-slider__image--desktop'
                  if block.settings.mobile_image == blank
                    assign desktop_class = ''
                  endif
                -%}
                {{ block.settings.image | image_url: width: 3840 | image_tag:
                  loading: 'lazy',
                  class: desktop_class,
                  widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                }}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg custom-hero-slider__image--desktop' }}
              {%- endif -%}

              {%- if block.settings.mobile_image != blank -%}
                {{ block.settings.mobile_image | image_url: width: 1100 | image_tag:
                  loading: 'lazy',
                  class: 'custom-hero-slider__image--mobile',
                  widths: '375, 550, 750, 1100'
                }}
              {%- endif -%}
            </div>

            <div class="page-width custom-hero-slider__content-wrapper" style="justify-content: {{ block.settings.desktop_content_position }};">
              <div class="custom-hero-slider__box" style="text-align: {{ block.settings.desktop_text_alignment }}; align-items: {% if block.settings.desktop_text_alignment == 'left' %}flex-start{% elsif block.settings.desktop_text_alignment == 'right' %}flex-end{% else %}center{% endif %};">
                  {%- if block.settings.heading != blank -%}
                    <h2 class="custom-hero-slider__title {{ block.settings.heading_size }}">
                      {{ block.settings.heading }}
                    </h2>
                  {%- endif -%}
                  
                  {%- if block.settings.text != blank -%}
                    <div class="custom-hero-slider__text">
                      {{ block.settings.text }}
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank -%}
                    <div class="custom-hero-slider__buttons">
                      {%- if block.settings.button_label_1 != blank -%}
                        <a {% if block.settings.button_link_1 == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link_1 }}"{% endif %} 
                           class="button {% if block.settings.button_style_1 == 'secondary' %}button--secondary{% else %}button--primary{% endif %}">
                          {{- block.settings.button_label_1 | escape -}}
                        </a>
                      {%- endif -%}
                      
                      {%- if block.settings.button_label_2 != blank -%}
                        <a {% if block.settings.button_link_2 == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link_2 }}"{% endif %} 
                           class="button {% if block.settings.button_style_2 == 'secondary' %}button--secondary{% else %}button--primary{% endif %}">
                          {{- block.settings.button_label_2 | escape -}}
                        </a>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
              </div>
            </div>

          </div>
        {%- endfor -%}
      </div>
      
      <div class="swiper-custom-controls">
        <div class="swiper-custom-prev swiper-custom-arrow 
          {% unless section.settings.mobile_arrows %}hide-on-mobile{% endunless %} 
          {% unless section.settings.desktop_arrows %}hide-on-desktop{% endunless %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        </div>
        
        <div class="swiper-pagination 
          {% unless section.settings.mobile_dots %}hide-on-mobile{% endunless %} 
          {% unless section.settings.desktop_dots %}hide-on-desktop{% endunless %}"></div>
          
        <div class="swiper-custom-next swiper-custom-arrow 
          {% unless section.settings.mobile_arrows %}hide-on-mobile{% endunless %} 
          {% unless section.settings.desktop_arrows %}hide-on-desktop{% endunless %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
      </div>

    </div>
  </div>
</slider-container>

{% schema %}
{
  "name": "Custom Hero Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "⚙️ Slider Configuration" },
    { "type": "checkbox", "id": "enable_autoplay", "label": "Enable Autoplay", "default": true },
    { "type": "range", "id": "autoplay_interval", "min": 2, "max": 10, "step": 1, "unit": "s", "label": "Autoplay Interval", "default": 5 },
    { "type": "checkbox", "id": "desktop_arrows", "label": "Show Arrows on Desktop", "default": true },
    { "type": "checkbox", "id": "mobile_arrows", "label": "Show Arrows on Mobile", "default": false },
    { "type": "checkbox", "id": "desktop_dots", "label": "Show Dots on Desktop", "default": true },
    { "type": "checkbox", "id": "mobile_dots", "label": "Show Dots on Mobile", "default": true },
    { "type": "checkbox", "id": "adapt_height_first_image", "label": "Adapt section height to first image size", "default": false },
    { "type": "header", "content": "Desktop Layout" },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "vh",
      "label": "Desktop section height",
      "default": 70
    },
    { "type": "header", "content": "Mobile Layout" },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "vh",
      "label": "Mobile section height",
      "default": 60
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (Optional)",
          "info": "Overrides desktop image on smaller screens."
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 10,
          "unit": "%",
          "label": "Image overlay opacity",
          "default": 30
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "scheme-4"
        },
        {
          "type": "select",
          "id": "desktop_content_position",
          "options": [
            { "value": "flex-start", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Right" }
          ],
          "default": "center",
          "label": "Desktop content position"
        },
        {
          "type": "select",
          "id": "desktop_text_alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center",
          "label": "Desktop text alignment"
        },
        {
           "type": "richtext",
           "id": "heading",
           "default": "<p>LESS MAINTENANCE. MORE RIDING.</p>",
           "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h2", "label": "Medium" },
            { "value": "h1", "label": "Large" },
            { "value": "h0", "label": "Extra Large" }
          ],
          "default": "h1",
          "label": "Heading size"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Bring home the comfort you love and choose a payment plan that works for you.</p>",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Explore our products",
          "label": "Primary button label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Primary button link"
        },
        {
          "type": "select",
          "id": "button_style_1",
          "options": [
            { "value": "primary", "label": "Solid" },
            { "value": "secondary", "label": "Outline" }
          ],
          "default": "primary",
          "label": "Primary button style"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Secondary button label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Secondary button link"
        },
        {
          "type": "select",
          "id": "button_style_2",
          "options": [
            { "value": "primary", "label": "Solid" },
            { "value": "secondary", "label": "Outline" }
          ],
          "default": "secondary",
          "label": "Secondary button style"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
