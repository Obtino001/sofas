{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Layout Variables ── */
  .custom-collage__layout {
    --gap: {{ section.settings.gap }}px;
  }

  /* ── Desktop: 4-Column Flex Layout ── */
  @media screen and (min-width: 750px) {
    .custom-collage__layout {
      display: flex;
      gap: var(--gap);
      align-items: flex-start; /* Do not stretch columns */
    }
    
    .custom-collage__col {
      display: flex;
      flex-direction: column;
      gap: var(--gap);
    }

    /* Column Widths */
    .custom-collage__col--1 { width: {{ section.settings.col_1_width }}%; }
    .custom-collage__col--2 { width: {{ section.settings.col_2_width }}%; margin-top: {{ section.settings.images_offset_top }}px; }
    .custom-collage__col--3 { width: {{ section.settings.col_3_width }}%; margin-top: {{ section.settings.images_offset_top }}px; }
    .custom-collage__col--4 { width: {{ section.settings.col_4_width }}%; margin-top: {{ section.settings.images_offset_top }}px; }
  }

  /* ── Mobile: 2-Column Grid ── */
  @media screen and (max-width: 749px) {
    .custom-collage__layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--gap);
    }
    .custom-collage__col {
      display: contents; /* Allows items to flow into the parent grid */
    }
    .custom-collage__text {
      grid-column: 1 / -1;
      order: 1;
    }
    /* Mobile Ordering */
    .item-img-1 { order: 2; }
    .item-img-2 { order: 3; }
    .item-img-3 { order: 4; }
    .item-img-4 { order: 5; }
    .item-img-5 { order: 6; }
    .item-img-6 { order: 7; }
  }

  /* ── Text Block ── */
  .custom-collage__text {
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  @media screen and (min-width: 750px) {
    .custom-collage__text {
      padding-right: 1.5rem;
      margin-bottom: 0;
    }
  }

  /* ── Image Blocks ── */
  .custom-collage__img {
    border-radius: 1rem;
    overflow: hidden;
    position: relative;
    width: 100%;
    /* Aspect ratio is set inline */
  }
  @media screen and (min-width: 750px) {
    .custom-collage__img { border-radius: 1.4rem; }
  }

  .custom-collage__img img, .custom-collage__img svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }
  .custom-collage__img:hover img { transform: scale(1.03); }

  .custom-collage__placeholder {
    background-color: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .custom-collage__placeholder svg {
    width: 40px;
    height: 40px;
    fill: rgba(var(--color-foreground), 0.15);
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="custom-collage__layout">

      {%- comment -%} ── Column 1: Text + White Sofa ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--1">
        {%- if section.settings.text != blank -%}
          <div class="custom-collage__text">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
        
        <div class="custom-collage__img item-img-1" style="aspect-ratio: {{ section.settings.img_1_aspect }};">
          {%- if section.settings.image_1 != blank -%}
            {{ section.settings.image_1 | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Column 2: Tall White Bed ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--2">
        <div class="custom-collage__img item-img-2" style="aspect-ratio: {{ section.settings.img_2_aspect }};">
          {%- if section.settings.image_2 != blank -%}
            {{ section.settings.image_2 | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Column 3: Grey Pillows + Brown Sofa ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--3">
        <div class="custom-collage__img item-img-3" style="aspect-ratio: {{ section.settings.img_3_aspect }};">
          {%- if section.settings.image_3 != blank -%}
            {{ section.settings.image_3 | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <div class="custom-collage__img item-img-4" style="aspect-ratio: {{ section.settings.img_4_aspect }};">
          {%- if section.settings.image_4 != blank -%}
            {{ section.settings.image_4 | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Column 4: Grey Bed + Black Sofa ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--4">
        <div class="custom-collage__img item-img-5" style="aspect-ratio: {{ section.settings.img_5_aspect }};">
          {%- if section.settings.image_5 != blank -%}
            {{ section.settings.image_5 | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <div class="custom-collage__img item-img-6" style="aspect-ratio: {{ section.settings.img_6_aspect }};">
          {%- if section.settings.image_6 != blank -%}
            {{ section.settings.image_6 | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Image Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Text Block (Column 1 Top)"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description Text",
      "default": "<p>At Sofas n Beds, we believe great furniture should be accessible, reliable, and built to last.</p>"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (Col 1 Bottom - White Sofa)"
    },
    {
      "type": "text",
      "id": "img_1_aspect",
      "label": "Image 1 Aspect Ratio",
      "default": "1.1 / 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (Col 2 - Tall White Bed)"
    },
    {
      "type": "text",
      "id": "img_2_aspect",
      "label": "Image 2 Aspect Ratio",
      "default": "0.75 / 1"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (Col 3 Top - Grey Pillows)"
    },
    {
      "type": "text",
      "id": "img_3_aspect",
      "label": "Image 3 Aspect Ratio",
      "default": "1 / 1.1"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4 (Col 3 Bottom - Brown Sofa)"
    },
    {
      "type": "text",
      "id": "img_4_aspect",
      "label": "Image 4 Aspect Ratio",
      "default": "1.3 / 1"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5 (Col 4 Top - Grey Bed)"
    },
    {
      "type": "text",
      "id": "img_5_aspect",
      "label": "Image 5 Aspect Ratio",
      "default": "1.4 / 1"
    },
    {
      "type": "image_picker",
      "id": "image_6",
      "label": "Image 6 (Col 4 Bottom - Black Sofa)"
    },
    {
      "type": "text",
      "id": "img_6_aspect",
      "label": "Image 6 Aspect Ratio",
      "default": "1 / 1"
    },
    {
      "type": "header",
      "content": "Desktop Layout Fine-Tuning"
    },
    {
      "type": "range",
      "id": "col_1_width",
      "min": 10, "max": 50, "step": 1, "unit": "%",
      "label": "Column 1 Width",
      "default": 30
    },
    {
      "type": "range",
      "id": "col_2_width",
      "min": 10, "max": 50, "step": 1, "unit": "%",
      "label": "Column 2 Width",
      "default": 20
    },
    {
      "type": "range",
      "id": "col_3_width",
      "min": 10, "max": 50, "step": 1, "unit": "%",
      "label": "Column 3 Width",
      "default": 24
    },
    {
      "type": "range",
      "id": "col_4_width",
      "min": 10, "max": 50, "step": 1, "unit": "%",
      "label": "Column 4 Width",
      "default": 26
    },
    {
      "type": "range",
      "id": "images_offset_top",
      "min": 0, "max": 150, "step": 2, "unit": "px",
      "label": "Images Offset Top",
      "info": "Pushes Col 2, 3, 4 down so the text block stays higher.",
      "default": 64
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4, "max": 30, "step": 2, "unit": "px",
      "label": "Gap Between Items",
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Custom Image Grid",
      "settings": {}
    }
  ]
}
{% endschema %}