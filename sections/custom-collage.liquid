{%- liquid
  assign text_block = section.blocks | where: 'type', 'text' | first
  assign image_1 = section.blocks | where: 'type', 'image_1' | first
  assign image_2 = section.blocks | where: 'type', 'image_2' | first
  assign image_3 = section.blocks | where: 'type', 'image_3' | first
  assign image_4 = section.blocks | where: 'type', 'image_4' | first
  assign image_5 = section.blocks | where: 'type', 'image_5' | first
  assign image_6 = section.blocks | where: 'type', 'image_6' | first
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-collage-{{ section.id }} {
    --collage-gap: {{ section.settings.gap }}px;
    --collage-radius: {{ section.settings.image_radius }}px;
    --collage-offset: {{ section.settings.images_offset_top }}px;
  }

  .custom-collage-{{ section.id }} .custom-collage__layout {
    display: grid;
    gap: var(--collage-gap);
  }

  .custom-collage-{{ section.id }} .custom-collage__text {
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    line-height: 1.6;
    margin: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__text p {
    margin: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__img {
    border-radius: var(--collage-radius);
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .custom-collage-{{ section.id }} .custom-collage__img img,
  .custom-collage-{{ section.id }} .custom-collage__img svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .custom-collage-{{ section.id }} .custom-collage__placeholder {
    background-color: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .custom-collage-{{ section.id }} .custom-collage__placeholder svg {
    width: 40px;
    height: 40px;
    fill: rgba(var(--color-foreground), 0.15);
  }

  .custom-collage-{{ section.id }} .custom-collage__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  /* Mobile / tablet: 4-column staggered grid */
  @media screen and (max-width: 989px) {
    .custom-collage-{{ section.id }} .custom-collage__layout {
      grid-template-columns: {{ section.settings.col_1_width }}% {{ section.settings.col_2_width }}% {{ section.settings.col_3_width }}% {{ section.settings.col_4_width }}%;
      grid-template-rows: auto auto auto auto;
      align-items: start;
    }

    .custom-collage-{{ section.id }} .custom-collage__text {
      grid-column: 1;
      grid-row: 1;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--1 {
      grid-column: 1;
      grid-row: 2 / span 2;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--2 {
      grid-column: 2;
      grid-row: 1 / span 2;
      margin-top: var(--collage-offset);
    }

    .custom-collage-{{ section.id }} .custom-collage__img--3 {
      grid-column: 3;
      grid-row: 1 / span 2;
      margin-top: var(--collage-offset);
    }

    .custom-collage-{{ section.id }} .custom-collage__img--4 {
      grid-column: 2;
      grid-row: 3;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--5 {
      grid-column: 4;
      grid-row: 2 / span 2;
      margin-top: calc(var(--collage-offset) + var(--collage-gap));
    }

    .custom-collage-{{ section.id }} .custom-collage__img--6 {
      grid-column: 3;
      grid-row: 3;
    }
  }

  /* Desktop: centered text + 2-column collage */
  @media screen and (min-width: 990px) {
    .custom-collage-{{ section.id }} .custom-collage__layout {
      grid-template-columns: 1fr 1fr 1fr 1fr;
      grid-template-rows: auto auto auto auto;
    }

    .custom-collage-{{ section.id }} .custom-collage__text {
      grid-column: 1 / -1;
      grid-row: 1;
      text-align: center;
      max-width: {{ section.settings.text_max_width }}rem;
      justify-self: center;
      width: 100%;
      margin-bottom: calc(var(--collage-gap) * 0.5);
    }

    .custom-collage-{{ section.id }} .custom-collage__img--1 {
      grid-column: 1 / 3;
      grid-row: 2 / 4;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--2 {
      grid-column: 3;
      grid-row: 2;
      margin-top: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--3 {
      grid-column: 4;
      grid-row: 2;
      margin-top: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--4 {
      grid-column: 1 / 3;
      grid-row: 4;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--5 {
      grid-column: 3 / 5;
      grid-row: 3;
      margin-top: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__img--6 {
      grid-column: 3 / 5;
      grid-row: 4;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="custom-collage-{{ section.id }}">
      <div class="custom-collage__layout">

        {%- if text_block != blank and text_block.settings.text != blank -%}
          <div
            class="custom-collage__text{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ text_block.shopify_attributes }}
          >
            {{ text_block.settings.text }}
          </div>
        {%- endif -%}

        {%- assign image_blocks = 'image_1,image_2,image_3,image_4,image_5,image_6' | split: ',' -%}
        {%- for block_type in image_blocks -%}
          {%- assign block_index = forloop.index -%}
          {%- assign current_block = nil -%}
          {%- case block_type -%}
            {%- when 'image_1' -%}{%- assign current_block = image_1 -%}
            {%- when 'image_2' -%}{%- assign current_block = image_2 -%}
            {%- when 'image_3' -%}{%- assign current_block = image_3 -%}
            {%- when 'image_4' -%}{%- assign current_block = image_4 -%}
            {%- when 'image_5' -%}{%- assign current_block = image_5 -%}
            {%- when 'image_6' -%}{%- assign current_block = image_6 -%}
          {%- endcase -%}

          {%- assign aspect_setting = 'img_' | append: block_index | append: '_aspect' -%}
          {%- assign aspect_ratio = section.settings[aspect_setting] -%}

          <div
            class="custom-collage__img custom-collage__img--{{ block_index }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            style="aspect-ratio: {{ aspect_ratio }};{% if settings.animations_reveal_on_scroll %} --animation-order: {{ block_index }};{% endif %}"
            {% if current_block %}{{ current_block.shopify_attributes }}{% endif %}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- if current_block and current_block.settings.image != blank -%}
              {%- if current_block.settings.link != blank -%}
                <a href="{{ current_block.settings.link }}" class="custom-collage__link">
              {%- endif -%}
              {{
                current_block.settings.image
                | image_url: width: 1600
                | image_tag: loading: 'lazy', widths: '375, 550, 750, 900, 1100, 1300, 1500, 1600'
              }}
              {%- if current_block.settings.link != blank -%}
                </a>
              {%- endif -%}
            {%- else -%}
              <div class="custom-collage__placeholder">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Collage",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Gap between items",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_radius",
