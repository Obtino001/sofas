{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-collage__flex {
    display: flex;
    flex-wrap: wrap;
    margin: -0.6rem; /* Negative margin for gap compensation */
  }
  
  @media screen and (min-width: 750px) {
    .custom-collage__flex {
      margin: -0.8rem;
    }
  }

  .custom-collage__item-wrapper {
    box-sizing: border-box;
    padding: 0.6rem;
    width: var(--m-width);
  }

  @media screen and (min-width: 750px) {
    .custom-collage__item-wrapper {
      padding: 0.8rem;
      width: var(--d-width);
    }
  }

  .custom-collage__item {
    border-radius: 1.2rem;
    overflow: hidden;
    position: relative;
    height: var(--m-height);
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .custom-collage__item {
      border-radius: 1.6rem;
      height: var(--d-height);
    }
  }

  /* Specifically for Text Block */
  .custom-collage__text-block {
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    line-height: 1.6;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .custom-collage__text-block {
      font-size: 1.6rem;
      padding-right: 2rem;
    }
  }

  .custom-collage__text-block p {
    margin: 0;
  }

  .custom-collage__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .custom-collage__item:hover .custom-collage__image {
    transform: scale(1.03);
  }

  .custom-collage__placeholder {
    width: 100%;
    height: 100%;
    background-color: rgba(var(--color-foreground), 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-collage__placeholder svg {
    width: 40px;
    height: 40px;
    fill: rgba(var(--color-foreground), 0.2);
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    
    <div class="custom-collage__flex">
      
      {%- if section.settings.text != blank -%}
        <div class="custom-collage__item-wrapper" style="--d-width: {{ section.settings.text_desktop_width }}%; --m-width: {{ section.settings.text_mobile_width }}%;">
          <div class="custom-collage__item custom-collage__item--text" style="--d-height: {{ section.settings.text_desktop_height }}px; --m-height: {{ section.settings.text_mobile_height }}px;">
            <div class="custom-collage__text-block">
              {{ section.settings.text }}
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        <div class="custom-collage__item-wrapper" style="--d-width: {{ block.settings.desktop_width }}%; --m-width: {{ block.settings.mobile_width }}%;" {{ block.shopify_attributes }}>
          <div class="custom-collage__item" style="--d-height: {{ block.settings.desktop_height }}px; --m-height: {{ block.settings.mobile_height }}px;">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: 
                loading: 'lazy', 
                class: 'custom-collage__image', 
                sizes: '(min-width: 750px) 50vw, 100vw' 
              }}
            {%- else -%}
              <div class="custom-collage__placeholder">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Image Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Text Block Settings"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description Text",
      "default": "<p>At Sofas n Beds, we believe great furniture should be accessible, reliable, and built to last. We create high-quality sofas and beds designed for real homes—combining comfort, durability, and value without the long wait times of traditional retailers.</p>"
    },
    {
      "type": "range",
      "id": "text_desktop_width",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Text Desktop Width",
      "default": 33
    },
    {
      "type": "range",
      "id": "text_desktop_height",
      "min": 50,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Text Desktop Height",
      "default": 250
    },
    {
      "type": "range",
      "id": "text_mobile_width",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Text Mobile Width",
      "default": 100
    },
    {
      "type": "range",
      "id": "text_mobile_height",
      "min": 50,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Text Mobile Height",
      "default": 150
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Grid Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Desktop Sizing"
        },
        {
          "type": "range",
          "id": "desktop_width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Width (%)",
          "default": 33
        },
        {
          "type": "range",
          "id": "desktop_height",
          "min": 100,
          "max": 800,
          "step": 10,
          "unit": "px",
          "label": "Height (px)",
          "default": 300
        },
        {
          "type": "header",
          "content": "Mobile Sizing"
        },
        {
          "type": "range",
          "id": "mobile_width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Width (%)",
          "default": 50
        },
        {
          "type": "range",
          "id": "mobile_height",
          "min": 100,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Height (px)",
          "default": 200
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Image Grid",
      "settings": {
        "text_desktop_width": 33,
        "text_desktop_height": 250,
        "text_mobile_width": 100,
        "text_mobile_height": 150
      },
      "blocks": [
        {
          "type": "image",
          "settings": {
            "desktop_width": 33,
            "desktop_height": 500,
            "mobile_width": 100,
            "mobile_height": 300
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_width": 17,
            "desktop_height": 240,
            "mobile_width": 50,
            "mobile_height": 150
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_width": 17,
            "desktop_height": 240,
            "mobile_width": 50,
            "mobile_height": 150
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_width": 34,
            "desktop_height": 250,
            "mobile_width": 100,
            "mobile_height": 200
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_width": 34,
            "desktop_height": 250,
            "mobile_width": 100,
            "mobile_height": 200
          }
        },
        {
          "type": "image",
          "settings": {
            "desktop_width": 17,
            "desktop_height": 250,
            "mobile_width": 50,
            "mobile_height": 150
          }
        }
      ]
    }
  ]
}
{% endschema %}