{%- liquid
  assign text_block = section.blocks | where: 'type', 'text' | first
  assign image_1 = section.blocks | where: 'type', 'image_1' | first
  assign image_2 = section.blocks | where: 'type', 'image_2' | first
  assign image_3 = section.blocks | where: 'type', 'image_3' | first
  assign image_4 = section.blocks | where: 'type', 'image_4' | first
  assign image_5 = section.blocks | where: 'type', 'image_5' | first
  assign image_6 = section.blocks | where: 'type', 'image_6' | first
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-collage-{{ section.id }} {
    --collage-gap: {{ section.settings.gap }}px;
    --collage-radius: {{ section.settings.image_radius }}px;
    --collage-offset: {{ section.settings.images_offset_top }}px;
  }

  .custom-collage-{{ section.id }} .custom-collage__text {
    color: rgb(var(--color-foreground));
    font-size: 2.4rem;
    line-height: 1.6;
    margin: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__text p {
    margin: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__text p + p {
    margin-top: 1em;
  }

  .custom-collage-{{ section.id }} .custom-collage__img {
    border-radius: var(--collage-radius);
    overflow: hidden;
    position: relative;
    width: 100%;
    flex-shrink: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__img img,
  .custom-collage-{{ section.id }} .custom-collage__img svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .custom-collage-{{ section.id }} .custom-collage__placeholder {
    background-color: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .custom-collage-{{ section.id }} .custom-collage__placeholder svg {
    width: 40px;
    height: 40px;
    fill: rgba(var(--color-foreground), 0.15);
  }

  .custom-collage-{{ section.id }} .custom-collage__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .custom-collage-{{ section.id }} .custom-collage__text--mobile {
    display: none;
  }

  .custom-collage-{{ section.id }} .custom-collage__layout--mobile {
    display: none;
  }

  /* Mobile: centered text + 2-column Figma collage */
  @media screen and (max-width: 749px) {
    .custom-collage-{{ section.id }} .custom-collage__layout--desktop {
      display: none;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile {
      display: flex;
      flex-direction: column;
      gap: var(--collage-gap);
    }

      .custom-collage-{{ section.id }} .custom-collage__text {
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
    line-height: 1.6;
    margin: 0;
  }

    .custom-collage-{{ section.id }} .custom-collage__text--mobile {
      display: block;
      text-align: center;
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-grid {
      display: flex;
      gap: var(--collage-gap);
      align-items: stretch;
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-left,
    .custom-collage-{{ section.id }} .custom-collage__mobile-right {
      display: flex;
      flex-direction: column;
      gap: var(--collage-gap);
      flex: 1;
      min-width: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-pair {
      display: flex;
      gap: var(--collage-gap);
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-pair .custom-collage__img {
      flex: 1;
      min-width: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile .custom-collage__img--1 {
      aspect-ratio: {{ section.settings.img_1_aspect_mobile }};
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile .custom-collage__img--2 {
      aspect-ratio: {{ section.settings.img_2_aspect_mobile }};
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile .custom-collage__img--3 {
      aspect-ratio: {{ section.settings.img_3_aspect_mobile }};
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile .custom-collage__img--4 {
      aspect-ratio: {{ section.settings.img_4_aspect_mobile }};
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile .custom-collage__img--5 {
      aspect-ratio: {{ section.settings.img_5_aspect_mobile }};
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile .custom-collage__img--6 {
      aspect-ratio: {{ section.settings.img_6_aspect_mobile }};
    }
  }

  @media screen and (min-width: 750px) {
    .custom-collage-{{ section.id }} .custom-collage__layout--mobile,
    .custom-collage-{{ section.id }} .custom-collage__text--mobile {
      display: none;
    }
  }

  /* Tablet / desktop: 4-column Figma flex layout */
  @media screen and (min-width: 750px) {
    .custom-collage-{{ section.id }} .custom-collage__layout--desktop {
      display: flex;
      gap: var(--collage-gap);
      align-items: stretch;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col {
      display: flex;
      flex-direction: column;
      gap: var(--collage-gap);
      min-width: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--1 {
      flex: {{ section.settings.col_1_width }} 1 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--2 {
      flex: {{ section.settings.col_2_width }} 1 0;
      margin-top: var(--collage-offset);
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--3 {
      flex: {{ section.settings.col_3_width }} 1 0;
      margin-top: calc(var(--collage-offset) * 1.65);
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--4 {
      flex: {{ section.settings.col_4_width }} 1 0;
      margin-top: calc(var(--collage-offset) * 2.35);
      justify-content: center;
    }
  }
{%- endstyle -%}

<div class="{% if section.settings.color_scheme != blank %}color-{{ section.settings.color_scheme }} {% endif %}gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="custom-collage-{{ section.id }}">

      {%- comment -%} Mobile layout {%- endcomment -%}
      <div class="custom-collage__layout custom-collage__layout--mobile">
        {%- if text_block != blank and text_block.settings.text != blank -%}
          <div
            class="custom-collage__text custom-collage__text--mobile"
            {{ text_block.shopify_attributes }}
          >
            {{ text_block.settings.text }}
          </div>
        {%- endif -%}

        <div class="custom-collage__mobile-grid">
          <div class="custom-collage__mobile-left">
            {%- render 'custom-collage-image',
              block: image_1,
              index: 1,
              aspect_ratio: section.settings.img_1_aspect_mobile,
              include_attributes: false
            -%}
            {%- render 'custom-collage-image',
              block: image_3,
              index: 3,
              aspect_ratio: section.settings.img_3_aspect_mobile,
              include_attributes: false
            -%}
          </div>

          <div class="custom-collage__mobile-right">
            <div class="custom-collage__mobile-pair">
              {%- render 'custom-collage-image',
                block: image_2,
                index: 2,
                aspect_ratio: section.settings.img_2_aspect_mobile,
                include_attributes: false
              -%}
              {%- render 'custom-collage-image',
                block: image_4,
                index: 4,
                aspect_ratio: section.settings.img_4_aspect_mobile,
                include_attributes: false
              -%}
            </div>
            {%- render 'custom-collage-image',
              block: image_6,
              index: 6,
              aspect_ratio: section.settings.img_6_aspect_mobile,
              include_attributes: false
            -%}
            {%- render 'custom-collage-image',
              block: image_5,
              index: 5,
              aspect_ratio: section.settings.img_5_aspect_mobile,
              include_attributes: false
            -%}
          </div>
        </div>
      </div>

      {%- comment -%} Desktop layout {%- endcomment -%}
      <div class="custom-collage__layout custom-collage__layout--desktop">

        <div class="custom-collage__col custom-collage__col--1">
          {%- if text_block != blank and text_block.settings.text != blank -%}
            <div class="custom-collage__text custom-collage__text--inline">
              {{ text_block.settings.text }}
            </div>
          {%- endif -%}
          {%- render 'custom-collage-image',
            block: image_1,
            index: 1,
            aspect_ratio: section.settings.img_1_aspect
          -%}
        </div>

        <div class="custom-collage__col custom-collage__col--2">
          {%- render 'custom-collage-image',
            block: image_2,
            index: 2,
            aspect_ratio: section.settings.img_2_aspect
          -%}
          {%- render 'custom-collage-image',
            block: image_3,
            index: 3,
            aspect_ratio: section.settings.img_3_aspect
          -%}
        </div>

        <div class="custom-collage__col custom-collage__col--3">
          {%- render 'custom-collage-image',
            block: image_4,
            index: 4,
            aspect_ratio: section.settings.img_4_aspect
          -%}
          {%- render 'custom-collage-image',
            block: image_5,
            index: 5,
            aspect_ratio: section.settings.img_5_aspect
          -%}
        </div>

        <div class="custom-collage__col custom-collage__col--4">
          {%- render 'custom-collage-image',
            block: image_6,
            index: 6,
            aspect_ratio: section.settings.img_6_aspect
          -%}
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Image Grid (Figma)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Gap between items",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Column widths"
    },
    {
      "type": "range",
      "id": "col_1_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 1 — Text & white sofa",
      "default": 30
    },
    {
      "type": "range",
      "id": "col_2_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 2 — Bed & image 3",
      "default": 20
    },
    {
      "type": "range",
      "id": "col_3_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 3 — Image 4 & image 5",
      "default": 24
    },
    {
      "type": "range",
      "id": "col_4_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 4 — Image 6",
      "default": 26
    },
    {
      "type": "range",
      "id": "images_offset_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Image column offset",
      "info": "Staggers columns 2–4 down from the text block.",
      "default": 64
    },
    {
      "type": "header",
      "content": "Image aspect ratios"
    },
    {
      "type": "text",
      "id": "img_1_aspect",
      "label": "Image 1 — White sofa",
      "default": "1.1 / 1"
    },
    {
      "type": "text",
      "id": "img_2_aspect",
      "label": "Image 2 — Bed",
      "default": "0.75 / 1"
    },
    {
      "type": "text",
      "id": "img_3_aspect",
      "label": "Image 3 — Brown sofa",
      "default": "1.3 / 1"
    },
    {
      "type": "text",
      "id": "img_4_aspect",
      "label": "Image 4 — Grey sofa detail",
      "default": "1 / 1.1"
    },
    {
      "type": "text",
      "id": "img_5_aspect",
      "label": "Image 5 — Dark sofa",
      "default": "1 / 1"
    },
    {
      "type": "text",
      "id": "img_6_aspect",
      "label": "Image 6 — Grey bed",
      "default": "1.4 / 1"
    },
    {
      "type": "header",
      "content": "Mobile aspect ratios"
    },
    {
      "type": "text",
      "id": "img_1_aspect_mobile",
      "label": "Image 1 — White sofa",
      "default": "0.85 / 1"
    },
    {
      "type": "text",
