{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Desktop: 4-column flex layout ── */
  .custom-collage__layout {
    --col-a: {{ section.settings.col_a_width }}%;
    --col-b: {{ section.settings.col_b_width }}%;
    --gap: {{ section.settings.gap }}px;
    --section-h: {{ section.settings.section_height }}px;
    --mobile-img-h: {{ section.settings.mobile_image_height }}px;
  }

  @media screen and (min-width: 750px) {
    .custom-collage__layout {
      display: flex;
      gap: var(--gap);
      min-height: var(--section-h);
      align-items: stretch;
    }
  }

  /* ── Columns (Desktop) ── */
  .custom-collage__col {
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }

  @media screen and (min-width: 750px) {
    .custom-collage__col--a { flex: 0 0 var(--col-a); }
    .custom-collage__col--b { flex: 0 0 var(--col-b); }
    .custom-collage__col--c { flex: 1; }
    .custom-collage__col--d { flex: 1; }
  }

  /* ── Mobile: 2-col grid, columns become invisible ── */
  @media screen and (max-width: 749px) {
    .custom-collage__layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--gap);
    }
    .custom-collage__col {
      display: contents;
    }
    .custom-collage__text {
      grid-column: 1 / -1;
    }
    /* Reorder items on mobile for best visual flow */
    .custom-collage__text       { order: 1; }
    .custom-collage__mob-2      { order: 2; }
    .custom-collage__mob-3      { order: 3; }
    .custom-collage__mob-4      { order: 4; }
    .custom-collage__mob-5      { order: 5; }
    .custom-collage__mob-6      { order: 6; }
    .custom-collage__mob-7      { order: 7; }
  }

  /* ── Text Block ── */
  .custom-collage__text {
    flex: 1;
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    line-height: 1.7;
    display: flex;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .custom-collage__text {
      font-size: 1.5rem;
      padding-right: 1rem;
    }
  }
  .custom-collage__text p { margin: 0; }

  /* ── Image Blocks ── */
  .custom-collage__img {
    flex: 1;
    border-radius: 1rem;
    overflow: hidden;
    position: relative;
  }
  @media screen and (min-width: 750px) {
    .custom-collage__img { border-radius: 1.4rem; }
  }
  @media screen and (max-width: 749px) {
    .custom-collage__img { min-height: var(--mobile-img-h); }
  }

  .custom-collage__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .custom-collage__img:hover img { transform: scale(1.03); }

  /* ── Placeholder ── */
  .custom-collage__placeholder {
    width: 100%;
    height: 100%;
    min-height: 150px;
    background-color: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .custom-collage__placeholder svg {
    width: 40px;
    height: 40px;
    fill: rgba(var(--color-foreground), 0.15);
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="custom-collage__layout">

      {%- comment -%} ── Column A: Text + Small Bottom Image ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--a">
        {%- if section.settings.text != blank -%}
          <div class="custom-collage__text">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
        <div class="custom-collage__img mob-5">
          {%- if section.settings.image_under_text != blank -%}
            {{ section.settings.image_under_text | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Column B: Tall Feature Image (full height) ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--b">
        <div class="custom-collage__img custom-collage__mob-2">
          {%- if section.settings.image_tall != blank -%}
            {{ section.settings.image_tall | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 15vw, 50vw' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Column C: Top Image + Bottom Image ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--c">
        <div class="custom-collage__img custom-collage__mob-3">
          {%- if section.settings.image_top_left != blank -%}
            {{ section.settings.image_top_left | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <div class="custom-collage__img custom-collage__mob-6">
          {%- if section.settings.image_bottom_left != blank -%}
            {{ section.settings.image_bottom_left | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── Column D: Top Image + Bottom Image ── {%- endcomment -%}
      <div class="custom-collage__col custom-collage__col--d">
        <div class="custom-collage__img custom-collage__mob-4">
          {%- if section.settings.image_top_right != blank -%}
            {{ section.settings.image_top_right | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <div class="custom-collage__img custom-collage__mob-7">
          {%- if section.settings.image_bottom_right != blank -%}
            {{ section.settings.image_bottom_right | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 50vw' }}
          {%- else -%}
            <div class="custom-collage__placeholder">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Image Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },

    {
      "type": "header",
      "content": "Text Block"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description Text",
      "default": "<p>At Sofas n Beds, we believe great furniture should be accessible, reliable, and built to last. We create high-quality sofas and beds designed for real homes—combining comfort, durability, and value without the long wait times of traditional retailers.</p>"
    },

    {
      "type": "header",
      "content": "Column A — Text & Image Below",
      "info": "Left column: shows text on top, one image below it."
    },
    {
      "type": "image_picker",
      "id": "image_under_text",
      "label": "Image Under Text"
    },

    {
      "type": "header",
      "content": "Column B — Tall Feature Image",
      "info": "Single tall image spanning the full section height."
    },
    {
      "type": "image_picker",
      "id": "image_tall",
      "label": "Tall Feature Image"
    },

    {
      "type": "header",
      "content": "Column C — Two Stacked Images",
      "info": "Left-center column: top image and bottom image."
    },
    {
      "type": "image_picker",
      "id": "image_top_left",
      "label": "Top Image"
    },
    {
      "type": "image_picker",
      "id": "image_bottom_left",
      "label": "Bottom Image"
    },

    {
      "type": "header",
      "content": "Column D — Two Stacked Images",
      "info": "Right column: top image and bottom image."
    },
    {
      "type": "image_picker",
      "id": "image_top_right",
      "label": "Top Image"
    },
    {
      "type": "image_picker",
      "id": "image_bottom_right",
      "label": "Bottom Image"
    },

    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Desktop Section Height",
      "default": 480
    },
    {
      "type": "range",
      "id": "col_a_width",
      "min": 15,
      "max": 45,
      "step": 1,
      "unit": "%",
      "label": "Column A Width (Text)",
      "default": 28,
      "info": "Width of the text + small image column."
    },
    {
      "type": "range",
      "id": "col_b_width",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "%",
      "label": "Column B Width (Tall Image)",
      "default": 14,
      "info": "Width of the tall feature image column."
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Gap Between Items",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 100,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Mobile Image Height",
      "default": 180
    },

    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Custom Image Grid",
      "settings": {
        "col_a_width": 28,
        "col_b_width": 14,
        "section_height": 480,
        "gap": 16,
        "mobile_image_height": 180
      }
    }
  ]
}
{% endschema %}