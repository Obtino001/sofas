{%- liquid
  assign text_block = section.blocks | where: 'type', 'text' | first
  assign image_1 = section.blocks | where: 'type', 'image_1' | first
  assign image_2 = section.blocks | where: 'type', 'image_2' | first
  assign image_3 = section.blocks | where: 'type', 'image_3' | first
  assign image_4 = section.blocks | where: 'type', 'image_4' | first
  assign image_5 = section.blocks | where: 'type', 'image_5' | first
  assign image_6 = section.blocks | where: 'type', 'image_6' | first
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-collage-{{ section.id }} {
    --collage-gap: {{ section.settings.gap }}px;
    --collage-radius: {{ section.settings.image_radius }}px;
  }

  .custom-collage-{{ section.id }} .custom-collage__text {
    color: rgb(var(--color-foreground));
    font-size: 1.5rem;
    line-height: 1.6;
    margin: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__text p {
    margin: 0;
  }

  .custom-collage-{{ section.id }} .custom-collage__text p + p {
    margin-top: 1em;
  }

  .custom-collage-{{ section.id }} .custom-collage__img {
    border-radius: var(--collage-radius);
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
    align-self: flex-start;
    max-width: none;
  }

  .custom-collage-{{ section.id }} .custom-collage__layout--desktop,
  .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col,
  .custom-collage-{{ section.id }} .custom-collage__mobile-grid,
  .custom-collage-{{ section.id }} .custom-collage__mobile-left,
  .custom-collage-{{ section.id }} .custom-collage__mobile-right {
    overflow: visible;
  }

  .custom-collage-{{ section.id }} .custom-collage__img img,
  .custom-collage-{{ section.id }} .custom-collage__img svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .custom-collage-{{ section.id }} .custom-collage__placeholder {
    background-color: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .custom-collage-{{ section.id }} .custom-collage__placeholder svg {
    width: 40px;
    height: 40px;
    fill: rgba(var(--color-foreground), 0.15);
  }

  .custom-collage-{{ section.id }} .custom-collage__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .custom-collage-{{ section.id }} .custom-collage__text--mobile {
    display: none;
  }

  .custom-collage-{{ section.id }} .custom-collage__layout--mobile {
    display: none;
  }

  {%- if text_block -%}
    .custom-collage-{{ section.id }} #block-{{ text_block.id }} {
      text-align: {{ text_block.settings.text_align_desktop }};
      margin-top: {{ text_block.settings.offset_top }}px;
      margin-bottom: {{ text_block.settings.gap_below }}px;
    }
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- unless block.type == 'text' -%}
      {%- liquid
        assign block_aspect = block.settings.aspect_ratio | default: '1 / 1'
        assign block_offset_top = block.settings.offset_top | default: 0
        assign block_offset_left = block.settings.offset_left | default: 0
        assign block_gap_below = block.settings.gap_below | default: 0
        assign block_width = block.settings.width_percent | default: 100
        assign block_width_align = block.settings.width_align | default: 'left'
        assign block_min_height = block.settings.min_height | default: 0
        assign block_max_height = block.settings.max_height | default: 0
        assign block_desktop_layout = block.settings.desktop_layout | default: 'aspect_ratio'
        assign block_fixed_height = block.settings.fixed_height | default: 200
      -%}
      .custom-collage-{{ section.id }} #block-{{ block.id }} {
        margin-top: {{ block_offset_top }}px;
        margin-left: {{ block_offset_left }}px;
        margin-bottom: {{ block_gap_below }}px;
        width: {{ block_width }}%;
        {%- if block_width > 100 -%}
          {%- case block_width_align -%}
            {%- when 'center' -%}
              align-self: center;
            {%- when 'right' -%}
              align-self: flex-end;
            {%- else -%}
              align-self: flex-start;
          {%- endcase -%}
        {%- endif -%}
        {%- if block_desktop_layout == 'fixed_height' -%}
          height: {{ block_fixed_height }}px;
          aspect-ratio: unset;
        {%- elsif block_desktop_layout == 'flex_grow' -%}
          flex: 1 1 0;
          aspect-ratio: unset;
          min-height: {{ block_min_height }}px;
        {%- else -%}
          aspect-ratio: {{ block_aspect }};
        {%- endif -%}
        {%- if block_min_height > 0 and block_desktop_layout != 'flex_grow' -%}
          min-height: {{ block_min_height }}px;
        {%- endif -%}
        {%- if block_max_height > 0 -%}
          max-height: {{ block_max_height }}px;
        {%- endif -%}
      }
    {%- endunless -%}
  {%- endfor -%}

  @media screen and (max-width: 749px) {
    .custom-collage-{{ section.id }} .custom-collage__layout--desktop {
      display: none;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--mobile {
      display: flex;
      flex-direction: column;
      gap: calc(var(--collage-gap) * 1.25);
    }

    .custom-collage-{{ section.id }} .custom-collage__text--mobile {
      display: block;
    }

    {%- if text_block -%}
      .custom-collage-{{ section.id }} #block-{{ text_block.id }} {
        text-align: {{ text_block.settings.text_align_mobile }};
        font-size: {{ text_block.settings.font_size_mobile }}px;
        line-height: {{ text_block.settings.line_height_mobile | divided_by: 100.0 }};
        margin-top: {{ text_block.settings.offset_top_mobile }}px;
        margin-bottom: {{ text_block.settings.gap_below_mobile }}px;
        padding-inline: {{ text_block.settings.padding_horizontal_mobile }}px;
      }
    {%- endif -%}

    .custom-collage-{{ section.id }} .custom-collage__mobile-grid {
      display: flex;
      gap: var(--collage-gap);
      align-items: stretch;
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-left,
    .custom-collage-{{ section.id }} .custom-collage__mobile-right {
      display: flex;
      flex-direction: column;
      gap: var(--collage-gap);
      flex: 1;
      min-width: 0;
      min-height: 100%;
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-pair {
      display: flex;
      gap: var(--collage-gap);
      flex-shrink: 0;
      overflow: visible;
    }

    .custom-collage-{{ section.id }} .custom-collage__mobile-pair .custom-collage__img {
      flex: 1;
      min-width: 0;
    }

    {%- for block in section.blocks -%}
      {%- unless block.type == 'text' -%}
        {%- liquid
          assign m_offset_top = block.settings.offset_top_mobile | default: 0
          assign m_offset_left = block.settings.offset_left_mobile | default: 0
          assign m_gap_below = block.settings.gap_below_mobile | default: 0
          assign m_width = block.settings.width_percent_mobile | default: 100
          assign m_width_align = block.settings.width_align_mobile | default: 'left'
          assign m_min_height = block.settings.min_height_mobile | default: 0
          assign m_max_height = block.settings.max_height_mobile | default: 0
          assign m_layout = block.settings.mobile_layout | default: 'aspect_ratio'
          assign m_aspect = block.settings.aspect_ratio_mobile | default: '1 / 1'
          assign m_fixed_height = block.settings.fixed_height_mobile | default: 200
        -%}
        .custom-collage-{{ section.id }} #block-{{ block.id }} {
          margin-top: {{ m_offset_top }}px;
          margin-left: {{ m_offset_left }}px;
          margin-bottom: {{ m_gap_below }}px;
          width: {{ m_width }}%;
          {%- if m_width > 100 -%}
            {%- case m_width_align -%}
              {%- when 'center' -%}
                align-self: center;
              {%- when 'right' -%}
                align-self: flex-end;
              {%- else -%}
                align-self: flex-start;
            {%- endcase -%}
          {%- endif -%}
          {%- if m_min_height > 0 -%}
            min-height: {{ m_min_height }}px;
          {%- else -%}
            min-height: 0;
          {%- endif -%}
          {%- if m_max_height > 0 -%}
            max-height: {{ m_max_height }}px;
          {%- else -%}
            max-height: none;
          {%- endif -%}
          {%- if m_layout == 'flex_grow' -%}
            flex: 1 1 0;
            aspect-ratio: unset;
            height: auto;
          {%- elsif m_layout == 'fixed_height' -%}
            flex: 0 0 auto;
            height: {{ m_fixed_height }}px;
            aspect-ratio: unset;
          {%- else -%}
            flex: 0 0 auto;
            aspect-ratio: {{ m_aspect }};
          {%- endif -%}
        }
      {%- endunless -%}
    {%- endfor -%}
  }

  @media screen and (min-width: 750px) {
    .custom-collage-{{ section.id }} .custom-collage__layout--mobile,
    .custom-collage-{{ section.id }} .custom-collage__text--mobile {
      display: none;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop {
      display: flex;
      gap: var(--collage-gap);
      align-items: flex-start;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col {
      display: flex;
      flex-direction: column;
      gap: var(--collage-gap);
      min-width: 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--1 {
      flex: {{ section.settings.col_1_width }} 1 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--2 {
      flex: {{ section.settings.col_2_width }} 1 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--3 {
      flex: {{ section.settings.col_3_width }} 1 0;
    }

    .custom-collage-{{ section.id }} .custom-collage__layout--desktop .custom-collage__col--4 {
      flex: {{ section.settings.col_4_width }} 1 0;
    }
  }
{%- endstyle -%}

<div class="{% if section.settings.color_scheme != blank %}color-{{ section.settings.color_scheme }} {% endif %}gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="custom-collage-{{ section.id }}">

      <div class="custom-collage__layout custom-collage__layout--mobile">
        {%- if text_block != blank and text_block.settings.text != blank -%}
          <div
            id="block-{{ text_block.id }}"
            class="custom-collage__text custom-collage__text--mobile{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ text_block.shopify_attributes }}
          >
            {{ text_block.settings.text }}
          </div>
        {%- endif -%}

        <div class="custom-collage__mobile-grid">
          <div class="custom-collage__mobile-left">
            {%- render 'custom-collage-image', block: image_1, index: 1, include_attributes: false -%}
            {%- render 'custom-collage-image', block: image_3, index: 3, include_attributes: false -%}
          </div>
          <div class="custom-collage__mobile-right">
            <div class="custom-collage__mobile-pair">
              {%- render 'custom-collage-image', block: image_2, index: 2, include_attributes: false -%}
              {%- render 'custom-collage-image', block: image_4, index: 4, include_attributes: false -%}
            </div>
            {%- render 'custom-collage-image', block: image_6, index: 6, include_attributes: false -%}
            {%- render 'custom-collage-image', block: image_5, index: 5, include_attributes: false -%}
          </div>
        </div>
      </div>

      <div class="custom-collage__layout custom-collage__layout--desktop">
        <div class="custom-collage__col custom-collage__col--1">
          {%- if text_block != blank and text_block.settings.text != blank -%}
            <div id="block-{{ text_block.id }}" class="custom-collage__text custom-collage__text--inline">
              {{ text_block.settings.text }}
            </div>
          {%- endif -%}
          {%- render 'custom-collage-image', block: image_1, index: 1 -%}
        </div>
        <div class="custom-collage__col custom-collage__col--2">
          {%- render 'custom-collage-image', block: image_2, index: 2 -%}
          {%- render 'custom-collage-image', block: image_3, index: 3 -%}
        </div>
        <div class="custom-collage__col custom-collage__col--3">
          {%- render 'custom-collage-image', block: image_4, index: 4 -%}
          {%- render 'custom-collage-image', block: image_5, index: 5 -%}
        </div>
        <div class="custom-collage__col custom-collage__col--4">
          {%- render 'custom-collage-image', block: image_6, index: 6 -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Image Grid (Figma)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Global layout"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Gap between items",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Desktop column widths"
    },
    {
      "type": "range",
      "id": "col_1_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 1",
      "default": 30
    },
    {
      "type": "range",
      "id": "col_2_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 2",
      "default": 20
    },
    {
      "type": "range",
      "id": "col_3_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 3",
      "default": 24
    },
    {
      "type": "range",
      "id": "col_4_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "fr",
      "label": "Column 4",
      "default": 26
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>At Sofas n Beds, we believe great furniture should be accessible, reliable, and built to last. We create high-quality sofas and beds designed for real homes—combining comfort, durability, and value without the long wait times of traditional retailers.</p>"
        },
        {
          "type": "header",
          "content": "Desktop text layout"
        },
        {
          "type": "select",
          "id": "text_align_desktop",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "offset_top",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Offset top",
          "default": 0
        },
        {
          "type": "range",
          "id": "gap_below",
          "min": 0,
          "max": 60,
          "step": 2,
          "unit": "px",
          "label": "Gap below text",
          "default": 0
        },
        {
          "type": "header",
          "content": "Mobile text layout"
        },
        {
          "type": "select",
          "id": "text_align_mobile",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "min": 12,
          "max": 20,
          "step": 1,
          "unit": "px",
          "label": "Font size",
          "default": 14
        },
        {
          "type": "range",
          "id": "line_height_mobile",
          "min": 120,
          "max": 200,
          "step": 5,
          "label": "Line height (%)",
          "default": 155
        },
        {
          "type": "range",
          "id": "offset_top_mobile",
          "min": 0,
          "max": 60,
          "step": 2,
          "unit": "px",
          "label": "Offset top",
          "default": 0
        },
        {
          "type": "range",
          "id": "gap_below_mobile",
          "min": 0,
          "max": 60,
          "step": 2,
          "unit": "px",
          "label": "Gap below text",
          "default": 8
        },
        {
          "type": "range",
          "id": "padding_horizontal_mobile",
          "min": 0,
          "max": 40,
          "step": 2,
          "unit": "px",
          "label": "Side padding",
          "default": 4
        }
      ]
    },
    {
      "type": "image_1",
      "name": "Image 1 — White sofa",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "header", "content": "Desktop layout" },
        { "type": "text", "id": "aspect_ratio", "label": "Aspect ratio (width / height)", "default": "1.1 / 1", "info": "Example: 1.1 / 1 landscape, 0.75 / 1 portrait" },
        { "type": "range", "id": "offset_top", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Offset top", "default": 0 },
        { "type": "range", "id": "offset_left", "min": -100, "max": 100, "step": 2, "unit": "px", "label": "Offset left", "default": 0 },
        { "type": "range", "id": "gap_below", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Extra gap below", "default": 0 },
        { "type": "range", "id": "width_percent", "min": 50, "max": 200, "step": 5, "unit": "%", "label": "Width (over 100% extends beyond column)", "default": 100 },
        { "type": "select", "id": "width_align", "label": "Wide image alignment", "info": "When width is over 100%, choose which direction it extends.", "options": [
          { "value": "left", "label": "Extend to the right" },
          { "value": "center", "label": "Extend both sides" },
          { "value": "right", "label": "Extend to the left" }
        ], "default": "left" },
        { "type": "select", "id": "desktop_layout", "label": "Desktop sizing", "options": [
          { "value": "aspect_ratio", "label": "Aspect ratio" },
          { "value": "fixed_height", "label": "Fixed height" },
          { "value": "flex_grow", "label": "Fill remaining space" }
        ], "default": "aspect_ratio" },
        { "type": "range", "id": "fixed_height", "min": 80, "max": 800, "step": 10, "unit": "px", "label": "Desktop fixed height", "default": 200, "info": "Used when desktop sizing is Fixed height" },
        { "type": "range", "id": "min_height", "min": 0, "max": 600, "step": 10, "unit": "px", "label": "Min height (0 = auto)", "default": 0 },
        { "type": "range", "id": "max_height", "min": 0, "max": 800, "step": 10, "unit": "px", "label": "Max height (0 = none)", "default": 0 },
        { "type": "header", "content": "Mobile layout" },
        { "type": "select", "id": "mobile_layout", "label": "Mobile sizing", "options": [
          { "value": "aspect_ratio", "label": "Aspect ratio" },
          { "value": "flex_grow", "label": "Fill remaining space" },
          { "value": "fixed_height", "label": "Fixed height" }
        ], "default": "flex_grow" },
        { "type": "text", "id": "aspect_ratio_mobile", "label": "Mobile aspect ratio", "default": "1.1 / 1" },
        { "type": "range", "id": "offset_top_mobile", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Offset top", "default": 0 },
        { "type": "range", "id": "offset_left_mobile", "min": -80, "max": 80, "step": 2, "unit": "px", "label": "Offset left", "default": 0 },
        { "type": "range", "id": "gap_below_mobile", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Extra gap below", "default": 0 },
        { "type": "range", "id": "width_percent_mobile", "min": 25, "max": 200, "step": 5, "unit": "%", "label": "Mobile width (over 100% extends beyond column)", "default": 100 },
        { "type": "select", "id": "width_align_mobile", "label": "Mobile wide image alignment", "info": "When mobile width is over 100%, choose which direction it extends.", "options": [
          { "value": "left", "label": "Extend to the right" },
          { "value": "center", "label": "Extend both sides" },
          { "value": "right", "label": "Extend to the left" }
        ], "default": "left" },
        { "type": "range", "id": "min_height_mobile", "min": 0, "max": 600, "step": 10, "unit": "px", "label": "Min height", "default": 140 },
        { "type": "range", "id": "fixed_height_mobile", "min": 80, "max": 600, "step": 10, "unit": "px", "label": "Fixed height", "default": 220 },
        { "type": "range", "id": "max_height_mobile", "min": 0, "max": 800, "step": 10, "unit": "px", "label": "Max height (0 = none)", "default": 0 }
      ]
    },
    {
      "type": "image_2",
      "name": "Image 2 — Bed",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "header", "content": "Desktop layout" },
