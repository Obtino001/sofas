{%- style -%}
  .announcement-timer-section {
    display: block;
    width: 100%;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.08);
  }

  .announcement-timer {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 0;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .announcement-timer {
      justify-content: center;
      padding: 0.8rem 0;
      gap: 2rem;
    }
  }

.announcement-timer__message {
    margin: 0;
    font-size: 1.3rem;
    letter-spacing: 0.1rem;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
    font-weight: 600;
}

  .countdown-timer-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 1.5px;
    line-height: 1;
    color: rgb(var(--color-foreground));
  }

  @media screen and (min-width: 750px) {
    .countdown-timer-wrapper {
      font-size: 26px;
    }
  }

  .countdown-timer__block {
    display: flex;
    align-items: center;
  }

  .countdown-timer__digit {
    font-variant-numeric: tabular-nums;
  }

  .countdown-timer__colon {
    margin-top: -0.2rem;
  }

  .countdown-timer__label {
    display: none;
  }

  /* Hidden state for JS */
  countdown-timer:not(:defined) {
    visibility: hidden;
  }
  .countdown-timer--hidden {
    display: none !important;
  }
{%- endstyle -%}

<div class="announcement-timer-section color-{{ section.settings.color_scheme }} gradient" 
     role="region" 
     aria-label="{{ 'sections.header.announcement' | t }}" 
     {{ section.shopify_attributes }}>
  <div class="page-width">
    <div class="announcement-timer">
      
      {%- if section.settings.text != blank -%}
        <div class="announcement-timer__message">
          {{ section.settings.text | escape }}
        </div>
      {%- endif -%}

      {%- if section.settings.end_date != blank -%}
        <countdown-timer data-datetime="{{ section.settings.end_date | escape }}" data-auto-restart="{{ section.settings.auto_restart }}" data-hide-on-expire="{{ section.settings.hide_on_expire }}">
          <div class="countdown-timer-wrapper">
            <div class="countdown-timer__block">
              <span class="countdown-timer__digit"><span data-hours>00</span>H</span>
            </div>
            
            <span class="countdown-timer__colon">:</span>
            
            <div class="countdown-timer__block">
              <span class="countdown-timer__digit"><span data-minutes>00</span>M</span>
            </div>
            
            <span class="countdown-timer__colon">:</span>
            
            <div class="countdown-timer__block">
              <span class="countdown-timer__digit"><span data-seconds>00</span>S</span>
            </div>
          </div>
        </countdown-timer>
      {%- endif -%}
      
    </div>
  </div>
</div>

<script>
  if (!customElements.get('countdown-timer')) {
    class CountdownTimer extends HTMLElement {
      constructor() {
        super();
        this.endDateString = this.dataset.datetime;
        this.hideOnExpire = this.dataset.hideOnExpire === 'true';
        this.autoRestartHours = parseInt(this.dataset.autoRestart, 10) || 0;
        this.parsedDate = new Date(this.endDateString.replace(/-/g, "/")).getTime();
        
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
      }

      connectedCallback() {
        if (!this.parsedDate || isNaN(this.parsedDate)) {
          console.error('Countdown Timer: Invalid date format. Please use YYYY/MM/DD HH:MM:SS');
          return;
        }
        
        this.updateTimer();
        this.interval = setInterval(this.updateTimer.bind(this), 1000);
      }

      disconnectedCallback() {
        if (this.interval) clearInterval(this.interval);
      }

      updateTimer() {
        const now = new Date().getTime();
        let distance = this.parsedDate - now;

        if (distance < 0) {
          if (this.autoRestartHours > 0) {
            // Auto-restart based on selected duration
            const millisToAdd = this.autoRestartHours * 60 * 60 * 1000;
            const periodsToAdd = Math.floor(Math.abs(distance) / millisToAdd) + 1;
            this.parsedDate += periodsToAdd * millisToAdd;
            distance = this.parsedDate - now;
          } else {
            clearInterval(this.interval);
            this.setZero();
            if (this.hideOnExpire) {
              this.closest('.announcement-timer-section').classList.add('countdown-timer--hidden');
            }
            return;
          }
        }

        const hours = Math.floor(distance / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.updateElements(hours, minutes, seconds);
      }

      updateElements(hours, minutes, seconds) {
        if (this.hoursEl) this.hoursEl.textContent = String(hours).padStart(2, '0');
        if (this.minutesEl) this.minutesEl.textContent = String(minutes).padStart(2, '0');
        if (this.secondsEl) this.secondsEl.textContent = String(seconds).padStart(2, '0');
      }

      setZero() {
        this.updateElements(0, 0, 0);
      }
    }
    
    customElements.define('countdown-timer', CountdownTimer);
  }
</script>

{% schema %}
{
  "name": "Announcement Timer",
  "class": "section-announcement-timer",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "text",
      "id": "text",
      "default": "30% OFF Store Wide | Sale ends in:",
      "label": "Announcement text"
    },
    {
      "type": "header",
      "content": "Timer Settings"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date and Time",
      "info": "Format: YYYY/MM/DD HH:MM:SS (e.g. 2026/12/31 23:59:59). Timezone is based on the user's browser.",
      "default": "2026/12/31 23:59:59"
    },
    {
      "type": "select",
      "id": "auto_restart",
      "label": "Auto-restart duration",
      "info": "How often the timer should automatically restart after expiring.",
      "options": [
        { "value": "0", "label": "No auto-restart" },
        { "value": "24", "label": "Every 24 hours" },
        { "value": "36", "label": "Every 36 hours" },
        { "value": "48", "label": "Every 48 hours" },
        { "value": "72", "label": "Every 72 hours" }
      ],
      "default": "24"
    },
    {
      "type": "checkbox",
      "id": "hide_on_expire",
      "label": "Hide entire bar when timer expires",
      "default": false
    },
    {
      "type": "header",
      "content": "Translations"
    },
    {
      "type": "text",
      "id": "label_hours",
      "label": "Hours label",
      "default": "Hours"
    },
    {
      "type": "text",
      "id": "label_minutes",
      "label": "Minutes label",
      "default": "Minutes"
    },
    {
      "type": "text",
      "id": "label_seconds",
      "label": "Seconds label",
      "default": "Seconds"
    }
  ],
  "presets": [
    {
      "name": "Announcement Timer"
    }
  ]
}
{% endschema %}