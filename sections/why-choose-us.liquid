{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .why-choose-wrapper {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .why-choose-heading {
    font-size: clamp(28px, 4vw, 38px);
    margin: 0 0 40px 0;
    color: rgb(var(--color-foreground));
    font-weight: 400;
  }

  /* Applies the elegant serif styling to italicized words like "choose" */
  .why-choose-heading em, 
  .why-choose-heading i {
    font-family: "Georgia", "Times New Roman", serif; /* Elegant serif fallback */
    font-style: italic;
    font-weight: 500;
  }

  .why-choose-main-image {
    max-width: 100%;
    height: auto;
    margin: 0 auto 50px;
    display: block;
    object-fit: contain;
  }

  /* Grid & Slider Layout */
  .why-choose-grid {
    display: flex;
    padding: 0;
    margin: 0;
    list-style: none;
    gap: 20px;
  }

  .why-choose-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }

  .why-choose-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 45px;
    height: 45px;
    margin-bottom: 15px;
    color: rgb(var(--color-foreground));
  }

  .why-choose-icon svg,
  .why-choose-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .why-choose-title {
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 10px 0;
    letter-spacing: 0.3px;
    color: rgb(var(--color-foreground));
  }

  .why-choose-text {
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    opacity: 0.8;
    color: rgb(var(--color-foreground));
  }

  /* Mobile Pagination */
  .why-choose-pagination {
    display: none;
  }

  /* Mobile: Native CSS Scroll Snap */
  @media screen and (max-width: 749px) {
    .why-choose-grid {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
      gap: 0; 
    }
    
    .why-choose-grid::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }

    .why-choose-item {
      flex: 0 0 100%;
      scroll-snap-align: center;
      padding: 0 15px;
    }

    .why-choose-pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 30px;
    }

    .why-choose-dot {
      width: 35px;
      height: 3px;
      background-color: rgb(var(--color-foreground));
      opacity: 0.15;
      border: none;
      padding: 0;
      cursor: pointer;
      border-radius: 0;
      transition: opacity 0.4s ease;
    }

    .why-choose-dot.is-active {
      opacity: 0.85;
    }
  }

  /* Desktop: Standard Grid */
  @media screen and (min-width: 750px) {
    .why-choose-grid {
      grid-template-columns: repeat(4, 1fr);
      display: grid;
      gap: 30px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="why-choose-wrapper">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="why-choose-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.main_image != blank -%}
      {{ section.settings.main_image | image_url: width: 1200 | image_tag: class: 'why-choose-main-image', loading: 'lazy' }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'why-choose-main-image placeholder-svg' }}
    {%- endif -%}

    <div class="why-choose-slider-container">
      <ul class="why-choose-grid" id="Slider-{{ section.id }}">
        {%- for block in section.blocks -%}
          <li class="why-choose-item" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            
            <div class="why-choose-icon">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              {%- endif -%}
            </div>
            
            {%- if block.settings.title != blank -%}
              <h3 class="why-choose-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <p class="why-choose-text">{{ block.settings.text }}</p>
            {%- endif -%}

          </li>
        {%- endfor -%}
      </ul>
      
      {%- if section.blocks.size > 1 -%}
        <div class="why-choose-pagination" id="Slider-Pagination-{{ section.id }}">
          {%- for block in section.blocks -%}
            <button class="why-choose-dot {% if forloop.first %}is-active{% endif %}" aria-label="Go to slide {{ forloop.index }}" data-index="{{ forloop.index0 }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionId = '{{ section.id }}';
    const slider = document.querySelector(`#Slider-${sectionId}`);
    const dots = document.querySelectorAll(`#Slider-Pagination-${sectionId} .why-choose-dot`);
    const slides = slider.querySelectorAll('.why-choose-item');
    
    if (!slider || dots.length === 0) return;

    // Smoothly update pagination dots on swipe/scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const index = entry.target.dataset.index;
          dots.forEach(dot => dot.classList.remove('is-active'));
          if(dots[index]) dots[index].classList.add('is-active');
        }
      });
    }, {
      root: slider,
      threshold: 0.6 // Slide is considered active when 60% visible
    });

    slides.forEach(slide => observer.observe(slide));

    // Allow clicking the dots to smoothly scroll to the slide
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const slide = slides[index];
        if (slide) {
          slider.scrollTo({
            left: slide.offsetLeft,
            behavior: 'smooth'
          });
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Why <em>choose</em> Sofas'n'Beds",
      "info": "Use italic text (Ctrl+I) to apply the elegant serif font style."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Sofa Image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "UK Manufactured"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Subtext",
          "default": "Every sofa is crafted right here in the UK, ensuring consistent quality and supporting local craftsmanship."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "UK Manufactured",
            "text": "Every sofa is crafted right here in the UK, ensuring consistent quality and supporting local craftsmanship."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Flexible Financing",
            "text": "Spread the cost with interest-free payment options, making it easier to bring home the sofa you love."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Handcrafted Quality",
            "text": "Carefully made by skilled artisans using durable materials designed for everyday comfort and long-term use."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Risk-Free Guarantee",
            "text": "14-day returns with no hassle, so you can shop knowing you're fully covered."
          }
        }
      ]
    }
  ]
}
{% endschema %}