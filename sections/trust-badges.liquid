{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .trust-badges-wrapper {
    display: flex;
    flex-wrap: nowrap;
    justify-content: flex-start;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0 -1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .trust-badges-wrapper::-webkit-scrollbar {
    display: none;
  }

  .trust-badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 32%;
    flex-shrink: 0;
    scroll-snap-align: center;
  }

  .trust-badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin-bottom: 1.2rem;
  }

  .trust-badge-icon img,
  .trust-badge-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    fill: currentColor;
    color: rgb(var(--color-foreground));
  }

  .trust-badge-text {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    letter-spacing: 0.04rem;
  }
  @media screen and (max-width: 750px) {
    .trust-badge-item {
    padding-inline: 15px;
}
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .trust-badges-wrapper {
      justify-content: center;
      flex-wrap: wrap;
      gap: 2rem;
      overflow-x: visible;
      padding: 0;
      margin: 0;
    }

    .trust-badge-item {
      width: auto;
      flex: 1 1 0; /* Distributes space evenly on desktop */
      max-width: 25rem;
      flex-shrink: 1;
      scroll-snap-align: none;
    }
    
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <ul class="trust-badges-wrapper" role="list">
      {%- for block in section.blocks -%}
        <li class="trust-badge-item" {{ block.shopify_attributes }}>
          <div class="trust-badge-icon">
            {%- if block.settings.image != blank -%}
              {%- assign image_width = section.settings.icon_size | times: 2 -%}
              {{ block.settings.image | image_url: width: image_width | image_tag: loading: 'lazy', alt: block.settings.title | escape }}
            {%- elsif block.settings.icon != blank and block.settings.icon != 'none' -%}
              {% render 'icon-accordion', icon: block.settings.icon %}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <p class="trust-badge-text">{{ block.settings.title }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

