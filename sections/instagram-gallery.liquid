{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Grid Column Variables based on schema */
  #sr-insta-grid-{{ section.id }} {
    --desktop-cols: {{ section.settings.columns_desktop }};
    --mobile-cols: {{ section.settings.columns_mobile }};
  }
{%- endstyle -%}

<div class="sr-insta-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="sr-insta-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="sr-insta-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <a href="{{ section.settings.subheading_link | default: '#' }}" class="sr-insta-handle" target="_blank">
          {{ section.settings.subheading }}
        </a>
      {%- endif -%}
    </div>

    <div id="sr-insta-grid-{{ section.id }}" class="sr-insta-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="sr-insta-item" {{ block.shopify_attributes }} {% if block.settings.link != blank %}target="_blank"{% endif %}>
          {%- if block.settings.image != blank -%}
            <img 
              src="{{ block.settings.image | image_url: width: 600 }}" 
              alt="{{ block.settings.image.alt | escape | default: 'Instagram Image' }}" 
              loading="lazy" 
              class="sr-insta-image"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            <div class="sr-insta-placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </a>
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="sr-insta-item">
             <div class="sr-insta-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% comment %} Styles moved to sereluna.css {% endcomment %}

{% schema %}
{
  "name": "Instagram Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Instagram"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading / Handle",
      "default": "@serelunaofficial"
    },
    {
      "type": "url",
      "id": "subheading_link",
      "label": "Instagram Profile Link"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "label": "Desktop Columns",
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Mobile Columns",
      "default": 2
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "instagram_image",
      "name": "Instagram Image",
      "limit": 24,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post Link",
          "info": "Optional: Link directly to the Instagram post."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Gallery",
      "blocks": [
        { "type": "instagram_image" },
        { "type": "instagram_image" },
        { "type": "instagram_image" },
        { "type": "instagram_image" },
        { "type": "instagram_image" },
        { "type": "instagram_image" }
      ]
    }
  ]
}
{% endschema %}