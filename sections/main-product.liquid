  .sticky-add-to-cart__timer {
    width: auto;
    flex: 0 0 auto;
  }
  .delivery-timer-container-sticky {
    flex-direction: row;
    gap: 20px;
    justify-content: flex-start;
  }
  .delivery-timer-container-sticky .dt-top {
    margin-bottom: 0;
  }
  .delivery-timer-container-sticky .dt-bottom {
    font-size: 22px;
  }
}
</style>

<script>
(function() {
  const stickyBar = document.getElementById('StickyAddToCart');
  const mainAddToCart = document.querySelector('#ProductInfo-{{ section.id }} .product-form__submit');
  
  if (!stickyBar || !mainAddToCart) return;

  // Intersection Observer for the sticky bar visibility
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      // If the main add to cart button is on screen, hide sticky bar
      if (entry.isIntersecting) {
        stickyBar.classList.remove('is-visible');
      } else {
        // Show sticky bar whenever the main button is not on screen (both above and below)
        stickyBar.classList.add('is-visible');
      }
    });
  }, {
    root: null,
    threshold: 0,
    rootMargin: "0px 0px 50px 0px"
  });

  observer.observe(mainAddToCart);

  // Timer logic for sticky bar
  const stickyCountdownEl = document.getElementById('countdown-sticky');
  if (stickyCountdownEl) {
    function updateStickyTimer() {
      const now = new Date();
      const tomorrow = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
      const diff = tomorrow - now;
      
      const h = Math.floor((diff / (1000 * 60 * 60)) % 24).toString().padStart(2, '0');
      const m = Math.floor((diff / 1000 / 60) % 60).toString().padStart(2, '0');
      const s = Math.floor((diff / 1000) % 60).toString().padStart(2, '0');
      
      stickyCountdownEl.innerHTML = `${h}H : ${m}M : ${s}S`;
    }
    setInterval(updateStickyTimer, 1000);
    updateStickyTimer();
  }
})();
</script>

