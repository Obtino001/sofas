{%- style -%}
  .ma-tp-widget {
    background: transparent;
    overflow: hidden;
    padding-top: {{ section.settings.ma-trust-section-padding-top }}px;
    padding-bottom: {{ section.settings.ma-trust-section-padding-bottom }}px;
    {% if section.settings.top_p %}padding-top: 0;{% endif %}
    {% if section.settings.bottom_p %}padding-bottom: 0;{% endif %}
  }

  @media screen and (max-width: 749px) {
    .ma-tp-widget {
      margin-block: 30px;
      padding-top: {{ section.settings.ma-trust-section-padding-top-mobile }}px;
      padding-bottom: {{ section.settings.ma-trust-section-padding-bottom-mobile }}px;
    }
  }
{%- endstyle -%}











{% comment %} Static styles moved to sereluna.css {% endcomment %}




