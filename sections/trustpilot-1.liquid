</div>

<script>
  function initMaTpSlider() {
    var sliderElement = document.querySelector('.ma-tp-swiper-container');
    if (!sliderElement) return;

    var swiper = new Swiper('.ma-tp-swiper-container', {
      slidesPerView: 4,
      spaceBetween: 10,
      speed: 300,
      loop: true,
      watchOverflow: true,
      navigation: {
        nextEl: '.ma-tp-next',
        prevEl: '.ma-tp-prev',
      },
      breakpoints: {
        1024: {
          slidesPerView: 3,
          slidesPerGroup: 1,
          spaceBetween: 10,
        },
        600: {
          slidesPerView: 2,
          slidesPerGroup: 2,
          spaceBetween: 10,
        },
        480: {
          slidesPerView: 1,
          slidesPerGroup: 1,
          spaceBetween: 10,
        }
      }
    });
  }
  document.addEventListener('DOMContentLoaded', initMaTpSlider);
  document.addEventListener('shopify:section:load', initMaTpSlider);
</script>

{% schema %}
{
  "name": "Trustpilot Slider",
  "class": "trust-bg",
  "settings": [
    {
      "type": "text",
      "id": "main-heading",
      "label": "Main Heading",
      "default": "Det siger vores kunder"
    },
    {
      "type": "text",
      "id": "ma-section-heading",
      "label": "Enter section heading",
      "default": "This is section heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fremragende"
    },
    {
      "type": "text",
      "id": "trustpilot_text",
      "label": "Trustpilot Text",
      "default": "Se alle anmeldelser"
    },
    {
      "type": "url",
      "id": "trustpiloturl",
      "label": "Trustpilot Url"
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Total Reviews",
      "default": "226+ anmeldelser"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background color"
    },
    {
      "id": "alternate_bg_color",
      "type": "checkbox",
      "label": "Use alternate section color",
      "default": false
    },
    {
      "type": "range",
      "id": "ma-trust-section-padding-top",
      "label": "Padding Top desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "ma-trust-section-padding-bottom",
      "label": "Padding Bottom desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "ma-trust-section-padding-top-mobile",
      "label": "Padding Top Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "ma-trust-section-padding-bottom-mobile",
      "label": "Padding Bottom Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    }
  ],
  "blocks":[
    {
      "name": "Trustpilot",
      "type": "review",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Would I recommend this company? Early signs is a resounding YES!"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date/ Time",
          "default": "33 hours ago"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "I looked at this company in depth, after requesting a phone call to discuss my r.."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "John Cina"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trustpilot Slider"
    }
  ]
}
{% endschema %}
