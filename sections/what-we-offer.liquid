{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .what-we-offer__container {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  /* --- Image Column --- */
  .what-we-offer__image-col {
    flex: 1.6;
    width: 100%;
    /* Add padding to prevent the offset shape from overflowing the screen on mobile */
    padding-top: 2rem;
    padding-left: 1.5rem; 
  }

  .what-we-offer__image-wrapper {
    position: relative;
    width: 100%;
    z-index: 1;
  }

  /* The offset background shape */
  .what-we-offer__image-wrapper::before {
    content: '';
    position: absolute;
    top: -2.5rem;
    left: -2.5rem;
    bottom: -2.5rem;
    right: 3rem; /* The image overhangs on the right */
    background-color: {{ section.settings.decorator_color }};
    border-radius: 1.2rem;
    z-index: -1;
  }

  .what-we-offer__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 0.8rem;
    display: block;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  /* --- Content Column --- */
  .what-we-offer__content-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .what-we-offer__heading {
    margin: 0 0 2.5rem 0;
    color: rgb(var(--color-foreground));
    font-weight: 500;
  }

  /* Applies elegant serif styling if the user italicizes a word */
  .what-we-offer__heading em, 
  .what-we-offer__heading i {
    font-style: italic;
    font-weight: 600;
  }

  .what-we-offer__text {
    font-size: 1.5rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.85);
    margin-bottom: 4rem;
  }

  .what-we-offer__text p {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
  .what-we-offer__text p:last-child {
    margin-bottom: 0;
  }

  /* --- Features Grid --- */
  .what-we-offer__features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 2rem;
  }

  .what-we-offer__feature {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .what-we-offer__feature-icon {
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: rgb(var(--color-foreground));
  }

  .what-we-offer__feature-icon img,
  .what-we-offer__feature-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .what-we-offer__feature-title {
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    margin: 0;
    max-width: 180px;
  }

  /* Desktop Adjustments */
  @media screen and (min-width: 750px) {
    .what-we-offer__container {
      flex-direction: row;
      align-items: center;
      gap: 8rem;
    }

    .what-we-offer__image-col {
      padding-top: 0;
      padding-left: 3rem;
    }

    .what-we-offer__image-wrapper::before {
      top: -3.5rem;
      left: -3.5rem;
      bottom: -3.5rem;
      right: 4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width what-we-offer__container">
    
    <div class="what-we-offer__image-col">
      <div class="what-we-offer__image-wrapper">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 4200 | image_tag: 
            class: 'what-we-offer__image', 
            loading: 'lazy', 
            sizes: '(min-width: 750px) 50vw, 100vw' 
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'what-we-offer__image placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="what-we-offer__content-col">
      {%- if section.settings.heading != blank -%}
        <h2 class="what-we-offer__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="what-we-offer__text">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="what-we-offer__features">
          {%- for block in section.blocks -%}
            <div class="what-we-offer__feature" {{ block.shopify_attributes }}>
              
              <div class="what-we-offer__feature-icon">
                {%- if block.settings.icon_image != blank -%}
                  {{ block.settings.icon_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                {%- endif -%}
              </div>
              
              {%- if block.settings.title != blank -%}
                <div class="what-we-offer__feature-title">{{ block.settings.title | escape }}</div>
              {%- endif -%}

            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "What We Offer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Image Layout"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "color",
      "id": "decorator_color",
      "label": "Offset Background Color",
      "default": "#EFEBE5",
      "info": "The color of the shape sitting slightly behind the main image."
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What we offer"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" },
        { "value": "h0", "label": "Extra Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description Paragraphs",
      "default": "<p>We offer a carefully curated range of sofas and beds designed for comfort, durability, and everyday living.</p><p>By combining UK manufacturing with efficient processes, we're able to deliver high-quality furniture without the long wait times or inflated prices of traditional retailers.</p><p>From modern sofas to practical storage beds, every piece is made to fit seamlessly into your home—both in style and function.</p>"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon (SVG or PNG)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Text",
          "default": "Made for everyday comfort"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What We Offer",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Made for everyday comfort"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Proudly made in UK"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Built to last long"
          }
        }
      ]
    }
  ]
}
{% endschema %}