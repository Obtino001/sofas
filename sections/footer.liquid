{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    background-color: #EFEBE5; /* Matches the screenshot background */
    color: #333333;
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  
  /* Trust Badges Top Section */
  .footer-trust-badges {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 20px;
    padding: 40px 5%;
    max-width: var(--page-width);
    margin: 0 auto;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  @media screen and (min-width: 750px) {
    .footer { margin-top: {{ section.settings.margin_top }}px; }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .footer-trust-badges {
      grid-template-columns: repeat(4, 1fr);
      gap: 30px;
      padding: 60px 0;
    }
  }
  .trust-badge-card {
    background: #f7f6f2;
    border-radius: 8px;
    padding: 30px 20px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }
  .trust-badge-card svg {
    width: 32px;
    height: 32px;
    margin-bottom: 15px;
  }
  .trust-badge-card h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px 0;
    color: #000;
  }
  .trust-badge-card p {
    font-size: 13px;
    margin: 0;
    color: #555;
    line-height: 1.4;
  }

  /* Main Footer Overrides */
  .footer__content-top {
    padding-top: 50px;
    padding-bottom: 40px;
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 30px;
  }
  .footer-block__brand-info {
    flex: 1 1 300px;
    max-width: 350px;
  }
  .footer__blocks-wrapper {
    flex: 2 1 500px;
    display: flex;
    justify-content: space-around;
  }
  .footer-block--newsletter {
    flex: 1 1 300px;
    max-width: 350px;
  }
  .footer-block__heading {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
    margin-bottom: 20px;
  }
  .footer-block__details-content p, .list-menu__item {
    font-size: 14px;
    color: #4a4a4a;
    line-height: 1.6;
  }
  
  /* Newsletter Input Override */
  .newsletter-form__field-wrapper .field__input {
    background: #f4f0ec;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 25px;
    padding-left: 20px;
  }
  .newsletter-form__button {
    background: #c3a67d;
    color: white;
    border-radius: 25px;
    width: auto;
    padding: 0 25px;
    margin-top: 15px;
    right: 0;
    position: relative;
    font-weight: 500;
  }
  
  /* Footer Bottom */
  .footer__content-bottom {
    border-top: 1px solid rgba(0,0,0,0.1);
    padding: 25px 0;
  }
  .footer__content-bottom-wrapper {
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
  }
  .dp-payment-icon {
    width: 38px;
    height: auto;
    margin-left: 8px;
  }
{%- endstyle -%}

<div class="footer section-{{ section.id }}-padding">
  
  <div class="footer-trust-badges">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust_badge' -%}
        <div class="trust-badge-card" {{ block.shopify_attributes }}>
          {%- if block.settings.custom_svg != blank -%}
            {{ block.settings.custom_svg }}
          {%- else -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          {%- endif -%}
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="footer__content-top">
    {%- for block in section.blocks -%}
      {%- if block.type == 'brand_info' -%}
        <div class="footer-block__brand-info" {{ block.shopify_attributes }}>
          {%- if block.settings.brand_image != blank -%}
            <div style="max-width: {{ block.settings.logo_width }}px; margin-bottom: 20px;">
              {{ block.settings.brand_image | image_url: width: 400 | image_tag: loading: 'lazy', style: 'width: 100%; height: auto;' }}
            </div>
          {%- endif -%}
          <div class="footer-block__details-content rte">
            {{ block.settings.text }}
          </div>
          {%- if block.settings.show_social -%}
            {%- render 'social-icons', class: 'footer__list-social' -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    <div class="footer__blocks-wrapper">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-block grid__item" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="footer-block__heading">{{- block.settings.heading -}}</h2>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="footer-block__details-content list-unstyled">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" class="link link--text list-menu__item">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer-block--newsletter">
      <h2 class="footer-block__heading">GET ADDITIONAL 10% OFF</h2>
      <p style="font-size: 14px; color: #4a4a4a; margin-bottom: 20px;">Be the first to hear about new arrivals, exclusive offers, and home inspiration.</p>
      {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form__field-wrapper">
          <div class="field">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="field__input"
              value="{{ form.email }}"
              aria-required="true"
              placeholder="Email Address"
              required
            >
          </div>
          <button type="submit" class="newsletter-form__button field__button" name="commit" id="Subscribe">
            Get 10% off
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>

  <div class="footer__content-bottom">
    <div class="footer__content-bottom-wrapper">
      <div class="footer__copyright caption">
        <small class="copyright__content">Copyright &copy; {{ 'now' | date: '%Y' }} Powered by {{ shop.name }}. All rights reserved.</small>
      </div>
      <div class="footer-right">
        {% assign active_payments = 'visa,master,klarna,apple_pay,google_pay,diners_club,discover' | split: ',' %}
        {% for type in active_payments %}
          {{ type | payment_type_svg_tag: class: 'dp-payment-icon' }}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge (Top Row)",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "SVG Icon Code"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Made in the UK"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subtext",
          "default": "Quality craftsmanship you can trust"
        }
      ]
    },
    {
      "type": "brand_info",
      "name": "Brand Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "brand_image",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 300,
          "step": 10,
          "unit": "px",
          "label": "Logo Width",
          "default": 180
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "label": "Show social icons",
          "default": true
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "trust_badge" },
      { "type": "trust_badge" },
      { "type": "trust_badge" },
      { "type": "trust_badge" },
      { "type": "brand_info" },
      { "type": "link_list" },
      { "type": "link_list" }
    ]
  }
}
{% endschema %}