{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Custom Footer Layout Styles */
  .cx-ftr-wrapper {
    background-color: var(--gradient-base-background-1, transparent);
    color: var(--gradient-base-text, #111);
    font-family: var(--font-body-family);
  }

  .cx-ftr-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Trust Badges Top Row */
  .cx-ftr-trust-row {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 16px;
    margin-bottom: 50px;
  }

  @media screen and (min-width: 750px) {
    .cx-ftr-trust-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (min-width: 990px) {
    .cx-ftr-trust-row {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cx-ftr-trust-badge {
    background-color: rgba(255, 255, 255, 0.45);
    border-radius: 8px;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cx-ftr-trust-icon {
    margin-bottom: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .cx-ftr-trust-icon svg, .cx-ftr-trust-icon img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .cx-ftr-trust-title {
    font-weight: 600;
    font-size: 1.4rem;
    margin: 0 0 6px 0;
    color: inherit;
  }

  .cx-ftr-trust-text {
    font-size: 1.2rem;
    margin: 0;
    opacity: 0.8;
    line-height: 1.4;
  }

  /* Main Footer Columns Grid */
  .cx-ftr-main-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 50px;
  }

  @media screen and (min-width: 750px) {
    .cx-ftr-main-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    /* Precise column ratios to match the screenshot */
    .cx-ftr-main-grid {
      grid-template-columns: 2.2fr 1fr 1fr 1.2fr 1.8fr;
      gap: 30px;
    }
  }

  .cx-ftr-col-heading {
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 20px 0;
    color: inherit;
  }

  /* Brand Info Column */
  .cx-ftr-brand-logo img {
    max-width: 100%;
    height: auto;
    margin-bottom: 20px;
  }
  
  .cx-ftr-brand-text {
    font-size: 1.3rem;
    line-height: 1.6;
    margin-bottom: 24px;
    opacity: 0.85;
  }

  .cx-ftr-socials {
    display: flex;
    gap: 15px;
  }

  .cx-ftr-socials a {
    color: inherit;
    text-decoration: none;
  }

  .cx-ftr-socials svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* Link Lists */
  .cx-ftr-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cx-ftr-menu li {
    margin-bottom: 12px;
  }

  .cx-ftr-menu a {
    text-decoration: none;
    color: inherit;
    font-size: 1.3rem;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .cx-ftr-menu a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Newsletter Column */
  .cx-ftr-nl-text {
    font-size: 1.3rem;
    line-height: 1.5;
    margin-bottom: 20px;
    opacity: 0.85;
  }

  .cx-ftr-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cx-ftr-input {
    width: 100%;
    padding: 12px 20px;
    border-radius: 30px;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    background-color: transparent;
    font-family: inherit;
    font-size: 1.3rem;
    color: inherit;
  }

  .cx-ftr-input:focus {
    outline: none;
    border-color: rgba(var(--color-foreground), 0.5);
  }

  .cx-ftr-btn {
    width: 100%;
    padding: 12px 20px;
    border-radius: 30px;
    background-color: #D1B38E; /* Exact tan from screenshot */
    color: #FFFFFF;
    border: none;
    font-family: inherit;
    font-size: 1.3rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    text-align: center;
  }

  .cx-ftr-btn:hover {
    background-color: #bd9b72;
  }

  /* Bottom Bar */
  .cx-ftr-bottom {
    display: flex;
    flex-direction: column-reverse;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding-top: 25px;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
  }

  @media screen and (min-width: 750px) {
    .cx-ftr-bottom {
      flex-direction: row;
    }
  }

  .cx-ftr-copyright {
    font-size: 1.2rem;
    opacity: 0.7;
  }

  .cx-ftr-payments {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cx-ftr-payments svg {
    width: 38px;
    height: 24px;
  }
{%- endstyle -%}

<div class="cx-ftr-wrapper color-{{ section.settings.color_scheme }} gradient">
  <footer class="cx-ftr-container section-{{ section.id }}-padding">
    
    {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
    {%- if trust_blocks.size > 0 -%}
      <div class="cx-ftr-trust-row">
        {%- for block in trust_blocks -%}
          <div class="cx-ftr-trust-badge" {{ block.shopify_attributes }}>
            <div class="cx-ftr-trust-icon">
              {%- if block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 64 }}" alt="{{ block.settings.title }}" loading="lazy">
              {%- endif -%}
            </div>
            <h4 class="cx-ftr-trust-title">{{ block.settings.title }}</h4>
            <p class="cx-ftr-trust-text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="cx-ftr-main-grid">
      {%- for block in section.blocks -%}
        {%- if block.type != 'trust_badge' -%}
          <div class="cx-ftr-column" {{ block.shopify_attributes }}>
            
            {%- case block.type -%}
              {%- when 'brand_info' -%}
                {%- if block.settings.logo != blank -%}
                  <div class="cx-ftr-brand-logo" style="max-width: {{ block.settings.logo_width }}px;">
                    <img src="{{ block.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" loading="lazy">
                  </div>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="cx-ftr-brand-text">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.show_social -%}
                  <div class="cx-ftr-socials">
                    {% render 'social-icons' %}
                  </div>
                {%- endif -%}

              {%- when 'link_list' -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="cx-ftr-col-heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="cx-ftr-menu">
                    {%- for link in block.settings.menu.links -%}
                      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'newsletter_column' -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="cx-ftr-col-heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="cx-ftr-nl-text">{{ block.settings.text }}</div>
                {%- endif -%}
                
                {%- form 'customer', id: 'ContactFooter', class: 'cx-ftr-form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="cx-ftr-input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    placeholder="Email Address"
                    required
                  >
                  <button type="submit" class="cx-ftr-btn" name="commit">
                    {{ block.settings.button_label }}
                  </button>
                  {%- if form.posted_successfully? -%}
                    <p style="color: #2e7d32; font-size: 1.2rem; margin-top: 5px;">Subscribed successfully!</p>
                  {%- endif -%}
                {%- endform -%}

            {%- endcase -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cx-ftr-bottom">
      <div class="cx-ftr-copyright">
        Copyright &copy; {{ 'now' | date: '%Y' }} Powered by {{ shop.name }}. All rights reserved.
      </div>
      
      {%- if section.settings.payment_enable -%}
        <div class="cx-ftr-payments">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </footer>
</div>

{% schema %}
{
  "name": "Footer (Custom Pixel)",
  "max_blocks": 10,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Show payment icons"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge (Top Row)",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG code here for best quality."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback Image Icon (If no SVG)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Made in the UK"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subtext",
          "default": "Quality craftsmanship you can trust"
        }
      ]
    },
    {
      "type": "brand_info",
      "name": "Brand Info Column",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 300,
          "step": 10,
          "default": 180,
          "unit": "px",
          "label": "Logo Width"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Brand Description",
          "default": "<p>At Sofas'n'Beds, excellence isn't just a promise; it's our ethos...</p>"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "label": "Show Social Icons",
          "default": true
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Link Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "CUSTOMER SERVICE"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    },
    {
      "type": "newsletter_column",
      "name": "Newsletter Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "GET ADDITIONAL 10% OFF"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Be the first to hear about new arrivals, exclusive offers, and home inspiration.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Get 10% off"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customized Footer",
      "blocks": [
        { "type": "trust_badge" },
        { "type": "trust_badge" },
        { "type": "trust_badge" },
        { "type": "trust_badge" },
        { "type": "brand_info" },
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "newsletter_column" }
      ]
    }
  ]
}
{% endschema %}